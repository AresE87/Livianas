---
import Layout from '../layouts/Layout.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { siteConfig, getConsultorioWhatsAppLink } from '../lib/config';

const c = siteConfig.consultorio;
const waDudas = getConsultorioWhatsAppLink('dudas');
---

<Layout
  title="Consultorio con Ana — Renová tu acompañamiento"
  description="Ya sos parte. Renová tu acompañamiento con Ana y seguí transformando tu relación con la comida. Desde $ 900/mes."
>
  <!-- ========== HERO ========== -->
  <section class="hero">
    <div class="hero__topbar">
      <span class="hero__wordmark">LIVIANAS</span>
    </div>
    <div class="container hero__inner">
      <h1 class="hero__title">Seguí creciendo con Ana</h1>
      <p class="hero__subtitle">
        Ya sos parte. Renová tu acompañamiento y seguí transformando tu relación con la comida.
      </p>
      <a href="#pricing" class="btn btn--primary hero__cta">Ver planes</a>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section pricing" id="pricing">
    <div class="container">
      <h2 class="section-heading">Renová tu plan</h2>
      <div class="pricing__grid">
        <!-- Mensual -->
        <div class="pricing__card">
          <div class="pricing__card-header">
            <h3 class="pricing__plan-name">{c.internas.mensual.label}</h3>
          </div>
          <div class="pricing__price-wrap">
            <span class="pricing__price">$ 900</span>
            <span class="pricing__period">/mes</span>
          </div>
          <a
            href={c.internas.mensual.link}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--secondary pricing__btn"
          >
            Renovar 1 mes
          </a>
        </div>

        <!-- Trimestral -->
        <div class="pricing__card pricing__card--featured">
          <span class="pricing__badge">Ahorrá $ 200</span>
          <div class="pricing__card-header">
            <h3 class="pricing__plan-name">{c.internas.trimestral.label}</h3>
          </div>
          <div class="pricing__price-wrap">
            <span class="pricing__price">$ 2.500</span>
            <span class="pricing__period">/trimestre</span>
          </div>
          <p class="pricing__monthly">~$ 833/mes</p>
          <a
            href={c.internas.trimestral.link}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--primary pricing__btn"
          >
            Renovar 3 meses
          </a>
        </div>
      </div>

      <div class="pricing__special">
        <p>Precio especial para quienes ya son parte del grupo</p>
      </div>

      <div class="pricing__trust">
        <p>Pago seguro por Mercado Pago &middot; Cancelá cuando quieras</p>
      </div>
    </div>
  </section>

  <!-- ========== RECORDATORIO ========== -->
  <section class="section recordatorio">
    <div class="container container--narrow">
      <h2 class="section-heading">Tu acompañamiento incluye:</h2>
      <div class="recordatorio__list">
        {c.includes.map((item) => (
          <div class="recordatorio__item">
            <div class="recordatorio__check">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <div class="recordatorio__text">
              <h3 class="recordatorio__title">{item.title}</h3>
              <p class="recordatorio__desc">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section class="section cta-final">
    <div class="container cta-final__inner">
      <h2 class="cta-final__title">¿Dudas? Hablá con Ana</h2>
      <div class="cta-final__buttons">
        <a
          href={waDudas}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--whatsapp"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Hablar con Ana por WhatsApp
        </a>
      </div>

      <div class="cta-final__plans">
        <a
          href={c.internas.mensual.link}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--secondary"
        >
          Renovar 1 mes — $ 900
        </a>
        <a
          href={c.internas.trimestral.link}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--primary"
        >
          Renovar 3 meses — $ 2.500
        </a>
      </div>
    </div>
  </section>

  <WhatsAppButton />
</Layout>

<style>
  /* Override global .section padding — this is a short funnel page */
  .section {
    padding: var(--space-12) 0;
  }

  @media (min-width: 768px) {
    .section {
      padding: var(--space-16) 0;
    }
  }

  /* ===== HERO ===== */
  .hero {
    background: linear-gradient(180deg, var(--color-sage-wash) 0%, var(--color-cream-warm) 100%);
    padding-bottom: var(--space-16);
  }

  .hero__topbar {
    padding: var(--space-4) var(--space-6);
  }

  .hero__wordmark {
    font-family: var(--font-outfit);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.2em;
    color: var(--color-sage);
  }

  .hero__inner {
    text-align: center;
    padding-top: var(--space-10);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-text);
    margin-bottom: var(--space-4);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-8);
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 768px) {
    .hero {
      padding-bottom: var(--space-20);
    }

    .hero__inner {
      padding-top: var(--space-16);
    }
  }

  /* ===== SECTION HEADING ===== */
  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 500;
    text-align: center;
    color: var(--color-text);
    margin-bottom: var(--space-12);
  }

  /* ===== PRICING ===== */
  .pricing {
    background: var(--color-cream);
  }

  .pricing__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 700px;
    margin: 0 auto;
  }

  @media (min-width: 600px) {
    .pricing__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .pricing__card {
    position: relative;
    background: var(--color-white);
    border: 1.5px solid var(--color-sand);
    border-radius: var(--radius-xl);
    padding: var(--space-8) var(--space-6);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .pricing__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .pricing__card--featured {
    border-color: var(--color-sage);
    border-width: 2px;
    box-shadow: var(--shadow-glow-sage);
  }

  .pricing__badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-white);
    background: var(--color-blush);
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .pricing__plan-name {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .pricing__price-wrap {
    display: flex;
    align-items: baseline;
    gap: var(--space-1);
  }

  .pricing__price {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 600;
    color: var(--color-text);
  }

  .pricing__period {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .pricing__monthly {
    font-size: var(--text-sm);
    color: var(--color-sage-dark);
    font-weight: 600;
    margin-top: calc(-1 * var(--space-2));
  }

  .pricing__btn {
    width: 100%;
    margin-top: var(--space-2);
  }

  .pricing__special {
    text-align: center;
    margin-top: var(--space-6);
  }

  .pricing__special p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .pricing__trust {
    text-align: center;
    margin-top: var(--space-4);
  }

  .pricing__trust p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* ===== RECORDATORIO ===== */
  .recordatorio {
    background: var(--color-white);
  }

  .recordatorio__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 600px;
    margin: 0 auto;
  }

  .recordatorio__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--color-cream);
    border-radius: var(--radius-xl);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .recordatorio__item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .recordatorio__check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: var(--radius-lg);
    background: var(--color-sage-wash);
    color: var(--color-sage);
  }

  .recordatorio__title {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .recordatorio__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ===== CTA FINAL ===== */
  .cta-final {
    background: linear-gradient(180deg, var(--color-sage-wash) 0%, var(--color-cream-warm) 100%);
  }

  .cta-final__inner {
    text-align: center;
  }

  .cta-final__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4.5vw, 2.5rem);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-8);
  }

  .cta-final__buttons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .cta-final__plans {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  @media (min-width: 600px) {
    .cta-final__buttons {
      flex-direction: row;
      justify-content: center;
    }

    .cta-final__plans {
      flex-direction: row;
      justify-content: center;
    }
  }

  /* WhatsApp CTA button */
  .btn--whatsapp {
    background: var(--color-whatsapp);
    color: var(--color-white);
    padding: var(--space-4) var(--space-8);
    border-radius: var(--radius-full);
    font-size: var(--text-base);
    box-shadow: var(--shadow-md);
  }

  .btn--whatsapp:hover {
    background: var(--color-whatsapp-hover);
    box-shadow: 0 0 30px rgba(18, 140, 126, 0.35);
  }
</style>
