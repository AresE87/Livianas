---
import Layout1a1 from '../../layouts/Layout1a1.astro';
import { site1a1Config, getWhatsAppLink1a1, getPaymentLink1a1, painPoints1a1Data, transformation1a1Data, phases1a1Data, includes1a1Data, paraQuienEs1a1Data, pricingFeatures1a1, faq1a1Data } from '../../lib/config-1a1';
import CountdownTimer from '../../components/CountdownTimer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';

const paymentHref = getPaymentLink1a1();
const whatsappHero = getWhatsAppLink1a1('hero');
const whatsappPricing = getWhatsAppLink1a1('pricing');
const whatsappFinal = getWhatsAppLink1a1('finalCta');
const whatsappFloating = getWhatsAppLink1a1('floating');

// Icons for includes cards
const icons = [
  // 1. Sessions — Person with circle
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="18" cy="12" r="5" stroke="currentColor" stroke-width="1.4"/>
    <path d="M8 30c0-5.5 4.5-10 10-10s10 4.5 10 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    <circle cx="18" cy="12" r="2" fill="currentColor" opacity="0.3"/>
  </svg>`,
  // 2. Nutrition — Leaf
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M8 30c0-12 9-20 22-22C28 20 19 28 8 30z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M8 30C17 21 21 15 30 8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
  </svg>`,
  // 3. WhatsApp — Chat bubble
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M6 28l2-6a12 12 0 1 1 4.8 4.8L6 28z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M14 16h8M14 20h5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
  </svg>`,
  // 4. Emotional — Heart
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M18 29s-10-6.5-10-14a6 6 0 0 1 10-4.5A6 6 0 0 1 28 15c0 7.5-10 14-10 14z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  // 5. Progress — Chart up
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M6 28L14 18l6 4 10-14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M24 8h6v6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  // 6. Recordings — Play circle
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="18" cy="18" r="13" stroke="currentColor" stroke-width="1.4"/>
    <path d="M15 12.5l9 5.5-9 5.5z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
];

const cardBackgrounds = [
  'var(--color-white)',
  'var(--color-blush-wash)',
  'var(--color-sage-wash)',
  'var(--color-lavender-wash)',
  'var(--color-blush-wash)',
  'var(--color-sage-wash)',
];

const iconColors = [
  'var(--color-sage)',
  'var(--color-blush)',
  'var(--color-sage-dark)',
  'var(--color-lavender)',
  'var(--color-blush-dark)',
  'var(--color-sage)',
];
---

<Layout1a1>
  <!-- ==========================================
       NAVBAR
       ========================================== -->
  <nav id="navbar" class="navbar" aria-label="Navegacion principal">
    <div class="navbar__inner">
      <a href="/1a1" class="navbar__logo" aria-label="LIVIANAS 1:1 - Inicio">
        LIVIANAS <span class="navbar__logo-badge">1:1</span>
      </a>
      <div class="navbar__links" role="navigation">
        <a href="#programa" class="navbar__link">Programa</a>
        <a href="#precio" class="navbar__link">Precio</a>
        <a href="#faq" class="navbar__link">FAQ</a>
        <span class="navbar__divider" aria-hidden="true"></span>
        <span class="navbar__countdown">
          <span class="navbar__countdown-dot" aria-hidden="true"></span>
          Solo {site1a1Config.cuposDisponibles} cupos
        </span>
      </div>
      <a href={whatsappHero} target="_blank" rel="noopener noreferrer" class="navbar__cta" data-utm="navbar-1a1">
        {site1a1Config.ctaMessages.secondary}
      </a>
      <button class="navbar__hamburger" aria-label="Abrir menu" aria-expanded="false" aria-controls="mobile-menu-1a1" type="button">
        <span class="navbar__hamburger-line" aria-hidden="true"></span>
        <span class="navbar__hamburger-line" aria-hidden="true"></span>
        <span class="navbar__hamburger-line" aria-hidden="true"></span>
      </button>
    </div>
    <div id="mobile-menu-1a1" class="navbar__mobile" aria-hidden="true">
      <a href="#programa" class="navbar__mobile-link">Programa</a>
      <a href="#precio" class="navbar__mobile-link">Precio</a>
      <a href="#faq" class="navbar__mobile-link">FAQ</a>
      <div class="navbar__mobile-divider"></div>
      <span class="navbar__mobile-countdown">
        <span class="navbar__countdown-dot" aria-hidden="true"></span>
        Solo {site1a1Config.cuposDisponibles} cupos disponibles
      </span>
      <a href={whatsappHero} target="_blank" rel="noopener noreferrer" class="navbar__mobile-cta btn btn--primary" data-utm="navbar-mobile-1a1">
        {site1a1Config.ctaMessages.secondary}
      </a>
    </div>
  </nav>

  <!-- ==========================================
       HERO
       ========================================== -->
  <section id="hero" class="hero" aria-label="Presentacion principal">
    <div class="hero__bg" aria-hidden="true">
      <img
        src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=1920&q=80"
        alt=""
        class="hero__bg-image"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <div class="hero__overlay"></div>
    </div>

    <div class="hero__badge" data-gsap="hero-label">
      <span class="hero__badge-text">Programa Individual &middot; 3 Meses &middot; 100% Personalizado</span>
    </div>

    <div class="hero__content">
      <div class="hero__title-block" data-gsap="hero-title">
        <span class="hero__title-line hero__title-line--sans">Solo vos</span>
        <span class="hero__title-line hero__title-line--serif">y Ana.</span>
        <p class="hero__title-sub">
          3 meses de acompa&ntilde;amiento individual para transformar tu relaci&oacute;n con la comida, tu cuerpo y tus emociones. De ra&iacute;z.
        </p>
      </div>

      <p class="hero__subtitle" data-gsap="hero-subtitle">
        12 sesiones 1:1 &middot; Solo {site1a1Config.cuposDisponibles} cupos &middot; Conducta, emoci&oacute;n y espiritualidad
      </p>

      <div class="hero__ctas" data-gsap="hero-ctas">
        <a href={whatsappHero} target="_blank" rel="noopener noreferrer" class="btn btn--primary hero__cta-primary" data-utm="hero-primary-1a1">
          {site1a1Config.ctaMessages.primary}
          <svg class="hero__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <div class="hero__scroll-track">
        <svg class="hero__scroll-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6" />
        </svg>
      </div>
    </div>
  </section>

  <!-- ==========================================
       EXCLUSIVE BADGE SECTION
       ========================================== -->
  <section class="exclusive-section section" data-gsap="exclusive">
    <div class="container container--narrow">
      <div class="exclusive-card">
        <div class="exclusive-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <h2 class="exclusive-title">
          &iquest;Por qu&eacute; un programa <em>1 a 1</em>?
        </h2>
        <p class="exclusive-text">
          Porque tu historia es &uacute;nica. Porque lo que necesit&aacute;s no es otro programa gen&eacute;rico, sino alguien que te mire a vos, escuche tu proceso y dise&ntilde;e un camino hecho a tu medida. En el programa 1:1, Ana trabaja exclusivamente con vos durante 3 meses completos.
        </p>
      </div>
    </div>
  </section>

  <!-- ==========================================
       MANIFESTO / PARA QUIEN ES
       ========================================== -->
  <section id="manifesto" class="manifesto-section">
    <div class="manifesto-bg" aria-hidden="true"></div>
    <div class="manifesto-overlay" aria-hidden="true"></div>
    <div class="container manifesto-container">
      <div class="manifesto-comparison">
        <div class="manifesto-block manifesto-block--old" data-gsap="manifesto-text">
          <span class="manifesto-label">Lo que ven&iacute;as haciendo:</span>
          <p class="manifesto-question manifesto-question--crossed">
            buscar soluciones gen&eacute;ricas que no funcionan
          </p>
        </div>
        <div class="manifesto-divider" data-gsap="manifesto-text" aria-hidden="true">
          <svg width="2" height="80" viewBox="0 0 2 80" fill="none">
            <line x1="1" y1="0" x2="1" y2="80" stroke="var(--color-sage)" stroke-width="2" stroke-dasharray="4 6" opacity="0.3"/>
          </svg>
        </div>
        <div class="manifesto-block manifesto-block--new" data-gsap="manifesto-text">
          <span class="manifesto-label manifesto-label--clay">Lo que necesit&aacute;s:</span>
          <p class="manifesto-question manifesto-question--big">
            que alguien te mire a vos.
          </p>
        </div>
      </div>

      <div class="manifesto-checklist" data-gsap="manifesto-text">
        <h3 class="manifesto-checklist__title">El programa 1:1 es para vos si...</h3>
        <ul class="manifesto-checklist__list">
          {paraQuienEs1a1Data.map((item) => (
            <li class="manifesto-checklist__item">
              <span class="manifesto-checklist__dot" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="manifesto-cta" data-gsap="manifesto-text">
        <a href="#programa" class="manifesto-cta__link">
          Conoc&eacute; el programa
          <svg class="manifesto-cta__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 3v10M4 9l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ==========================================
       3 PHASES (like Features/Weeks)
       ========================================== -->
  <section id="features" class="section features-section">
    <div class="container">
      <header class="features-header" data-gsap="features-header">
        <h2 class="features-title">
          <span class="features-title__serif">Tres meses.</span>
          <span class="features-title__sans">Una transformaci&oacute;n profunda.</span>
        </h2>
        <p class="features-subtitle">
          Cada mes abre una nueva fase de tu proceso: diagn&oacute;stico, transformaci&oacute;n e integraci&oacute;n. Todo adaptado a vos.
        </p>
      </header>

      <div class="weeks-grid weeks-grid--3" data-gsap="features-weeks">
        {phases1a1Data.map((phase) => (
          <article class="feature-panel week-card" style={`--card-gradient: ${phase.gradient};`}>
            <div class="week-card__badge">
              <span class="week-card__badge-text">{phase.duration}</span>
            </div>
            <div class="week-card__icon" aria-hidden="true">
              {phase.number === 1 && (
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="24" cy="14" r="6" />
                  <circle cx="24" cy="14" r="2" />
                  <path d="M24 20v18" />
                  <path d="M18 32c0-4 2.7-7 6-7s6 3 6 7" />
                </svg>
              )}
              {phase.number === 2 && (
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M24 6c-2 8-10 14-10 22a10 10 0 0020 0C34 20 26 14 24 6z" />
                  <path d="M24 44c-3 0-5-2.5-5-6 0-5 5-9 5-9s5 4 5 9c0 3.5-2 6-5 6z" />
                </svg>
              )}
              {phase.number === 3 && (
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M24 6l-12 12 12 22 12-22L24 6z" />
                  <path d="M12 18h24" />
                  <path d="M18 6l-6 12" />
                  <path d="M30 6l6 12" />
                  <path d="M24 18l-6-12" />
                  <path d="M24 18l6-12" />
                </svg>
              )}
            </div>
            <h3 class="week-card__title">{phase.title}</h3>
            <span class="week-card__name">{phase.name}</span>
            <p class="week-card__description">{phase.description}</p>
          </article>
        ))}
      </div>

      <!-- Transformation: Before → After -->
      <div class="transformation" data-gsap="features-transformation">
        <div class="transformation__header">
          <h3 class="transformation__title">
            <span class="transformation__title-serif">De donde est&aacute;s</span>
            <span class="transformation__title-sans">a donde quer&eacute;s llegar</span>
          </h3>
        </div>
        <div class="transformation__list">
          {transformation1a1Data.map((item) => (
            <div class="transformation__row feature-panel">
              <div class="transformation__from">
                <span class="transformation__label transformation__label--from">Antes</span>
                <p class="transformation__text transformation__text--from">{item.from}</p>
              </div>
              <div class="transformation__divider">
                <svg class="transformation__arrow" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <div class="transformation__elegant-arrow" aria-hidden="true">
                  <span class="transformation__line"></span>
                  <svg viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m1 1 5 5 5-5" />
                  </svg>
                </div>
              </div>
              <div class="transformation__to">
                <span class="transformation__label transformation__label--to">Despu&eacute;s</span>
                <p class="transformation__text transformation__text--to">{item.to}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       PROGRAM ARCHIVE / INCLUDES
       ========================================== -->
  <section id="programa" aria-labelledby="archive-title-1a1" class="archive-section section">
    <div class="container">
      <div class="archive-header" data-gsap="archive-header">
        <h2 id="archive-title-1a1" class="archive-title">
          <span class="archive-title-serif">Todo lo que incluye</span>
          <br />
          <span class="archive-title-sans">tu programa 1:1.</span>
        </h2>
        <p class="archive-subtitle">
          3 meses de acompa&ntilde;amiento completo, dise&ntilde;ado exclusivamente para vos.
        </p>
      </div>

      <div class="archive-grid" role="list">
        {includes1a1Data.map((item, i) => (
          <article
            class="archive-card"
            data-gsap="archive-card"
            role="listitem"
            style={`--card-bg: ${cardBackgrounds[i]}; --icon-color: ${iconColors[i]};`}
          >
            <div class="archive-card-inner">
              <div class="archive-card-icon" set:html={icons[i]} />
              <h3 class="archive-card-title">{item.title}</h3>
              <p class="archive-card-desc">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ==========================================
       ABOUT ANA
       ========================================== -->
  <section id="sobre-ana" aria-labelledby="about-ana-title-1a1" class="about-section section">
    <div class="container">
      <div class="about-wrapper" data-gsap="about">
        <div class="about-grid">
          <div class="about-image-col">
            <div class="about-image-frame">
              <img
                src="/images/ana-foto.webp"
                alt="Ana, creadora del M&eacute;todo Livianas"
                width="480"
                height="600"
                loading="lazy"
                decoding="async"
                class="about-image"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
              />
              <div class="about-image-placeholder">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
                <span class="about-placeholder-text">Foto de Ana</span>
              </div>
            </div>
          </div>
          <div class="about-text-col">
            <span class="about-label">SOBRE ANA</span>
            <blockquote class="about-quote">
              &ldquo;En el 1 a 1 puedo ver lo que nadie m&aacute;s ve. Porque te dedico toda mi atenci&oacute;n a vos.&rdquo;
            </blockquote>
            <p class="about-bio">
              Ana es coach de bienestar y creadora del M&eacute;todo Livianas. En el programa 1:1, trabaja de manera individual y profunda con cada mujer, adapt&aacute;ndose a su historia, sus necesidades y su ritmo. Conducta, emoci&oacute;n y espiritualidad &mdash; todo en un proceso hecho a medida.
            </p>
            <div class="about-detail">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="about-detail-icon">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <span>Programa 100% individual &middot; Solo {site1a1Config.cuposDisponibles} cupos simult&aacute;neos</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       PRICING
       ========================================== -->
  <section id="precio" aria-labelledby="precio-title-1a1" class="premium-pricing section">
    <div class="container">
      <div class="pricing-header" data-gsap="pricing-header">
        <h2 id="precio-title-1a1" class="pricing-title">
          <span class="pricing-title-serif">Tu inversi&oacute;n</span>
          <span class="pricing-title-sans">en tu transformaci&oacute;n.</span>
        </h2>
      </div>

      <div class="pricing-countdown" data-gsap="pricing-countdown">
        <p class="pricing-countdown-label">Las inscripciones cierran en:</p>
        <CountdownTimer variant="section" />
      </div>

      <div class="pricing-card" data-gsap="pricing-card">
        <div class="pricing-badge-wrap">
          <span class="pricing-badge">Programa Exclusivo 1:1</span>
        </div>
        <p class="pricing-program-name">LIVIANAS &mdash; 3 Meses Personalizado</p>
        <div class="pricing-prices">
          <span class="pricing-old-price">USD {site1a1Config.valorTotal}</span>
          <div class="pricing-main-price">
            <span class="pricing-currency">USD</span>
            <span class="pricing-amount">{site1a1Config.precioUSD}</span>
          </div>
          <p class="pricing-weekly">USD {site1a1Config.precioMensual} por mes &middot; 3 meses</p>
          <p class="pricing-installments">Cuotas disponibles con tarjeta de cr&eacute;dito</p>
        </div>
        <div class="pricing-divider"></div>
        <ul class="pricing-features" role="list">
          {pricingFeatures1a1.map((feature) => (
            <li class="pricing-feature-item">
              <span class="pricing-check">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </span>
              <span>{feature}</span>
            </li>
          ))}
        </ul>
        <div class="pricing-ctas">
          <a href={whatsappPricing} target="_blank" rel="noopener noreferrer" class="btn btn--ghost-card" data-utm="pricing-secondary-1a1">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            {site1a1Config.ctaMessages.secondary}
          </a>
          <a href={whatsappPricing} target="_blank" rel="noopener noreferrer" class="btn btn--clay" data-utm="pricing-primary-1a1">
            {site1a1Config.ctaMessages.primary}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <div class="pricing-mp-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            Pag&aacute; con Mercado Pago &middot; Cuotas disponibles
          </div>
        </div>
      </div>

      <p class="pricing-below-note" data-gsap="pricing-note">
        Son USD {site1a1Config.precioMensual} por mes de coaching individual, acompa&ntilde;amiento ilimitado y un plan 100% hecho a tu medida.
