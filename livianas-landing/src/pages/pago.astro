---
import Layout from '../layouts/Layout.astro';
import { siteConfig, getDirectPaymentLink, getWhatsAppLink } from '../lib/config';

const mpLink = getDirectPaymentLink('mercadoPago');
const paypalLink = getDirectPaymentLink('paypal');
const whatsappLink = getWhatsAppLink('pricing');
const hasMp = mpLink !== '#';
const hasPaypal = paypalLink !== '#';
---

<Layout
  title="Completar inscripcion — LIVIANAS"
  description="Elegí tu forma de pago y asegurá tu lugar en el próximo círculo LIVIANAS."
>
  <main class="pago">
    <img
      class="pago__bg"
      src="https://images.unsplash.com/photo-1676877883867-4fd7e3e17caa?w=1920&q=80"
      alt=""
      loading="eager"
      aria-hidden="true"
    />
    <div class="pago__overlay"></div>
    <div class="pago__container">

      <!-- Back link -->
      <a href="/" class="pago__back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Volver
      </a>

      <!-- Header -->
      <header class="pago__header">
        <span class="pago__logo">LIVIANAS</span>
        <h1 class="pago__title">
          <span class="pago__title-serif">Completá</span>
          <span class="pago__title-sans">tu inscripción</span>
        </h1>
        <p class="pago__subtitle">
          Experiencia 30 Días — Próximo círculo: {siteConfig.fechaInicioCírculo}
        </p>
      </header>

      <!-- Summary Card -->
      <div class="pago__summary">
        <div class="pago__summary-row">
          <span>LIVIANAS — Experiencia 30 Días</span>
          <span class="pago__summary-old">USD {siteConfig.valorTotal}</span>
        </div>
        <div class="pago__summary-row pago__summary-row--total">
          <span>Total a pagar</span>
          <span class="pago__summary-price">USD {siteConfig.precioUSD}</span>
        </div>
        <p class="pago__summary-note">Pago único · Sin suscripciones · Sin cargos ocultos</p>
      </div>

      <!-- Payment Options -->
      <div class="pago__options">
        <h2 class="pago__options-title">Elegí tu forma de pago</h2>

        <a href={hasMp ? mpLink : whatsappLink} target="_blank" rel="noopener noreferrer" class="pago__option pago__option--mp">
          <div class="pago__option-icon">
            <img src="/images/mercadopago-logo.png" alt="Mercado Pago" width="36" height="36" />
          </div>
          <div class="pago__option-body">
            <div class="pago__option-top">
              <div>
                <span class="pago__option-name">Mercado Pago</span>
                <span class="pago__option-region">Uruguay y Latinoam&eacute;rica</span>
              </div>
              <svg class="pago__option-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
            <ul class="pago__option-details">
              <li>Tarjeta de cr&eacute;dito (cuotas disponibles)</li>
              <li>Tarjeta de d&eacute;bito</li>
              <li>Transferencia bancaria</li>
            </ul>
          </div>
        </a>

        <a href={hasPaypal ? paypalLink : whatsappLink} target="_blank" rel="noopener noreferrer" class="pago__option pago__option--paypal">
          <div class="pago__option-icon">
            <img src="/images/paypal-logo-clean.png" alt="PayPal" width="36" height="36" />
          </div>
          <div class="pago__option-body">
            <div class="pago__option-top">
              <div>
                <span class="pago__option-name">PayPal</span>
                <span class="pago__option-region">Uruguay y Latinoam&eacute;rica</span>
              </div>
              <svg class="pago__option-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
            <ul class="pago__option-details">
              <li>Tarjeta de cr&eacute;dito internacional</li>
              <li>Saldo de PayPal</li>
            </ul>
          </div>
        </a>
      </div>

      <!-- Guarantee -->
      <div class="pago__guarantee">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <div>
          <strong>Garantía de devolución</strong>
          <p>Si durante la primera semana sentís que no es para vos, te devolvemos el 100% de tu inversión. Sin preguntas, sin vueltas. Queremos que estés segura de tu decisión.</p>
        </div>
      </div>

      <!-- What happens after -->
      <div class="pago__next-steps">
        <h3 class="pago__next-title">Después de pagar:</h3>
        <ol class="pago__steps">
          <li>Recibís confirmación inmediata por WhatsApp</li>
          <li>Ana te da la bienvenida personalmente</li>
          <li>Te sumás al grupo privado del círculo</li>
          <li>Empezás el {siteConfig.fechaInicioCírculo}</li>
        </ol>
      </div>

      <!-- Help -->
      <div class="pago__help">
        <p>¿Tenés dudas sobre el pago?</p>
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="pago__help-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          Escribile a Ana
        </a>
      </div>

      <!-- Trust -->
      <div class="pago__trust">
        <span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Pago 100% seguro
        </span>
        <span>&middot;</span>
        <span>Datos encriptados</span>
      </div>

    </div>
  </main>
</Layout>

<style>
  .pago {
    min-height: 100dvh;
    position: relative;
    padding: var(--space-8) var(--space-4);
    overflow: hidden;
  }

  .pago__bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 55%;
    z-index: 0;
  }

  .pago__overlay {
    position: fixed;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(251, 249, 245, 0.35) 0%,
      rgba(251, 249, 245, 0.55) 20%,
      rgba(251, 249, 245, 0.82) 45%,
      rgba(251, 249, 245, 0.95) 70%,
      rgba(251, 249, 245, 1) 100%
    );
  }

  .pago__container {
    max-width: 520px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  /* --- Back --- */
  .pago__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-carbon);
    text-decoration: none;
    margin-bottom: var(--space-8);
    transition: color var(--transition-base);
    opacity: 0.7;
  }

  .pago__back:hover {
    opacity: 1;
  }

  /* --- Header --- */
  .pago__header {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .pago__logo {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.2em;
    color: var(--color-sage-dark);
    display: block;
    margin-bottom: var(--space-4);
  }

  .pago__title {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-3);
  }

  .pago__title-serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: var(--text-4xl);
    color: var(--color-carbon);
    line-height: 1.1;
  }

  .pago__title-sans {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-2xl);
    color: var(--color-sage-dark);
    line-height: 1.2;
  }

  .pago__subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-carbon);
    opacity: 0.7;
  }

  /* --- Summary --- */
  .pago__summary {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: var(--space-5);
    margin-bottom: var(--space-8);
  }

  .pago__summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: var(--space-2) 0;
  }

  .pago__summary-old {
    text-decoration: line-through;
    opacity: 0.6;
  }

  .pago__summary-row--total {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-2);
    padding-top: var(--space-3);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-carbon);
  }

  .pago__summary-price {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-2xl);
    color: var(--color-sage-dark);
  }

  .pago__summary-note {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-align: center;
    margin-top: var(--space-3);
    opacity: 0.7;
  }

  /* --- Payment Options --- */
  .pago__options {
    margin-bottom: var(--space-8);
  }

  .pago__options-title {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-carbon);
    margin-bottom: var(--space-4);
    text-align: center;
  }

  .pago__option {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    background: var(--color-white);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: var(--space-5);
    margin-bottom: var(--space-3);
    text-decoration: none;
    color: var(--color-carbon);
    transition: all var(--transition-base);
  }

  .pago__option:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  /* Brand colors on hover */
  .pago__option--mp:hover {
    border-color: #009ee3;
  }

  .pago__option--paypal:hover {
    border-color: #0070ba;
  }

  /* Icon circle */
  .pago__option-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .pago__option--mp .pago__option-icon {
    background: #e8f4fd;
  }

  .pago__option--paypal .pago__option-icon {
    background: #e6f0f9;
  }

  .pago__option-icon img {
    width: 36px;
    height: 36px;
    object-fit: contain;
  }

  .pago__option-body {
    flex: 1;
    min-width: 0;
  }

  .pago__option-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .pago__option-top > div {
    display: flex;
    flex-direction: column;
  }

  .pago__option-name {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-lg);
  }

  .pago__option--mp .pago__option-name {
    color: #009ee3;
  }

  .pago__option--paypal .pago__option-name {
    color: #003087;
  }

  .pago__option-region {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pago__option-arrow {
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  .pago__option--mp .pago__option-arrow {
    color: #009ee3;
  }

  .pago__option--paypal .pago__option-arrow {
    color: #0070ba;
  }

  .pago__option:hover .pago__option-arrow {
    transform: translateX(4px);
  }

  .pago__option-details {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-4);
  }

  .pago__option-details li {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    position: relative;
    padding-left: var(--space-3);
  }

  .pago__option-details li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    opacity: 0.5;
  }

  .pago__option--mp .pago__option-details li::before {
    background: #009ee3;
  }

  .pago__option--paypal .pago__option-details li::before {
    background: #0070ba;
  }

  /* --- Guarantee --- */
  .pago__guarantee {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    background: var(--color-sage-wash);
    border: 1px solid rgba(123, 143, 107, 0.15);
    border-radius: var(--radius-2xl);
    padding: var(--space-5);
    margin-bottom: var(--space-6);
  }

  .pago__guarantee svg {
    flex-shrink: 0;
    color: var(--color-sage);
    margin-top: 2px;
  }

  .pago__guarantee strong {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-sage-dark);
    display: block;
    margin-bottom: var(--space-1);
  }

  .pago__guarantee p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* --- Next Steps --- */
  .pago__next-steps {
    margin-bottom: var(--space-6);
  }

  .pago__next-title {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-carbon);
    margin-bottom: var(--space-3);
  }

  .pago__steps {
    list-style: none;
    padding: 0;
    counter-reset: steps;
  }

  .pago__steps li {
    counter-increment: steps;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: var(--space-2) 0;
    line-height: 1.5;
  }

  .pago__steps li::before {
    content: counter(steps);
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-sage-wash);
    color: var(--color-sage-dark);
    font-size: var(--text-xs);
    font-weight: 700;
    border-radius: 50%;
  }

  /* --- Help --- */
  .pago__help {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .pago__help p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .pago__help-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-sage-dark);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .pago__help-link:hover {
    color: var(--color-sage);
  }

  /* --- Trust --- */
  .pago__trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    opacity: 0.6;
    padding-bottom: var(--space-8);
  }

  .pago__trust span {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }
</style>
