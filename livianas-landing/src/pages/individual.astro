  .ind-footer__links { display: flex; gap: var(--space-4); }
  .ind-footer__links a { font-family: var(--font-sans); font-size: var(--text-xs); color: rgba(255,255,255,0.3); text-decoration: none; transition: color 0.2s; }
  .ind-footer__links a:hover { color: rgba(255,255,255,0.7); }
</style>

<script>
  // Navbar scroll
  const navbar = document.getElementById('navbar');
  const hero = document.getElementById('hero');
  if (navbar && hero) {
    const obs = new IntersectionObserver(([e]) => {
      navbar.classList.toggle('scrolled', !e.isIntersecting);
    }, { rootMargin: '-80px 0px 0px 0px' });
    obs.observe(hero);
  }

  // Mobile menu
  const hamburger = document.querySelector('.ind-navbar__hamburger') as HTMLButtonElement;
  const mobileMenu = document.getElementById('ind-mobile-menu');
  if (hamburger && mobileMenu && navbar) {
    hamburger.addEventListener('click', () => {
      const isOpen = hamburger.classList.contains('is-active');
      hamburger.classList.toggle('is-active', !isOpen);
      navbar.classList.toggle('mobile-open', !isOpen);
      hamburger.setAttribute('aria-expanded', String(!isOpen));
      mobileMenu.setAttribute('aria-hidden', String(isOpen));
    });
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        hamburger.classList.remove('is-active');
        navbar.classList.remove('mobile-open');
        hamburger.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
      });
    });
  }

  // FAQ accordion
  document.querySelectorAll('[data-ind-faq]').forEach(item => {
    const trigger = item.querySelector('.ind-faq__trigger') as HTMLButtonElement;
    const panel = item.querySelector('.ind-faq__panel') as HTMLElement;
    if (!trigger || !panel) return;
    trigger.addEventListener('click', () => {
      const isOpen = item.getAttribute('data-open') === 'true';
      // Close others
      document.querySelectorAll('[data-ind-faq]').forEach(other => {
        if (other !== item && other.getAttribute('data-open') === 'true') {
          other.setAttribute('data-open', 'false');
          (other.querySelector('.ind-faq__trigger') as HTMLButtonElement)?.setAttribute('aria-expanded', 'false');
          other.querySelector('.ind-faq__panel')?.classList.remove('is-open');
          setTimeout(() => { if (other.getAttribute('data-open') !== 'true') other.querySelector('.ind-faq__panel')?.setAttribute('hidden', ''); }, 500);
        }
      });
      if (isOpen) {
        item.setAttribute('data-open', 'false');
        trigger.setAttribute('aria-expanded', 'false');
        panel.classList.remove('is-open');
        setTimeout(() => { if (item.getAttribute('data-open') !== 'true') panel.setAttribute('hidden', ''); }, 500);
      } else {
        item.setAttribute('data-open', 'true');
        trigger.setAttribute('aria-expanded', 'true');
        panel.removeAttribute('hidden');
        panel.offsetHeight;
        panel.classList.add('is-open');
      }
    });
  });
</script>
