  .ind-footer__logo { font-family: var(--font-display); font-style: italic; font-weight: 700; font-size: var(--text-3xl); color: white; text-decoration: none; letter-spacing: 0.04em; }
  .ind-footer__badge-1a1 { font-family: var(--font-sans); font-size: var(--text-xs); font-weight: 600; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.08em; }
