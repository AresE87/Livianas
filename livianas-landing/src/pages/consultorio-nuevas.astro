---
import Layout from '../layouts/Layout.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { siteConfig, getConsultorioWhatsAppLink } from '../lib/config';

const c = siteConfig.consultorio;
const waHero = getConsultorioWhatsAppLink('hero');
const waDudas = getConsultorioWhatsAppLink('dudas');
---

<Layout
  title="Consultorio con Ana — Acompañamiento mensual para mujeres"
  description="Dos sesiones en vivo al mes + grupo privado de WhatsApp. Sin dietas, sin culpa, con guía real. Desde $ 1.500/mes."
>
  <!-- ========== HERO ========== -->
  <section class="hero">
    <div class="hero__topbar">
      <span class="hero__wordmark">LIVIANAS</span>
    </div>
    <div class="container hero__grid">
      <div class="hero__photo-wrap">
        <img
          src="/images/ana-foto.webp"
          alt="Ana — Coach de bienestar"
          width="400"
          height="400"
          class="hero__photo"
          loading="eager"
        />
      </div>
      <div class="hero__content">
        <span class="hero__badge">Cupos limitados</span>
        <h1 class="hero__title">
          Acompañamiento mensual con Ana para transformar tu relación con la comida
        </h1>
        <p class="hero__subtitle">
          Dos sesiones en vivo al mes + grupo privado de WhatsApp. Sin dietas, sin culpa, con guía real.
        </p>
        <a href="#pricing" class="btn btn--primary hero__cta">Ver planes</a>
      </div>
    </div>
  </section>

  <!-- ========== QUE INCLUYE ========== -->
  <section class="section includes">
    <div class="container">
      <h2 class="section-heading">¿Qué incluye tu acompañamiento?</h2>
      <div class="includes__grid">
        {c.includes.map((item, i) => (
          <div class="includes__card glass">
            <div class="includes__icon">
              {i === 0 && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2" />
                  <circle cx="12" cy="10" r="3" />
                  <path d="M2 17l20 0" />
                  <path d="M8 21h8" />
                  <path d="M12 17v4" />
                </svg>
              )}
              {i === 1 && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
                  <path d="M8 10h.01" />
                  <path d="M12 10h.01" />
                  <path d="M16 10h.01" />
                </svg>
              )}
              {i === 2 && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 21C12 21 3 13.5 3 8.5C3 5.42 5.42 3 8.5 3c1.74 0 3.41.81 4.5 2.09A6.04 6.04 0 0117.5 3C20.58 3 23 5.42 23 8.5c0 1.3-.39 2.54-1.07 3.6" />
                  <path d="M15 17l2 2 4-4" />
                </svg>
              )}
            </div>
            <h3 class="includes__title">{item.title}</h3>
            <p class="includes__desc">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section pricing" id="pricing">
    <div class="container">
      <h2 class="section-heading">Elegí tu plan</h2>
      <div class="pricing__grid">
        <!-- Mensual -->
        <div class="pricing__card">
          <div class="pricing__card-header">
            <h3 class="pricing__plan-name">{c.nuevas.mensual.label}</h3>
          </div>
          <div class="pricing__price-wrap">
            <span class="pricing__price">$ 1.500</span>
            <span class="pricing__period">/mes</span>
          </div>
          <a
            href={c.nuevas.mensual.link}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--secondary pricing__btn"
          >
            Empezar ahora
          </a>
        </div>

        <!-- Trimestral -->
        <div class="pricing__card pricing__card--featured">
          <span class="pricing__badge">Ahorrá $ 1.000</span>
          <div class="pricing__card-header">
            <h3 class="pricing__plan-name">{c.nuevas.trimestral.label}</h3>
          </div>
          <div class="pricing__price-wrap">
            <span class="pricing__price">$ 3.500</span>
            <span class="pricing__period">/trimestre</span>
          </div>
          <p class="pricing__monthly">~$ 1.167/mes</p>
          <a
            href={c.nuevas.trimestral.link}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--primary pricing__btn"
          >
            Elegir este plan
          </a>
        </div>
      </div>

      <div class="pricing__trust">
        <p>Pago seguro por Mercado Pago &middot; Cancelá cuando quieras</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq">
    <div class="container container--narrow">
      <h2 class="section-heading">Preguntas frecuentes</h2>
      <div class="faq__list">
        {c.faq.map((item) => (
          <details class="faq__item">
            <summary class="faq__question">{item.question}</summary>
            <p class="faq__answer">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section class="section cta-final">
    <div class="container cta-final__inner">
      <h2 class="cta-final__title">Tu cambio empieza con una decisión</h2>
      <div class="cta-final__buttons">
        <a
          href={waDudas}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--whatsapp"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Tengo dudas, quiero hablar con Ana
        </a>
        <a href="#pricing" class="btn btn--primary">Ver planes</a>
      </div>
    </div>
  </section>

  <WhatsAppButton />
</Layout>

<style>
  /* Override global .section padding — this is a short funnel page */
  .section {
    padding: var(--space-12) 0;
  }

  @media (min-width: 768px) {
    .section {
      padding: var(--space-16) 0;
    }
  }

  /* ===== HERO ===== */
  .hero {
    background: linear-gradient(180deg, var(--color-cream) 0%, var(--color-cream-warm) 100%);
    padding-bottom: var(--space-16);
  }

  .hero__topbar {
    padding: var(--space-4) var(--space-6);
  }

  .hero__wordmark {
    font-family: var(--font-outfit);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.2em;
    color: var(--color-sage);
  }

  .hero__grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-10);
  }

  .hero__photo-wrap {
    flex-shrink: 0;
  }

  .hero__photo {
    width: 220px;
    height: 220px;
    object-fit: cover;
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-lg);
    border: 4px solid var(--color-white);
  }

  .hero__content {
    text-align: center;
  }

  .hero__badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-sage-dark);
    background: var(--color-sage-wash);
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-4);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-text);
    margin-bottom: var(--space-4);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-8);
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 768px) {
    .hero {
      padding-bottom: var(--space-20);
    }

    .hero__grid {
      flex-direction: row;
      gap: var(--space-16);
    }

    .hero__photo {
      width: 300px;
      height: 300px;
    }

    .hero__content {
      text-align: left;
      flex: 1;
    }

    .hero__title {
      margin-left: 0;
      margin-right: 0;
    }

    .hero__subtitle {
      margin-left: 0;
      margin-right: 0;
    }
  }

  /* ===== SECTION HEADING ===== */
  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 500;
    text-align: center;
    color: var(--color-text);
    margin-bottom: var(--space-12);
  }

  /* ===== INCLUDES ===== */
  .includes {
    background: var(--color-white);
  }

  .includes__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .includes__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8);
    }
  }

  .includes__card {
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    text-align: center;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .includes__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .includes__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    background: var(--color-sage-wash);
    color: var(--color-sage);
    margin-bottom: var(--space-4);
  }

  .includes__title {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .includes__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ===== PRICING ===== */
  .pricing {
    background: var(--color-cream);
  }

  .pricing__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 700px;
    margin: 0 auto;
  }

  @media (min-width: 600px) {
    .pricing__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .pricing__card {
    position: relative;
    background: var(--color-white);
    border: 1.5px solid var(--color-sand);
    border-radius: var(--radius-xl);
    padding: var(--space-8) var(--space-6);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .pricing__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .pricing__card--featured {
    border-color: var(--color-sage);
    border-width: 2px;
    box-shadow: var(--shadow-glow-sage);
  }

  .pricing__badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-white);
    background: var(--color-blush);
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .pricing__plan-name {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .pricing__price-wrap {
    display: flex;
    align-items: baseline;
    gap: var(--space-1);
  }

  .pricing__price {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 600;
    color: var(--color-text);
  }

  .pricing__period {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .pricing__monthly {
    font-size: var(--text-sm);
    color: var(--color-sage-dark);
    font-weight: 600;
    margin-top: calc(-1 * var(--space-2));
  }

  .pricing__btn {
    width: 100%;
    margin-top: var(--space-2);
  }

  .pricing__trust {
    text-align: center;
    margin-top: var(--space-8);
  }

  .pricing__trust p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* ===== FAQ ===== */
  .faq {
    background: var(--color-white);
  }

  .faq__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .faq__item {
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow var(--transition-base);
  }

  .faq__item[open] {
    box-shadow: var(--shadow-md);
  }

  .faq__question {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    cursor: pointer;
    padding: var(--space-5) var(--space-6);
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    user-select: none;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::after {
    content: '+';
    flex-shrink: 0;
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--color-sage);
    transition: transform var(--transition-fast);
  }

  .faq__item[open] .faq__question::after {
    content: '-';
    transform: rotate(0deg);
  }

  .faq__answer {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    padding: 0 var(--space-6) var(--space-5);
  }

  /* ===== CTA FINAL ===== */
  .cta-final {
    background: linear-gradient(180deg, var(--color-sage-wash) 0%, var(--color-cream-warm) 100%);
  }

  .cta-final__inner {
    text-align: center;
  }

  .cta-final__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4.5vw, 2.5rem);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-8);
  }

  .cta-final__buttons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  @media (min-width: 600px) {
    .cta-final__buttons {
      flex-direction: row;
      justify-content: center;
    }
  }

  /* WhatsApp CTA button */
  .btn--whatsapp {
    background: var(--color-whatsapp);
    color: var(--color-white);
    padding: var(--space-4) var(--space-8);
    border-radius: var(--radius-full);
    font-size: var(--text-base);
    box-shadow: var(--shadow-md);
  }

  .btn--whatsapp:hover {
    background: var(--color-whatsapp-hover);
    box-shadow: 0 0 30px rgba(18, 140, 126, 0.35);
  }
</style>
