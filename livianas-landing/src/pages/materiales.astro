---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PremiumFooter from '../components/PremiumFooter.astro';
import ChatWidgetMateriales from '../components/ChatWidgetMateriales.astro';
import { bundleData, materialesFaqData, materialesConfig } from '../lib/config-materiales';

const payMp = materialesConfig.paymentLinks.mercadoPago;
const payPp = materialesConfig.paymentLinks.paypal;
const discount = Math.round((1 - bundleData.price / bundleData.oldPrice) * 100);
---

<Layout title="Materiales Digitales | LIVIANAS" description="Guía y recetario antiinflamatorio del Método Livianas. Descargá tus materiales digitales y empezá hoy tu camino al bienestar.">
  <Navbar basePath="/" />

  <!-- ==========================================
       HERO
       ========================================== -->
  <section class="mat-hero">
    <div class="container">
      <span class="mat-hero__label" data-gsap="hero-label">TIENDA LIVIANAS</span>
      <h1 class="mat-hero__title" data-gsap="hero-title">
        <span class="mat-hero__title-serif">Materiales</span>
        <span class="mat-hero__title-sans">digitales.</span>
      </h1>
      <p class="mat-hero__sub" data-gsap="hero-sub">
        Recursos prácticos para que arranques tu camino hacia el bienestar.<br />
        Descarga inmediata. Sin esperas. A tu ritmo.
      </p>
    </div>
  </section>

  <!-- ==========================================
       PRODUCT CARD
       ========================================== -->
  <section id="producto" class="mat-product section">
    <div class="container">
      <div class="mat-product__card" data-gsap="product-card">
        <!-- Badge -->
        <div class="mat-product__badge-wrap">
          <span class="mat-product__badge">{bundleData.badge}</span>
          <span class="mat-product__discount">-{discount}%</span>
        </div>

        <!-- Content grid -->
        <div class="mat-product__grid">
          <!-- Image placeholder -->
          <div class="mat-product__visual">
            <div class="mat-product__mockup">
              <div class="mat-product__mockup-page mat-product__mockup-page--back">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                <span>Recetario</span>
              </div>
              <div class="mat-product__mockup-page mat-product__mockup-page--front">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                <span>Guía</span>
              </div>
            </div>
          </div>

          <!-- Info -->
          <div class="mat-product__info">
            <h2 class="mat-product__name">{bundleData.name}</h2>
            <p class="mat-product__tagline">{bundleData.tagline}</p>
            <p class="mat-product__desc">{bundleData.description}</p>

            <!-- Items included -->
            <div class="mat-product__items">
              {bundleData.items.map((item) => (
                <div class="mat-product__item">
                  <div class="mat-product__item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  </div>
                  <div>
                    <strong class="mat-product__item-title">{item.title}</strong>
                    <span class="mat-product__item-meta">{item.format} · {item.pages}</span>
                    <p class="mat-product__item-desc">{item.description}</p>
                  </div>
                </div>
              ))}
            </div>

            <!-- Pricing -->
            <div class="mat-product__pricing">
              <span class="mat-product__old-price">{bundleData.currency} {bundleData.oldPrice}</span>
              <div class="mat-product__current-price">
                <span class="mat-product__currency">{bundleData.currency}</span>
                <span class="mat-product__amount">{bundleData.price}</span>
              </div>
              <p class="mat-product__price-note">Pago único · Descarga inmediata</p>
            </div>

            <!-- CTA Buttons -->
            <div class="mat-product__ctas">
              {payMp && (
                <a href={payMp} target="_blank" rel="noopener noreferrer" class="btn mat-btn mat-btn--mp">
                  Comprar con Mercado Pago
                </a>
              )}
              {payPp && (
                <a href={payPp} target="_blank" rel="noopener noreferrer" class="btn mat-btn mat-btn--paypal">
                  Comprar con PayPal
                </a>
              )}
              {!payMp && !payPp && (
                <p class="mat-product__coming-soon">Links de pago próximamente. Mientras tanto, preguntale a Livia 👇</p>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       CÓMO FUNCIONA
       ========================================== -->
  <section class="mat-steps section">
    <div class="container">
      <h2 class="mat-section-title" data-gsap="steps-title">
        <span class="mat-section-title-serif">Así de</span>
        <span class="mat-section-title-sans">simple.</span>
      </h2>

      <div class="mat-steps__grid" data-gsap="steps-grid">
        <div class="mat-step">
          <div class="mat-step__number">1</div>
          <h3 class="mat-step__title">Elegí</h3>
          <p class="mat-step__desc">Revisá el contenido del pack y decidí si es para vos.</p>
        </div>
        <div class="mat-step__arrow" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div class="mat-step">
          <div class="mat-step__number">2</div>
          <h3 class="mat-step__title">Pagá</h3>
          <p class="mat-step__desc">Elegí tu medio de pago: Mercado Pago o PayPal. Seguro y rápido.</p>
        </div>
        <div class="mat-step__arrow" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div class="mat-step">
          <div class="mat-step__number">3</div>
          <h3 class="mat-step__title">Descargá</h3>
          <p class="mat-step__desc">Recibís el link al instante. Descargá y empezá cuando quieras.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       FAQ
       ========================================== -->
  <section class="mat-faq section">
    <div class="container">
      <h2 class="mat-section-title" data-gsap="faq-title">
        <span class="mat-section-title-serif">Preguntas</span>
        <span class="mat-section-title-sans">frecuentes.</span>
      </h2>

      <div class="mat-faq__list" data-gsap="faq-list">
        {materialesFaqData.map((faq) => (
          <details class="mat-faq__item">
            <summary class="mat-faq__question">
              {faq.question}
              <svg class="mat-faq__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <p class="mat-faq__answer">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ==========================================
       CTA FINAL
       ========================================== -->
  <section class="mat-cta section">
    <div class="container">
      <div class="mat-cta__card" data-gsap="cta-card">
        <h2 class="mat-cta__title">¿Lista para empezar?</h2>
        <p class="mat-cta__sub">Descargá el pack y dá el primer paso hoy.</p>
        <a href="#producto" class="btn mat-btn mat-btn--cta">
          Quiero el pack
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <PremiumFooter />
  <ChatWidgetMateriales />
</Layout>

<style>
/* ===== HERO ===== */
.mat-hero{padding:calc(var(--space-32) + var(--space-8)) 0 var(--space-16);background:linear-gradient(180deg,var(--color-sage-wash) 0%,var(--color-cream) 100%);text-align:center}
.mat-hero__label{display:inline-block;font-family:var(--font-sans);font-size:var(--text-xs);font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--color-sage);margin-bottom:var(--space-4)}
.mat-hero__title{font-family:var(--font-display);font-weight:700;line-height:1.1;margin-bottom:var(--space-4)}
.mat-hero__title-serif{display:block;font-size:clamp(2.5rem,6vw,4rem);color:var(--color-carbon);font-style:italic}
.mat-hero__title-sans{display:block;font-family:var(--font-sans);font-size:clamp(1.2rem,3vw,1.8rem);font-weight:300;color:var(--color-text-muted);letter-spacing:-.01em}
.mat-hero__sub{font-family:var(--font-sans);font-size:clamp(.9rem,1.8vw,1.1rem);color:var(--color-text-muted);line-height:1.6;max-width:520px;margin:0 auto}

/* ===== PRODUCT CARD ===== */
.mat-product{padding:var(--space-8) 0 var(--space-16)}
.mat-product__card{background:white;border-radius:var(--radius-2xl);box-shadow:0 8px 40px rgba(44,40,37,.08),0 0 0 1px var(--color-border);overflow:hidden;position:relative}
.mat-product__badge-wrap{display:flex;gap:var(--space-2);padding:var(--space-4) var(--space-6);background:var(--color-sage-wash);border-bottom:1px solid var(--color-border)}
.mat-product__badge{font-family:var(--font-sans);font-size:var(--text-xs);font-weight:700;color:var(--color-sage);text-transform:uppercase;letter-spacing:.08em}
.mat-product__discount{font-family:var(--font-sans);font-size:var(--text-xs);font-weight:700;color:var(--color-blush);background:var(--color-blush-wash);padding:2px var(--space-2);border-radius:var(--radius-sm)}
.mat-product__grid{display:grid;grid-template-columns:1fr;gap:0}
@media(min-width:768px){.mat-product__grid{grid-template-columns:1fr 1.4fr}}

/* Visual / mockup */
.mat-product__visual{display:flex;align-items:center;justify-content:center;padding:var(--space-10);background:linear-gradient(135deg,var(--color-sage-wash) 0%,var(--color-cream-warm) 100%);min-height:280px}
.mat-product__mockup{position:relative;width:200px;height:240px}
.mat-product__mockup-page{position:absolute;width:150px;height:200px;background:white;border-radius:var(--radius-lg);box-shadow:0 4px 20px rgba(0,0,0,.1);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:var(--space-2)}
.mat-product__mockup-page span{font-family:var(--font-sans);font-size:var(--text-sm);font-weight:600;color:var(--color-text-muted)}
.mat-product__mockup-page svg{color:var(--color-sage);opacity:.6}
.mat-product__mockup-page--back{top:0;right:0;transform:rotate(6deg)}
.mat-product__mockup-page--front{bottom:0;left:0;transform:rotate(-3deg);z-index:1;box-shadow:0 8px 32px rgba(0,0,0,.12)}

/* Info */
.mat-product__info{padding:var(--space-8) var(--space-6)}
@media(min-width:768px){.mat-product__info{padding:var(--space-10) var(--space-8)}}
.mat-product__name{font-family:var(--font-display);font-weight:700;font-size:var(--text-2xl);color:var(--color-carbon);margin-bottom:var(--space-1)}
.mat-product__tagline{font-family:var(--font-sans);font-size:var(--text-sm);font-weight:600;color:var(--color-sage);margin-bottom:var(--space-3)}
.mat-product__desc{font-family:var(--font-sans);font-size:var(--text-base);color:var(--color-text-muted);line-height:1.65;margin-bottom:var(--space-6)}

/* Items */
.mat-product__items{display:flex;flex-direction:column;gap:var(--space-4);margin-bottom:var(--space-8);padding:var(--space-5);background:var(--color-cream);border-radius:var(--radius-lg)}
.mat-product__item{display:flex;gap:var(--space-3);align-items:flex-start}
.mat-product__item-icon{width:36px;height:36px;min-width:36px;border-radius:var(--radius-md);background:var(--color-sage-wash);display:flex;align-items:center;justify-content:center;color:var(--color-sage);margin-top:2px}
.mat-product__item-title{font-family:var(--font-sans);font-weight:700;font-size:var(--text-sm);color:var(--color-carbon);display:block}
.mat-product__item-meta{font-family:var(--font-sans);font-size:var(--text-xs);color:var(--color-text-light);display:block;margin-bottom:var(--space-1)}
.mat-product__item-desc{font-family:var(--font-sans);font-size:var(--text-sm);color:var(--color-text-muted);line-height:1.5}

/* Pricing */
.mat-product__pricing{display:flex;align-items:baseline;gap:var(--space-3);margin-bottom:var(--space-2);flex-wrap:wrap}
.mat-product__old-price{font-family:var(--font-display);font-size:var(--text-xl);color:var(--color-text-light);text-decoration:line-through;font-weight:400}
.mat-product__current-price{display:flex;align-items:baseline;gap:4px}
.mat-product__currency{font-family:var(--font-sans);font-size:var(--text-lg);font-weight:600;color:var(--color-sage)}
.mat-product__amount{font-family:var(--font-display);font-size:var(--text-5xl);font-weight:700;color:var(--color-sage);line-height:1}
.mat-product__price-note{font-family:var(--font-sans);font-size:var(--text-xs);color:var(--color-text-light);width:100%;margin-bottom:var(--space-6)}
.mat-product__coming-soon{font-family:var(--font-sans);font-size:var(--text-sm);color:var(--color-text-muted);font-style:italic;text-align:center;padding:var(--space-4)}

/* CTA Buttons */
.mat-product__ctas{display:flex;flex-direction:column;gap:var(--space-3)}
@media(min-width:480px){.mat-product__ctas{flex-direction:row}}
.mat-btn{display:inline-flex;align-items:center;justify-content:center;gap:var(--space-2);padding:var(--space-4) var(--space-8);font-family:var(--font-sans);font-weight:700;font-size:var(--text-base);border-radius:var(--radius-full);text-decoration:none;transition:all var(--transition-fast);cursor:pointer;border:none;text-align:center}
.mat-btn--mp{background:#009ee3;color:#fff;box-shadow:0 2px 12px rgba(0,158,227,.25)}
.mat-btn--mp:hover{background:#008bd1;transform:translateY(-1px)}
.mat-btn--paypal{background:#0070ba;color:#fff;box-shadow:0 2px 12px rgba(0,112,186,.25)}
.mat-btn--paypal:hover{background:#005ea6;transform:translateY(-1px)}
.mat-btn--cta{background:var(--color-sage);color:#fff;box-shadow:0 2px 12px rgba(123,143,107,.3)}
.mat-btn--cta:hover{background:var(--color-sage-dark);transform:translateY(-1px)}

/* ===== STEPS ===== */
.mat-steps{padding:var(--space-16) 0;background:var(--color-sage-wash)}
.mat-section-title{text-align:center;margin-bottom:var(--space-10)}
.mat-section-title-serif{display:block;font-family:var(--font-display);font-style:italic;font-weight:700;font-size:clamp(1.8rem,4vw,2.8rem);color:var(--color-carbon)}
.mat-section-title-sans{font-family:var(--font-sans);font-weight:300;font-size:clamp(1rem,2.5vw,1.5rem);color:var(--color-text-muted);letter-spacing:-.01em}
.mat-steps__grid{display:flex;align-items:flex-start;justify-content:center;gap:var(--space-4);flex-wrap:wrap}
.mat-step{background:white;border-radius:var(--radius-xl);padding:var(--space-6);text-align:center;flex:1;min-width:200px;max-width:260px}
.mat-step__number{width:40px;height:40px;border-radius:50%;background:var(--color-sage);color:white;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:1.1rem;margin:0 auto var(--space-3)}
.mat-step__title{font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);color:var(--color-carbon);margin-bottom:var(--space-2)}
.mat-step__desc{font-family:var(--font-sans);font-size:var(--text-sm);color:var(--color-text-muted);line-height:1.5}
.mat-step__arrow{display:none;color:var(--color-sage);opacity:.4;padding-top:var(--space-8)}
@media(min-width:768px){.mat-step__arrow{display:block}}

/* ===== FAQ ===== */
.mat-faq{padding:var(--space-16) 0}
.mat-faq__list{max-width:640px;margin:0 auto;display:flex;flex-direction:column;gap:var(--space-3)}
.mat-faq__item{background:white;border-radius:var(--radius-lg);border:1px solid var(--color-border);overflow:hidden;transition:border-color var(--transition-fast)}
.mat-faq__item[open]{border-color:var(--color-sage)}
.mat-faq__question{display:flex;align-items:center;justify-content:space-between;gap:var(--space-3);padding:var(--space-4) var(--space-5);font-family:var(--font-sans);font-weight:600;font-size:var(--text-sm);color:var(--color-carbon);cursor:pointer;list-style:none}
.mat-faq__question::-webkit-details-marker{display:none}
.mat-faq__chevron{transition:transform var(--transition-base);flex-shrink:0;color:var(--color-sage)}
.mat-faq__item[open] .mat-faq__chevron{transform:rotate(180deg)}
.mat-faq__answer{padding:0 var(--space-5) var(--space-5);font-family:var(--font-sans);font-size:var(--text-sm);color:var(--color-text-muted);line-height:1.6}

/* ===== CTA FINAL ===== */
.mat-cta{padding:var(--space-8) 0 var(--space-16)}
.mat-cta__card{background:var(--color-carbon);border-radius:var(--radius-2xl);padding:var(--space-12) var(--space-8);text-align:center}
.mat-cta__title{font-family:var(--font-display);font-style:italic;font-weight:700;font-size:clamp(1.8rem,4vw,2.5rem);color:white;margin-bottom:var(--space-3)}
.mat-cta__sub{font-family:var(--font-sans);font-size:var(--text-base);color:rgba(255,255,255,.6);margin-bottom:var(--space-6)}

/* ===== GENERAL ===== */
.section{position:relative}
.container{max-width:var(--container-max);margin:0 auto;padding:0 var(--space-4)}
@media(min-width:768px){.container{padding:0 var(--space-6)}}
</style>
