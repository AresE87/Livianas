---
// src/pages/masterclass/gracias.astro — Página post-registro masterclass EFECTO LIVIANA
import '../../styles/global.css';
import { siteConfig } from '../../lib/config';

const whatsappLink = `https://wa.me/59891086674?text=${encodeURIComponent('Hola Ana! Me inscribí a EFECTO LIVIANA 🌿')}`;
const metaPixelId = siteConfig.metaPixelId;
const ga4Id = siteConfig.ga4Id;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>¡Inscripción confirmada! — EFECTO LIVIANA</title>
    <meta name="description" content="Tu lugar en la masterclass EFECTO LIVIANA está confirmado." />
    <meta name="robots" content="noindex, nofollow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,700;1,400;1,700&family=Outfit:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    {metaPixelId && (
      <script set:html={`
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '${metaPixelId}');
        fbq('track', 'PageView');
        fbq('track', 'Lead', {
          content_name: 'Masterclass EFECTO LIVIANA',
          content_type: 'event'
        });
      `} />
    )}

    {ga4Id && (
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
    )}
    {ga4Id && (
      <script set:html={`
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '${ga4Id}');
        gtag('event', 'sign_up', { method: 'masterclass_efecto_liviana' });
      `} />
    )}
  </head>

  <body class="bg-cream text-carbon min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-carbon text-center py-12 px-6">
      <div class="max-w-lg mx-auto">
        <div class="check-icon mx-auto mb-6">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
            <circle cx="32" cy="32" r="30" stroke="#C9A96E" stroke-width="3" fill="none" />
            <path d="M20 32L28 40L44 24" stroke="#C9A96E" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <p class="text-gold text-xs font-bold tracking-[0.25em] mb-3">EXPERIENCIA INTEGRAL CON ENERGÍA</p>
        <h1 class="font-display text-3xl md:text-4xl text-cream font-bold mb-3">
          ¡Tu lugar está reservado!
        </h1>
        <p class="text-cream/70 text-base">
          Masterclass EFECTO LIVIANA
        </p>
      </div>
    </header>

    <!-- Content -->
    <main class="flex-1 py-12 px-6">
      <div class="max-w-lg mx-auto space-y-8">

        <!-- Event details card -->
        <div class="bg-white rounded-xl p-6 shadow-md border border-border">
          <h2 class="font-outfit font-bold text-lg mb-4 text-carbon">Detalles del evento</h2>
          <div class="space-y-3 text-sm text-text-muted">
            <p>📅 <strong class="text-carbon">Sábado 28 de marzo de 2026</strong></p>
            <p>🕐 <strong class="text-carbon">11:00 hs (Uruguay)</strong></p>
            <p>💻 <strong class="text-carbon">Zoom</strong> — el link te llega por email</p>
            <p>🎁 <strong class="text-carbon">100% gratuita</strong></p>
          </div>
        </div>

        <!-- Next steps -->
        <div class="bg-sage-wash rounded-xl p-6">
          <h2 class="font-outfit font-bold text-lg mb-4 text-carbon">Próximos pasos</h2>
          <ol class="space-y-3 text-sm text-text-muted">
            <li><strong class="text-gold">1.</strong> Revisá tu email — te enviamos la confirmación</li>
            <li><strong class="text-gold">2.</strong> Agendá la fecha en tu calendario</li>
            <li><strong class="text-gold">3.</strong> Seguinos en Instagram: <a href="https://instagram.com/anabienestarintegral" target="_blank" rel="noopener" class="text-sage font-semibold hover:underline">@anabienestarintegral</a></li>
          </ol>
        </div>

        <!-- WhatsApp CTA -->
        <div class="bg-blush-wash rounded-xl p-6 text-center">
          <p class="text-sm text-carbon mb-3">¿Tenés dudas? Escribile a Ana</p>
          <a href={whatsappLink} target="_blank" rel="noopener"
            class="inline-flex items-center gap-2 bg-whatsapp hover:bg-whatsapp-hover text-white font-bold text-sm px-6 py-3 rounded-full transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.638l4.716-1.246A11.937 11.937 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.319 0-4.476-.678-6.29-1.846l-.126-.079-3.006.794.808-2.95-.09-.132A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
            Hablar con Ana
          </a>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="text-center py-8 px-6 border-t border-border">
      <p class="text-xs text-text-light">© 2026 LIVIANAS — Todos los derechos reservados</p>
    </footer>

    <style>
      .check-icon {
        animation: scaleIn 0.5s ease-out;
      }
      @keyframes scaleIn {
        from { transform: scale(0.5); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
      }
    </style>
  </body>
</html>
