---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import PremiumFooter from '../../components/PremiumFooter.astro';
import { siteConfig } from '../../lib/config';

const mc = siteConfig.masterclass;

// Google Calendar link
const calTitle = encodeURIComponent(`Masterclass: ${mc.nombre} — LIVIANAS`);
const calDetails = encodeURIComponent(`Masterclass gratuita con Ana.\n${mc.subtitulo}\n\nLink de Zoom: te llegará por email antes del evento.`);
const calStart = '20260426T220000Z'; // 19:00 Uruguay = 22:00 UTC
const calEnd = '20260426T233000Z';   // 90 min después
const googleCalUrl = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${calTitle}&dates=${calStart}/${calEnd}&details=${calDetails}`;
---

<Layout
  title="¡Estás registrada! — Masterclass Las 3 Mentiras"
  description="Tu lugar está reservado para la masterclass gratuita con Ana."
>
  <Navbar />

  <section class="gracias-section">
    <div class="container container--narrow gracias-content">
      <div class="gracias-icon">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 12 2 2 4-4"/>
          <circle cx="12" cy="12" r="10"/>
        </svg>
      </div>

      <h1 class="gracias-title">¡Tu lugar está reservado!</h1>

      <p class="gracias-subtitle">
        Revisá tu email — te enviamos todos los detalles para la masterclass.
      </p>

      <div class="gracias-details">
        <div class="gracias-detail">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>{mc.fecha}</span>
        </div>
        <div class="gracias-detail">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>{mc.hora} · {mc.duracion}</span>
        </div>
        <div class="gracias-detail">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 10l5 5-5 5"/><path d="M4 4v7a4 4 0 004 4h12"/></svg>
          <span>En vivo por {mc.plataforma}</span>
        </div>
      </div>

      <a href={googleCalUrl} target="_blank" rel="noopener" class="gracias-cal-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
        Agregar a Google Calendar
      </a>

      <div class="gracias-share">
        <p class="gracias-share-text">¿Conocés a alguien que necesite escuchar esto?</p>
        <a
          href={`https://wa.me/?text=${encodeURIComponent(`¡Me registré en la masterclass gratuita "Las 3 Mentiras" con Ana de Livianas! 🌿 Registrate acá: https://livianas.com/masterclass`)}`}
          target="_blank"
          rel="noopener"
          class="gracias-share-btn"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.67-2.08-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.03-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.21 5.1 4.5.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.58-.09 1.76-.72 2.01-1.42.25-.7.25-1.3.17-1.42-.07-.13-.27-.2-.57-.35z"/><path d="M12 0C5.37 0 0 5.37 0 12c0 2.12.55 4.11 1.51 5.85L0 24l6.33-1.66C8.07 23.42 9.99 24 12 24c6.63 0 12-5.37 12-12S18.63 0 12 0zm0 22c-1.82 0-3.56-.5-5.08-1.41l-.36-.22-3.76.99 1-3.67-.24-.37A9.94 9.94 0 012 12c0-5.51 4.49-10 10-10s10 4.49 10 10-4.49 10-10 10z"/></svg>
          Compartir por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <PremiumFooter />
</Layout>

<style>
  .gracias-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    background: linear-gradient(180deg, var(--color-cream) 0%, var(--color-cream-warm) 100%);
    padding-top: 8rem;
    padding-bottom: var(--space-16);
  }

  .gracias-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .gracias-icon {
    animation: scaleIn 0.5s ease-out;
  }

  @keyframes scaleIn {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  .gracias-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-carbon);
  }

  .gracias-subtitle {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 440px;
    line-height: 1.6;
  }

  .gracias-details {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4) var(--space-8);
    padding: var(--space-6) var(--space-8);
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 24px rgba(44, 40, 37, 0.06);
    border: 1px solid var(--color-border);
  }

  .gracias-detail {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-carbon);
  }

  .gracias-detail svg {
    color: var(--color-sage);
  }

  .gracias-cal-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-outfit);
    font-weight: 600;
    font-size: 1rem;
    color: white;
    background: var(--color-sage);
    border-radius: var(--radius-full);
    padding: 0.875rem 2rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .gracias-cal-btn:hover {
    background: var(--color-sage-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(123, 143, 107, 0.3);
  }

  .gracias-share {
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .gracias-share-text {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .gracias-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-outfit);
    font-weight: 600;
    font-size: 0.9rem;
    color: white;
    background: var(--color-whatsapp);
    border-radius: var(--radius-full);
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .gracias-share-btn:hover {
    background: var(--color-whatsapp-hover);
    transform: translateY(-1px);
  }
</style>
