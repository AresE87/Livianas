---
// src/pages/programa-livianas/gracias.astro
// Página post-pago del Programa Livianas.
// El usuario llega aquí después de pagar en MP (redirect) o volviendo de la pestaña de MP.
// Usa visibilitychange + localStorage email para enviar confirmación automáticamente.

import '../../styles/global.css';
import { siteConfig } from '../../lib/config';

const metaPixelId = siteConfig.metaPixelId;
const ga4Id = siteConfig.ga4Id;
const precioUYU = siteConfig.programaLivianas.precioUYU;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>¡Tu lugar está confirmado! — Programa Livianas</title>
    <meta name="description" content="Tu inscripción al Programa Livianas fue confirmada." />
    <meta name="robots" content="noindex, nofollow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,700;1,400;1,700&family=Outfit:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    {metaPixelId && (
      <script set:html={`
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '${metaPixelId}');
        fbq('track', 'PageView');
        fbq('track', 'Purchase', {
          content_name: 'Programa Livianas',
          content_type: 'product',
          content_ids: ['programa-livianas'],
          value: ${precioUYU},
          currency: 'UYU'
        });
      `} />
    )}

    {ga4Id && (
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
      <script set:html={`
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '${ga4Id}');
        gtag('event', 'purchase', {
          transaction_id: 'pl_' + Date.now(),
          currency: 'UYU',
          value: ${precioUYU},
          items: [{ item_id: 'programa-livianas', item_name: 'Programa Livianas', price: ${precioUYU}, quantity: 1 }]
        });
      `} />
    )}
  </head>
  <body>
    <main class="ty">
      <div class="ty__container">

        <!-- Header -->
        <header class="ty__header">
          <span class="ty__logo">LIVIANAS</span>
          <div class="ty__check">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <h1 class="ty__title">
            <span class="ty__title-serif">¡Tu lugar</span>
            <span class="ty__title-sans">está confirmado!</span>
          </h1>
          <p class="ty__subtitle">
            Tu pago fue procesado correctamente. Ya sos parte del Programa Livianas.
          </p>
        </header>

        <!-- Info card -->
        <section class="ty__info">
          <div class="ty__info-card">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <div>
              <strong>Revisá tu email</strong>
              <p>Te enviamos una confirmación con todos los detalles del programa. Si no la ves, revisá spam o promociones.</p>
            </div>
          </div>
        </section>

        <!-- Next Steps -->
        <section class="ty__next">
          <h2 class="ty__section-title">¿Qué sigue?</h2>
          <ol class="ty__next-list">
            <li>
              <span class="ty__next-num">1</span>
              <div>
                <strong>Ana te escribe</strong>
                <p>Te va a contactar por WhatsApp para darte la bienvenida personalmente.</p>
              </div>
            </li>
            <li>
              <span class="ty__next-num">2</span>
              <div>
                <strong>Te sumamos al grupo</strong>
                <p>Vas a ser parte del grupo privado de WhatsApp del programa.</p>
              </div>
            </li>
            <li>
              <span class="ty__next-num">3</span>
              <div>
                <strong>Primera clase</strong>
                <p>Recibís toda la info de la primera sesión en vivo antes de arrancar.</p>
              </div>
            </li>
          </ol>
        </section>

        <!-- WhatsApp directo -->
        <section class="ty__help">
          <p>¿Tenés alguna consulta? <a href="https://wa.me/59891086674?text=Hola%20Ana!%20Acabo%20de%20inscribirme%20en%20el%20Programa%20Livianas%20%F0%9F%8C%BF" target="_blank" rel="noopener noreferrer" class="ty__wa-link">Escribile a Ana por WhatsApp</a></p>
        </section>

        <!-- Footer -->
        <footer class="ty__footer">
          <p>&copy; 2026 LIVIANAS. Todos los derechos reservados.</p>
        </footer>

      </div>
    </main>

    <!-- Auto-send confirmation email -->
    <script>
      (function () {
        const email = localStorage.getItem('pl_email');
        if (!email) return;

        let sent = false;

        async function sendConfirmation() {
          if (sent) return;
          sent = true;

          try {
            const res = await fetch('/api/send-confirmacion-programa', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email }),
            });
            if (res.ok) {
              console.log('[gracias] Confirmación enviada a', email);
              localStorage.removeItem('pl_email');
            }
          } catch (err) {
            console.error('[gracias] Error enviando confirmación:', err);
            sent = false;
          }
        }

        // Send immediately if page is visible
        if (!document.hidden) {
          sendConfirmation();
        }

        // Also try on visibility change (returning from MP tab)
        document.addEventListener('visibilitychange', () => {
          if (!document.hidden) sendConfirmation();
        });
      })();
    </script>

    <style>
      .ty {
        min-height: 100dvh;
        background: var(--color-cream);
        padding: var(--space-8) var(--space-4) var(--space-4);
      }

      .ty__container {
        max-width: 560px;
        margin: 0 auto;
      }

      .ty__header {
        text-align: center;
        margin-bottom: var(--space-10);
        padding-top: var(--space-4);
      }

      .ty__logo {
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: var(--text-sm);
        letter-spacing: 0.25em;
        color: var(--color-carbon);
        display: block;
        margin-bottom: var(--space-8);
      }

      .ty__check {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--space-5);
        color: var(--color-sage);
      }

      .ty__check svg {
        animation: scaleIn 0.5s ease-out;
      }

      @keyframes scaleIn {
        from { transform: scale(0); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
      }

      .ty__title {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
        margin-bottom: var(--space-3);
      }

      .ty__title-serif {
        font-family: var(--font-display);
        font-style: italic;
        font-weight: 700;
        font-size: clamp(2rem, 5vw, 3rem);
        color: var(--color-carbon);
        line-height: 1.1;
      }

      .ty__title-sans {
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: clamp(1.2rem, 3vw, 1.5rem);
        color: var(--color-sage-dark);
        line-height: 1.2;
      }

      .ty__subtitle {
        font-family: var(--font-sans);
        font-size: var(--text-base);
        color: var(--color-text-muted);
        line-height: 1.6;
        max-width: 400px;
        margin: 0 auto;
      }

      .ty__info {
        margin-bottom: var(--space-10);
      }

      .ty__info-card {
        display: flex;
        align-items: flex-start;
        gap: var(--space-4);
        background: var(--color-sage-wash);
        border: 1px solid rgba(123, 143, 107, 0.2);
        border-radius: var(--radius-xl);
        padding: var(--space-5);
      }

      .ty__info-card svg {
        flex-shrink: 0;
        color: var(--color-sage);
        margin-top: 2px;
      }

      .ty__info-card strong {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 700;
        color: var(--color-sage-dark);
        display: block;
        margin-bottom: var(--space-1);
      }

      .ty__info-card p {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: 1.6;
      }

      .ty__section-title {
        font-family: var(--font-sans);
        font-size: var(--text-lg);
        font-weight: 700;
        color: var(--color-carbon);
        text-align: center;
        margin-bottom: var(--space-5);
      }

      .ty__next {
        margin-bottom: var(--space-10);
      }

      .ty__next-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
      }

      .ty__next-list li {
        display: flex;
        align-items: flex-start;
        gap: var(--space-4);
      }

      .ty__next-num {
        flex-shrink: 0;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-sage-wash);
        color: var(--color-sage-dark);
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 700;
        border-radius: 50%;
      }

      .ty__next-list strong {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 700;
        color: var(--color-carbon);
        display: block;
        margin-bottom: 2px;
      }

      .ty__next-list p {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: 1.5;
      }

      .ty__help {
        text-align: center;
        margin-bottom: var(--space-8);
      }

      .ty__help p {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
      }

      .ty__wa-link {
        color: var(--color-sage-dark);
        font-weight: 600;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .ty__wa-link:hover {
        color: var(--color-sage);
      }

      .ty__footer {
        text-align: center;
        padding: var(--space-6) 0;
        border-top: 1px solid var(--color-border);
      }

      .ty__footer p {
        font-family: var(--font-sans);
        font-size: var(--text-xs);
        color: var(--color-text-light);
      }

      @media (max-width: 480px) {
        .ty {
          padding: var(--space-6) var(--space-4) var(--space-4);
        }
      }
    </style>
  </body>
</html>
