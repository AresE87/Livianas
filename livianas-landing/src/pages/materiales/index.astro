---
import '../../styles/global.css';
import { siteConfig } from '../../lib/config';
import CheckoutModal from '../../components/CheckoutModal.astro';

const whatsappLink = `https://wa.me/59891086674?text=${encodeURIComponent('Hola, quiero info sobre el Pack de Materiales LIVIANAS 🌿')}`;
const metaPixelId = siteConfig.metaPixelId;
const ga4Id = siteConfig.ga4Id;

const items = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'Guía Livianas',
    format: 'PDF · 32 páginas',
    desc: 'Los fundamentos del enfoque antiinflamatorio: qué comer, cómo combinar alimentos y cómo empezar sin estrés. Incluye planificación semanal y lista de compras.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'Recetario Livianas',
    format: 'PDF · 28 páginas',
    desc: 'Recetas antiinflamatorias para el día a día. Desayunos, almuerzos, cenas y snacks con ingredientes accesibles y preparaciones simples.',
  },
];

const faqItems = [
  {
    q: '¿En qué formato vienen los materiales?',
    a: 'Ambos materiales vienen en formato PDF, optimizados para leer en celular, tablet o computadora. También los podés imprimir.',
  },
  {
    q: '¿Puedo pagar desde fuera de Uruguay?',
    a: 'Sí. Mercado Pago acepta tarjetas de crédito y débito internacionales. Si tenés algún inconveniente, escribinos por WhatsApp y te ayudamos.',
  },
  {
    q: '¿Cómo recibo los materiales?',
    a: 'Ingresás tu email antes de pagar. Una vez confirmado el pago, te enviamos los materiales automáticamente a tu casilla. También los podés descargar desde la pantalla de confirmación.',
  },
  {
    q: '¿El contenido se actualiza?',
    a: 'Sí. Cuando actualicemos los materiales, recibís la nueva versión sin costo adicional.',
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pack de Materiales — LIVIANAS</title>
    <meta name="description" content="Guía Livianas + Recetario Livianas. Tu primer paso hacia una alimentación consciente. Descarga inmediata." />
    <meta name="robots" content="noindex, nofollow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,700;1,400;1,700&family=Outfit:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    {metaPixelId && (
      <script set:html={`
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '${metaPixelId}');
        fbq('track', 'PageView');
        fbq('track', 'ViewContent', {
          content_name: 'Pack Materiales LIVIANAS',
          content_type: 'product',
          content_ids: ['pack-materiales'],
          value: 15,
          currency: 'USD'
        });
      `} />
      <noscript>
        <img height="1" width="1" style="display:none" src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`} />
      </noscript>
    )}

    {ga4Id && (
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
      <script set:html={`
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '${ga4Id}');
        gtag('event', 'view_item', {
          currency: 'USD',
          value: 15,
          items: [{ item_id: 'pack-materiales', item_name: 'Pack Materiales LIVIANAS', price: 15 }]
        });
      `} />
    )}
  </head>
  <body>
    <main class="mat">
      <div class="mat__container">

        <!-- Minimal Header (no nav links) -->
        <header class="mat__header">
          <span class="mat__logo">LIVIANAS</span>
          <p class="mat__label">TIENDA LIVIANAS</p>
          <h1 class="mat__title">
            <span class="mat__title-serif">Materiales</span>
            <span class="mat__title-sans">digitales.</span>
          </h1>
          <p class="mat__subtitle">
            Recursos prácticos para que arranques tu camino hacia el bienestar.<br />
            Descarga inmediata. Sin esperas. A tu ritmo.
          </p>
          <!-- Social proof -->
          <div class="mat__social-proof">
            <div class="mat__social-proof-avatars">
              <span class="mat__avatar">M</span>
              <span class="mat__avatar">L</span>
              <span class="mat__avatar">C</span>
              <span class="mat__avatar">V</span>
            </div>
            <p class="mat__social-proof-text">+200 mujeres ya descargaron el pack</p>
          </div>
        </header>

        <!-- Product Card -->
        <section class="mat__product">
          <div class="mat__product-badge">
            <span class="mat__product-badge-text">OFERTA DE LANZAMIENTO</span>
            <span class="mat__product-badge-discount">-38%</span>
          </div>

          <div class="mat__product-content">
            <div class="mat__product-info">
              <h2 class="mat__product-title">Pack Livianas</h2>
              <p class="mat__product-tagline">Tu primer paso hacia una alimentación consciente</p>
              <p class="mat__product-desc">
                Todo lo que necesitás para arrancar tu camino hacia el bienestar. Una guía práctica con los principios del método y un recetario con opciones reales, ricas y fáciles de hacer.
              </p>

              <!-- Items included -->
              <div class="mat__product-items">
                {items.map((item) => (
                  <div class="mat__product-item">
                    <div class="mat__product-item-icon" set:html={item.icon} />
                    <div>
                      <strong class="mat__product-item-title">{item.title}</strong>
                      <span class="mat__product-item-format">{item.format}</span>
                      <p class="mat__product-item-desc">{item.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Pricing + CTA -->
            <div class="mat__product-pricing">
              <div class="mat__price-box">
                <div class="mat__price-row">
                  <span class="mat__price-old">USD 24</span>
                  <span class="mat__price-current">USD 15</span>
                </div>
                <p class="mat__price-note">Pago único &middot; Descarga inmediata</p>
              </div>

              <!-- Checkout Bricks embebido en modal -->
              <CheckoutModal />

              <p class="mat__payment-methods">
                <img src="/images/mercadopago-logo.png" alt="Mercado Pago" width="20" height="20" />
                Tarjeta, débito o transferencia
              </p>
            </div>
          </div>
        </section>

        <!-- Content Preview -->
        <section class="mat__preview">
          <h3 class="mat__preview-title">Mirá lo que vas a encontrar adentro</h3>
          <div class="mat__preview-grid">
            <div class="mat__preview-card">
              <span class="mat__preview-icon">📖</span>
              <strong>Guía Livianas</strong>
              <ul>
                <li>Qué es la alimentación antiinflamatoria</li>
                <li>Alimentos que suman vs. que inflaman</li>
                <li>Guía de porciones con tu mano</li>
                <li>Planificación semanal paso a paso</li>
                <li>Lista de compras descargable</li>
                <li>Cómo empezar sin estrés</li>
              </ul>
            </div>
            <div class="mat__preview-card">
              <span class="mat__preview-icon">🍳</span>
              <strong>Recetario Livianas</strong>
              <ul>
                <li>+30 recetas antiinflamatorias</li>
                <li>Desayunos energizantes</li>
                <li>Almuerzos y cenas completas</li>
                <li>Snacks saludables</li>
                <li>Ingredientes accesibles</li>
                <li>Preparaciones de 20 min o menos</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- How it works -->
        <section class="mat__steps">
          <h3 class="mat__steps-title">¿Cómo funciona?</h3>
          <ol class="mat__steps-list">
            <li>
              <span class="mat__step-num">1</span>
              <div>
                <strong>Dejá tu email</strong>
                <p>Ingresá tu email para que te enviemos los materiales automáticamente.</p>
              </div>
            </li>
            <li>
              <span class="mat__step-num">2</span>
              <div>
                <strong>Pagá con Mercado Pago</strong>
                <p>Tarjeta de crédito, débito o transferencia. Proceso 100% seguro.</p>
              </div>
            </li>
            <li>
              <span class="mat__step-num">3</span>
              <div>
                <strong>Recibí todo por email</strong>
                <p>Te llegan los materiales a tu casilla automáticamente + descarga en pantalla.</p>
              </div>
            </li>
          </ol>
        </section>

        <!-- FAQ -->
        <section class="mat__faq">
          <h3 class="mat__faq-title">Preguntas frecuentes</h3>
          {faqItems.map((item) => (
            <details class="mat__faq-item">
              <summary class="mat__faq-q">{item.q}</summary>
              <p class="mat__faq-a">{item.a}</p>
            </details>
          ))}
        </section>

        <!-- Trust -->
        <div class="mat__trust">
          <span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Pago 100% seguro
          </span>
          <span>&middot;</span>
          <span>Datos encriptados</span>
        </div>

        <!-- Help -->
        <div class="mat__help">
          <p>¿Tenés dudas?</p>
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="mat__help-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Escribinos por WhatsApp
          </a>
        </div>

        <!-- Minimal footer -->
        <footer class="mat__footer">
          <p>&copy; 2026 LIVIANAS. Todos los derechos reservados.</p>
          <div class="mat__footer-links">
            <a href="/terminos">Términos</a>
            <span>&middot;</span>
            <a href="/privacidad">Privacidad</a>
          </div>
        </footer>

      </div>
    </main>

    <!-- Tracking events are now handled by the CheckoutModal component -->

    <style>
      /* ======= BASE ======= */
      .mat {
        min-height: 100dvh;
        background: var(--color-cream);
        padding: var(--space-8) var(--space-4) var(--space-4);
      }

      .mat__container {
        max-width: 720px;
        margin: 0 auto;
      }

      /* ======= HEADER ======= */
      .mat__header {
        text-align: center;
        margin-bottom: var(--space-10);
        padding-top: var(--space-4);
      }

      .mat__logo {
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: var(--text-sm);
        letter-spacing: 0.25em;
        color: var(--color-carbon);
        display: block;
        margin-bottom: var(--space-8);
      }

      .mat__label {
        font-family: var(--font-sans);
        font-size: var(--text-xs);
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-sage);
        margin-bottom: var(--space-4);
      }

      .mat__title {
        display: flex;
        flex-direction: column;
        gap: 0;
        margin-bottom: var(--space-5);
      }

      .mat__title-serif {
        font-family: var(--font-display);
        font-style: italic;
        font-weight: 700;
        font-size: clamp(2.5rem, 6vw, 4rem);
        color: var(--color-carbon);
        line-height: 1.1;
      }

      .mat__title-sans {
        font-family: var(--font-sans);
        font-weight: 400;
        font-size: clamp(1.5rem, 3.5vw, 2rem);
        color: var(--color-text-muted);
        line-height: 1.3;
      }

      .mat__subtitle {
        font-family: var(--font-sans);
        font-size: var(--text-base);
        color: var(--color-text-muted);
        line-height: 1.7;
        max-width: 460px;
        margin: 0 auto;
      }

      /* ======= PRODUCT CARD ======= */
      .mat__product {
        background: var(--color-white);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-2xl);
        overflow: hidden;
        margin-bottom: var(--space-10);
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.04);
      }

      .mat__product-badge {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-3) var(--space-6);
        border-bottom: 1px solid var(--color-border);
        background: var(--color-sage-wash);
      }

      .mat__product-badge-text {
        font-family: var(--font-sans);
        font-size: var(--text-xs);
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--color-sage-dark);
      }

      .mat__product-badge-discount {
        font-family: var(--font-sans);
        font-size: var(--text-xs);
        font-weight: 700;
        color: var(--color-blush-dark);
        background: var(--color-blush-wash);
        padding: 2px var(--space-2);
        border-radius: var(--radius-sm);
      }

      .mat__product-content {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
      }

      @media (min-width: 640px) {
        .mat__product-content {
          grid-template-columns: 1fr 1fr;
        }
      }

      .mat__product-info {
        padding: var(--space-6);
      }

      .mat__product-title {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: var(--text-2xl);
        color: var(--color-carbon);
        margin-bottom: var(--space-2);
      }

      .mat__product-tagline {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--color-sage);
        margin-bottom: var(--space-4);
      }

      .mat__product-desc {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: 1.7;
        margin-bottom: var(--space-6);
      }

      .mat__product-items {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
      }

      .mat__product-item {
        display: flex;
        align-items: flex-start;
        gap: var(--space-3);
        background: var(--color-cream);
        border-radius: var(--radius-xl);
        padding: var(--space-4);
      }

      .mat__product-item-icon {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-white);
        border-radius: var(--radius-md);
        color: var(--color-sage);
      }

      .mat__product-item-title {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 700;
        color: var(--color-carbon);
        display: block;
      }

      .mat__product-item-format {
        font-family: var(--font-sans);
        font-size: var(--text-xs);
        color: var(--color-text-light);
        display: block;
        margin-bottom: var(--space-2);
      }

      .mat__product-item-desc {
        font-family: var(--font-sans);
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        line-height: 1.6;
      }

      /* Pricing column */
      .mat__product-pricing {
        padding: var(--space-6);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        border-top: 1px solid var(--color-border);
      }

      @media (min-width: 640px) {
        .mat__product-pricing {
          border-top: none;
          border-left: 1px solid var(--color-border);
          background: var(--color-sage-wash);
        }
      }

      .mat__price-box {
        margin-bottom: var(--space-5);
      }

      .mat__price-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-3);
        margin-bottom: var(--space-1);
      }

      .mat__price-old {
        font-family: var(--font-sans);
        font-size: var(--text-lg);
        color: var(--color-text-muted);
        text-decoration: line-through;
        opacity: 0.5;
      }

      .mat__price-current {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: var(--text-4xl);
        color: var(--color-sage-dark);
        line-height: 1;
      }

      .mat__price-note {
        font-family: var(--font-sans);
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        opacity: 0.7;
      }

      /* CheckoutModal component handles its own styles */

      .mat__payment-methods {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2);
        font-family: var(--font-sans);
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        margin-top: var(--space-3);
        opacity: 0.7;
      }

      .mat__payment-methods img {
        width: 20px;
        height: 20px;
        object-fit: contain;
      }

      /* ======= STEPS ======= */
      .mat__steps {
        margin-bottom: var(--space-10);
      }

      .mat__steps-title {
        font-family: var(--font-sans);
        font-size: var(--text-lg);
        font-weight: 700;
        color: var(--color-carbon);
        text-align: center;
        margin-bottom: var(--space-6);
      }

      .mat__steps-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
      }

      .mat__steps-list li {
        display: flex;
        align-items: flex-start;
        gap: var(--space-4);
      }

      .mat__step-num {
        flex-shrink: 0;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-sage-wash);
        color: var(--color-sage-dark);
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 700;
        border-radius: 50%;
      }

      .mat__steps-list strong {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 700;
        color: var(--color-carbon);
        display: block;
        margin-bottom: 2px;
      }

      .mat__steps-list p {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: 1.5;
      }

      /* ======= FAQ ======= */
      .mat__faq {
        margin-bottom: var(--space-8);
      }

      .mat__faq-title {
        font-family: var(--font-sans);
        font-size: var(--text-lg);
        font-weight: 700;
        color: var(--color-carbon);
        text-align: center;
        margin-bottom: var(--space-6);
      }

      .mat__faq-item {
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        margin-bottom: var(--space-3);
        background: var(--color-white);
        overflow: hidden;
      }

      .mat__faq-q {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--color-carbon);
        padding: var(--space-4) var(--space-5);
        cursor: pointer;
        list-style: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-3);
      }

      .mat__faq-q::-webkit-details-marker {
        display: none;
      }

      .mat__faq-q::after {
        content: '+';
        flex-shrink: 0;
        font-size: var(--text-lg);
        color: var(--color-sage);
        font-weight: 300;
        transition: transform 0.2s ease;
      }

      .mat__faq-item[open] .mat__faq-q::after {
        content: '−';
      }

      .mat__faq-a {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: 1.7;
        padding: 0 var(--space-5) var(--space-4);
      }

      /* ======= TRUST ======= */
      .mat__trust {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2);
        font-family: var(--font-sans);
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        opacity: 0.6;
        margin-bottom: var(--space-6);
      }

      .mat__trust span {
        display: inline-flex;
        align-items: center;
        gap: var(--space-1);
      }

      /* ======= HELP ======= */
      .mat__help {
        text-align: center;
        margin-bottom: var(--space-8);
      }

      .mat__help p {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        margin-bottom: var(--space-2);
      }

      .mat__help-btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--color-whatsapp);
        text-decoration: none;
        transition: opacity 0.3s ease;
      }

      .mat__help-btn:hover {
        opacity: 0.8;
      }

      /* ======= SOCIAL PROOF ======= */
      .mat__social-proof {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-3);
        margin-top: var(--space-6);
      }

      .mat__social-proof-avatars {
        display: flex;
      }

      .mat__avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-sans);
        font-size: 11px;
        font-weight: 700;
        color: white;
        margin-left: -6px;
        border: 2px solid var(--color-cream);
      }

      .mat__avatar:first-child {
        margin-left: 0;
      }

      .mat__avatar:nth-child(1) { background: var(--color-sage); }
      .mat__avatar:nth-child(2) { background: var(--color-blush); }
      .mat__avatar:nth-child(3) { background: var(--color-lavender); }
      .mat__avatar:nth-child(4) { background: var(--color-gold); }

      .mat__social-proof-text {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        font-weight: 500;
      }

      /* ======= CONTENT PREVIEW ======= */
      .mat__preview {
        margin-bottom: var(--space-10);
      }

      .mat__preview-title {
        font-family: var(--font-sans);
        font-size: var(--text-lg);
        font-weight: 700;
        color: var(--color-carbon);
        text-align: center;
        margin-bottom: var(--space-6);
      }

      .mat__preview-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-4);
      }

      @media (min-width: 640px) {
        .mat__preview-grid {
          grid-template-columns: 1fr 1fr;
        }
      }

      .mat__preview-card {
        background: var(--color-white);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        padding: var(--space-5);
      }

      .mat__preview-icon {
        font-size: var(--text-2xl);
        display: block;
        margin-bottom: var(--space-2);
      }

      .mat__preview-card strong {
        font-family: var(--font-sans);
        font-size: var(--text-base);
        font-weight: 700;
        color: var(--color-carbon);
        display: block;
        margin-bottom: var(--space-3);
      }

      .mat__preview-card ul {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
      }

      .mat__preview-card li {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        padding-left: var(--space-5);
        position: relative;
        line-height: 1.5;
      }

      .mat__preview-card li::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: var(--color-sage);
        font-weight: 700;
        font-size: var(--text-xs);
      }

      /* ======= FOOTER (minimal, no method links) ======= */
      .mat__footer {
        text-align: center;
        padding: var(--space-6) 0;
        border-top: 1px solid var(--color-border);
      }

      .mat__footer p {
        font-family: var(--font-sans);
        font-size: var(--text-xs);
        color: var(--color-text-light);
        margin-bottom: var(--space-2);
      }

      .mat__footer-links {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2);
        font-family: var(--font-sans);
        font-size: var(--text-xs);
      }

      .mat__footer-links a {
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 0.2s ease;
      }

      .mat__footer-links a:hover {
        color: var(--color-sage);
      }

      .mat__footer-links span {
        color: var(--color-text-light);
      }

      /* ======= RESPONSIVE ======= */
      @media (max-width: 480px) {
        .mat {
          padding: var(--space-6) var(--space-4) var(--space-4);
        }

        .mat__title-serif {
          font-size: var(--text-3xl);
        }

        .mat__title-sans {
          font-size: var(--text-xl);
        }

        .mat__product-info {
          padding: var(--space-4);
        }

        .mat__product-pricing {
          padding: var(--space-5) var(--space-4);
        }

        .mat__price-current {
          font-size: var(--text-3xl);
        }
      }
    </style>
  </body>
</html>
