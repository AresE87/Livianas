        margin: 0 0 0.75rem;
      }
      .testimonial-card__text {
        font-family: var(--font-sans);
        font-size: 0.9rem;
        color: var(--color-text-muted);
        line-height: 1.7;
        max-width: 500px;
        margin: 0 auto;
      }
      .testimonials__nav {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin-top: 1.5rem;
      }
      .carousel-btn {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-full);
        border: 1px solid var(--color-border);
        background: var(--color-white);
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
      }
      .carousel-btn:hover {
        background: var(--color-sage-wash);
        border-color: var(--color-sage-light);
      }
      .carousel-dots {
        display: flex;
        gap: 0.4rem;
      }
      .carousel-dot {
        width: 8px;
        height: 8px;
        border-radius: var(--radius-full);
        background: var(--color-border);
        border: none;
        cursor: pointer;
        transition: all 0.2s;
      }
      .carousel-dot.active {
        background: var(--color-gold);
        width: 20px;
      }

      /* --- Registration --- */
      .registro {
        background: var(--color-carbon);
        color: var(--color-cream);
      }
      .registro .section-label { color: var(--color-gold); }
      .registro .section-title { color: var(--color-cream); }
      .registro .section-subtitle { color: rgba(251,249,245,0.6); }
      .registro__inner { max-width: 480px; }
      .registro__form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .form-group label {
        display: block;
        font-family: var(--font-outfit);
        font-size: 0.85rem;
        font-weight: 600;
        color: rgba(251,249,245,0.7);
        margin-bottom: 0.35rem;
      }
      .form-group input {
        width: 100%;
        padding: 0.85rem 1rem;
        border: 1px solid rgba(251,249,245,0.15);
        border-radius: var(--radius-md);
        background: rgba(251,249,245,0.06);
        color: var(--color-cream);
        font-family: var(--font-sans);
        font-size: 1rem;
        transition: border-color 0.2s;
        box-sizing: border-box;
      }
      .form-group input::placeholder { color: rgba(251,249,245,0.3); }
      .form-group input:focus {
        outline: none;
        border-color: var(--color-gold);
      }
      .registro__btn {
        width: 100%;
        padding: 1rem;
        background: var(--color-gold);
        color: var(--color-carbon);
        font-family: var(--font-outfit);
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: 0.08em;
        border: none;
        border-radius: var(--radius-full);
        cursor: pointer;
        transition: all 0.3s;
      }
      .registro__btn:hover {
        background: var(--color-gold-light);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(201,169,110,0.3);
      }
      .registro__btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
      }
      .registro__privacy {
        text-align: center;
        font-size: 0.75rem;
        color: rgba(251,249,245,0.4);
        font-family: var(--font-sans);
      }
      .registro__success {
        text-align: center;
        padding: 2rem 0;
      }
      .registro__success h3 {
        font-family: var(--font-display);
        font-size: 1.5rem;
        color: var(--color-cream);
        margin: 1rem 0 0.5rem;
      }
      .registro__success p {
        color: rgba(251,249,245,0.7);
        font-family: var(--font-sans);
      }
      .check-anim {
        width: 56px;
        height: 56px;
        border-radius: var(--radius-full);
        border: 2px solid var(--color-gold);
        color: var(--color-gold);
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        animation: scaleIn 0.4s ease-out;
