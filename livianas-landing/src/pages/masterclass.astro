---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PremiumFooter from '../components/PremiumFooter.astro';
import TestimonialsCarousel from '../components/TestimonialsCarousel.astro';
import { siteConfig } from '../lib/config';

const mc = siteConfig.masterclass;
const waLink = `https://wa.me/${siteConfig.whatsappNumber}?text=${mc.whatsappMessages.hero}`;

const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: `Masterclass: ${mc.nombre}`,
  description: mc.subtitulo,
  startDate: mc.fechaISO,
  eventAttendanceMode: 'https://schema.org/OnlineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: {
    '@type': 'VirtualLocation',
    url: 'https://livianas.com/masterclass',
  },
  organizer: {
    '@type': 'Person',
    name: 'Ana',
    url: 'https://livianas.com',
  },
  isAccessibleForFree: true,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
  },
};

const queVasAAprender = [
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`,
    title: 'Mentira #1: "Necesitás más fuerza de voluntad"',
    description: 'Vas a descubrir por qué la fuerza de voluntad no es el problema — y qué es lo que realmente te frena.',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Mentira #2: "Comer sano es caro y difícil"',
    description: 'Te voy a mostrar cómo la alimentación antiinflamatoria puede ser simple, accesible y sin restricciones.',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    title: 'Mentira #3: "Tu cuerpo es el enemigo"',
    description: 'Vamos a cambiar la forma en que te mirás y hablás sobre tu cuerpo. El cambio empieza por dentro.',
  },
];

const paraQuienEs = [
  'Estás cansada de empezar dietas y no poder sostenerlas',
  'Sentís que la comida te controla en vez de nutrirte',
  'Te pesás cada mañana y ese número decide tu día',
  'Comés por ansiedad o emociones y después sentís culpa',
  'Sabés que algo tiene que cambiar pero no sabés por dónde',
  'Querés entender qué hay detrás de tu relación con la comida',
];
---

<Layout
  title={`Masterclass Gratuita: ${mc.nombre} — LIVIANAS`}
  description={mc.subtitulo}
>
  <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />

  <!-- ========== TOP BAR ========== -->
  <div class="mc-topbar">
    ¿Cansada de empezar dietas que nunca funcionan? Descubrí por qué.
  </div>

  <!-- ========== 1. HERO — SPLIT LAYOUT ========== -->
  <section class="mc-hero" aria-label="Masterclass gratuita">
    <!-- Background watermark -->
    <div class="mc-hero__watermark" aria-hidden="true">LIVIANAS</div>

    <div class="mc-hero__grid">
      <!-- LEFT: Content -->
      <div class="mc-hero__text">
        <div class="mc-hero__top-badge">
          MASTERCLASS GRATUITA &middot; {mc.fecha.toUpperCase()} &middot; {mc.hora.toUpperCase()} &middot; {mc.plataforma.toUpperCase()}
        </div>

        <h1 class="mc-hero__title">
          Las 3 Mentiras que te Alejan de <em class="mc-hero__highlight">Vivir</em> Liviana.
        </h1>

        <p class="mc-hero__subtitle">
          En {mc.duracion} vas a entender por qué las dietas no funcionan, qué hay detrás de tu relación con la comida y los 3 pasos para transformarla. Sin restricciones. Sin culpa. Sin sufrir.
        </p>

        <div class="mc-hero__pills">
          <span class="mc-pill">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {mc.fecha}
          </span>
          <span class="mc-pill">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            {mc.plataforma}
          </span>
          <span class="mc-pill">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12V8H6a2 2 0 01-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/><path d="M18 12a2 2 0 000 4h4v-4h-4z"/></svg>
            100% gratuita
          </span>
        </div>

        <div class="mc-hero__time-row">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>{mc.hora}</span>
        </div>

        <a href="#registro" class="mc-hero__cta">
          QUIERO RESERVAR MI LUGAR GRATIS
        </a>

        <p class="mc-hero__urgency">
          ⚡ Los cupos son limitados. Cuando se llena, se cierra. ⚡
        </p>
      </div>

      <!-- RIGHT: Ana photo -->
      <div class="mc-hero__image-col">
        <img
          src="/images/ana-foto.webp"
          alt="Ana, creadora del Método Livianas"
          width="700"
          height="900"
          class="mc-hero__photo"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- ========== 2. QUE VAS A APRENDER ========== -->
  <section class="mc-learn section" aria-labelledby="mc-learn-title">
    <div class="container">
      <div class="mc-section-header">
        <span class="mc-label">En esta masterclass</span>
        <h2 id="mc-learn-title" class="mc-section-title">¿Qué vas a descubrir?</h2>
        <p class="mc-section-subtitle">3 creencias que te mantienen atrapada — y cómo soltarlas</p>
      </div>

      <div class="mc-cards-grid">
        {queVasAAprender.map((item, i) => (
          <article class="mc-card" style={`--card-delay: ${i * 0.1}s`}>
            <div class="mc-card__icon" set:html={item.icon} />
            <h3 class="mc-card__title">{item.title}</h3>
            <p class="mc-card__desc">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== 3. PARA QUIEN ES ========== -->
  <section class="mc-quien section" aria-labelledby="mc-quien-title">
    <div class="container container--narrow">
      <div class="mc-section-header">
        <span class="mc-label">¿Es para vos?</span>
        <h2 id="mc-quien-title" class="mc-section-title">Esta masterclass es para vos si...</h2>
      </div>

      <ul class="mc-checklist">
        {paraQuienEs.map((item) => (
          <li class="mc-checklist__item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mc-checklist__icon"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>

      <div class="mc-quien__cta-wrap">
        <a href="#registro" class="mc-hero__cta" style="display:inline-block;">Quiero mi lugar gratis</a>
      </div>
    </div>
  </section>

  <!-- ========== 4. SOBRE ANA ========== -->
  <section class="mc-ana section" aria-labelledby="mc-ana-title">
    <div class="container">
      <div class="mc-ana__grid">
        <div class="mc-ana__image-col">
          <div class="mc-ana__image-frame">
            <img
              src="/images/ana-foto.webp"
              alt="Ana, creadora del Método Livianas"
              width="480"
              height="600"
              loading="lazy"
              decoding="async"
              class="mc-ana__image"
            />
          </div>
        </div>
        <div class="mc-ana__text-col">
          <span class="mc-label">Tu guía</span>
          <h2 id="mc-ana-title" class="mc-section-title">Ana</h2>
          <blockquote class="mc-ana__quote">
            &ldquo;No necesitás más fuerza de voluntad. Necesitás entender por qué hacés lo que hacés.&rdquo;
          </blockquote>
          <p class="mc-ana__bio">
            Coach de bienestar y creadora del Método Livianas. Acompaña a mujeres a transformar su relación con la comida y el cuerpo desde un enfoque integral: conducta, emoción y espiritualidad.
          </p>
          <p class="mc-ana__bio">
            En esta masterclass gratuita, Ana va a compartir las 3 mentiras que la industria de las dietas te hizo creer — y el camino real para vivir más liviana.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 5. TESTIMONIOS ========== -->
  <TestimonialsCarousel />

  <!-- ========== 6. REGISTRO ========== -->
  <section id="registro" class="mc-registro section" aria-labelledby="mc-registro-title">
    <div class="container container--narrow">
      <div class="mc-section-header">
        <span class="mc-label">Cupos limitados</span>
        <h2 id="mc-registro-title" class="mc-section-title">Reservá tu lugar</h2>
        <p class="mc-section-subtitle">Es 100% gratuita. Solo necesitamos tu nombre y email para enviarte el link de acceso.</p>
      </div>

      <form id="mc-form" class="mc-form" action="/api/masterclass-registro" method="POST">
        <div class="mc-form__field">
          <label for="mc-nombre" class="mc-form__label">Tu nombre</label>
          <input
            type="text"
            id="mc-nombre"
            name="nombre"
            required
            placeholder="¿Cómo te llamás?"
            class="mc-form__input"
            autocomplete="given-name"
          />
        </div>
        <div class="mc-form__field">
          <label for="mc-email" class="mc-form__label">Tu email</label>
          <input
            type="email"
            id="mc-email"
            name="email"
            required
            placeholder="tu@email.com"
            class="mc-form__input"
            autocomplete="email"
          />
        </div>
        <button type="submit" class="mc-form__btn mc-hero__cta" id="mc-submit" style="text-align:center;">
          <span id="mc-btn-text">RESERVAR MI LUGAR GRATIS</span>
          <span id="mc-btn-loading" style="display:none;">Registrando...</span>
        </button>
        <p class="mc-form__privacy">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          Tu información está segura. No compartimos tus datos.
        </p>
      </form>

      <div id="mc-success" class="mc-success" style="display:none;">
        <div class="mc-success__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
        </div>
        <h3 class="mc-success__title">¡Listo! Tu lugar está reservado</h3>
        <p class="mc-success__text">Revisá tu email — te enviamos los detalles de acceso.</p>
      </div>
    </div>
  </section>

  <!-- ========== 7. CTA FINAL ========== -->
  <section class="mc-final section" aria-label="Llamado final">
    <div class="container container--narrow" style="text-align:center;">
      <h2 class="mc-section-title" style="color:white;">¿Tenés dudas?</h2>
      <p style="color: rgba(255,255,255,0.8); font-size: 1.05rem; margin-bottom: var(--space-8);">
        Escribile directamente a Ana por WhatsApp
      </p>
      <a href={waLink} target="_blank" rel="noopener" class="btn--whatsapp mc-final__btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.67-2.08-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.03-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.21 5.1 4.5.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.58-.09 1.76-.72 2.01-1.42.25-.7.25-1.3.17-1.42-.07-.13-.27-.2-.57-.35z"/><path d="M12 0C5.37 0 0 5.37 0 12c0 2.12.55 4.11 1.51 5.85L0 24l6.33-1.66C8.07 23.42 9.99 24 12 24c6.63 0 12-5.37 12-12S18.63 0 12 0zm0 22c-1.82 0-3.56-.5-5.08-1.41l-.36-.22-3.76.99 1-3.67-.24-.37A9.94 9.94 0 012 12c0-5.51 4.49-10 10-10s10 4.49 10 10-4.49 10-10 10z"/></svg>
        Hablar con Ana
      </a>
    </div>
  </section>

  <PremiumFooter />
</Layout>

<script>
  function initMasterclassForm() {
    const form = document.getElementById('mc-form') as HTMLFormElement;
    const successEl = document.getElementById('mc-success');
    const btnText = document.getElementById('mc-btn-text');
    const btnLoading = document.getElementById('mc-btn-loading');
    const submitBtn = document.getElementById('mc-submit') as HTMLButtonElement;
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !btnText || !btnLoading || !successEl) return;

      submitBtn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = 'inline';

      const formData = new FormData(form);
      const data = {
        nombre: formData.get('nombre'),
        email: formData.get('email'),
      };

      try {
        const res = await fetch('/api/masterclass-registro', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.style.display = 'none';
          successEl.style.display = 'block';
        } else {
          throw new Error('Error en el registro');
        }
      } catch (err) {
        alert('Hubo un error. Por favor intentá de nuevo o escribile a Ana por WhatsApp.');
        submitBtn.disabled = false;
        btnText.style.display = 'inline';
        btnLoading.style.display = 'none';
      }
    });
  }

  initMasterclassForm();
  document.addEventListener('astro:after-swap', initMasterclassForm);
</script>

<style>
  /* ========== TOP BAR ========== */
  .mc-topbar {
    background: var(--color-sage);
    color: white;
    text-align: center;
    font-family: var(--font-outfit);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.65rem 1rem;
    position: relative;
    z-index: 100;
  }

  /* ========== HERO — SPLIT ========== */
  .mc-hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-cream-warm) 60%, rgba(123, 143, 107, 0.08) 100%);
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
  }

  .mc-hero__watermark {
    position: absolute;
    right: -2%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: clamp(8rem, 18vw, 20rem);
    font-weight: 700;
    color: rgba(123, 143, 107, 0.04);
    pointer-events: none;
    white-space: nowrap;
    line-height: 1;
    z-index: 0;
  }

  .mc-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 6rem 1.5rem 2rem;
    gap: var(--space-8);
    position: relative;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .mc-hero__grid {
      grid-template-columns: 1fr 1fr;
      padding: 2rem 3rem;
      gap: var(--space-6);
      min-height: 100vh;
      min-height: 100dvh;
    }
  }

  @media (min-width: 1024px) {
    .mc-hero__grid {
      grid-template-columns: 1.1fr 0.9fr;
      padding: 2rem 4rem;
    }
  }

  /* Hero text */
  .mc-hero__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .mc-hero__top-badge {
    display: inline-flex;
    align-self: flex-start;
    font-family: var(--font-outfit);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: white;
    background: var(--color-sage);
    padding: 0.6rem 1.5rem;
    border-radius: var(--radius-full);
  }

  .mc-hero__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.2;
    color: var(--color-carbon);
  }

  .mc-hero__highlight {
    color: var(--color-sage);
    font-style: italic;
  }

  .mc-hero__subtitle {
    font-family: var(--font-sans);
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 540px;
  }

  /* Pills */
  .mc-hero__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .mc-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-carbon);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.5rem 1rem;
  }

  .mc-pill svg {
    color: var(--color-sage);
    flex-shrink: 0;
  }

  .mc-hero__time-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding: 0.5rem 1rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    align-self: flex-start;
  }

  .mc-hero__time-row svg {
    color: var(--color-sage);
  }

  /* CTA */
  .mc-hero__cta {
    display: inline-block;
    font-family: var(--font-outfit);
    font-weight: 700;
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: white;
    background: var(--color-sage);
    border: none;
    border-radius: var(--radius-full);
    padding: 1.1rem 2.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    text-align: center;
    box-shadow: 0 4px 20px rgba(123, 143, 107, 0.35);
  }

  .mc-hero__cta:hover {
    background: var(--color-sage-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(123, 143, 107, 0.45);
  }

  .mc-hero__urgency {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* Hero image */
  .mc-hero__image-col {
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }

  .mc-hero__photo {
    width: 100%;
    max-width: 500px;
    height: auto;
    object-fit: cover;
    object-position: top center;
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    box-shadow: 0 20px 60px rgba(44, 40, 37, 0.15);
  }

  @media (min-width: 768px) {
    .mc-hero__photo {
      max-width: 100%;
      max-height: 85vh;
      border-radius: var(--radius-xl);
    }
  }

  /* ========== SHARED ========== */
  .mc-section-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .mc-label {
    display: inline-block;
    font-family: var(--font-outfit);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-sage);
    background: var(--color-sage-wash);
    padding: 0.35rem 1rem;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-4);
  }

  .mc-section-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--color-carbon);
    margin-bottom: var(--space-3);
  }

  .mc-section-subtitle {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 520px;
    margin: 0 auto;
  }

  /* ========== QUE VAS A APRENDER ========== */
  .mc-learn {
    background: var(--color-white);
  }

  .mc-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 960px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .mc-cards-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .mc-card {
