      }

      /* --- Footer --- */
      .mc-footer {
        background: var(--color-carbon);
        color: rgba(251,249,245,0.5);
        text-align: center;
        padding: 2rem 1.5rem;
        font-family: var(--font-sans);
        font-size: 0.8rem;
        border-top: 1px solid rgba(251,249,245,0.08);
      }
      .mc-footer__brand {
        font-family: var(--font-outfit);
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        color: rgba(251,249,245,0.7);
        margin-bottom: 0.5rem;
      }
      .mc-footer__links {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
      }
      .mc-footer__links a {
        color: rgba(251,249,245,0.4);
        text-decoration: none;
        font-size: 0.75rem;
      }
      .mc-footer__links a:hover { color: rgba(251,249,245,0.7); }
      .mc-footer__copy { margin-bottom: 0.25rem; }
      .mc-footer__tagline { font-style: italic; color: rgba(251,249,245,0.3); }

      /* --- Responsive --- */
      @media (max-width: 768px) {
        .hero__inner {
          flex-direction: column;
          text-align: center;
        }
        .hero__photo { max-width: 260px; }
        .hero__subtitle { margin-left: auto; margin-right: auto; }
        .hero__badges { justify-content: center; }
        .pillars__grid { grid-template-columns: 1fr; }
        .about-ana__inner {
          flex-direction: column;
          align-items: center;
          text-align: center;
        }
        .about-ana__content .section-title { text-align: center !important; }
      }

      /* --- Animations --- */
      @keyframes scaleIn {
        from { transform: scale(0.5); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
      }
    </style>

    <!-- ═══ SCRIPTS ═══ -->
    <script>
      // --- Carousel ---
      const cards = document.querySelectorAll('.testimonial-card');
      const dotsContainer = document.getElementById('carousel-dots');
      const prevBtn = document.getElementById('prev-btn');
      const nextBtn = document.getElementById('next-btn');
      let currentIndex = 0;

      // Create dots
      cards.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.className = `carousel-dot${i === 0 ? ' active' : ''}`;
        dot.setAttribute('aria-label', `Ver testimonio ${i + 1}`);
        dot.addEventListener('click', () => goTo(i));
        dotsContainer?.appendChild(dot);
      });

      function goTo(index: number) {
        currentIndex = index;
        cards.forEach((card, i) => {
          (card as HTMLElement).style.transform = `translateX(-${currentIndex * 100}%)`;
        });
        document.querySelectorAll('.carousel-dot').forEach((dot, i) => {
          dot.classList.toggle('active', i === currentIndex);
        });
      }

      prevBtn?.addEventListener('click', () => goTo((currentIndex - 1 + cards.length) % cards.length));
      nextBtn?.addEventListener('click', () => goTo((currentIndex + 1) % cards.length));

      // Touch swipe
      let touchStartX = 0;
      const carousel = document.getElementById('carousel');
      carousel?.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
      carousel?.addEventListener('touchend', (e) => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) {
          diff > 0 ? goTo((currentIndex + 1) % cards.length) : goTo((currentIndex - 1 + cards.length) % cards.length);
        }
      });

      // --- Registration Form ---
      const form = document.getElementById('mc-form') as HTMLFormElement;
      const submitBtn = document.getElementById('mc-submit') as HTMLButtonElement;
      const successDiv = document.getElementById('mc-success');

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        submitBtn.querySelector('.btn-text')!.style.display = 'none';
        submitBtn.querySelector('.btn-loading')!.style.display = 'inline';

        const nombre = (document.getElementById('mc-nombre') as HTMLInputElement).value.trim();
        const email = (document.getElementById('mc-email') as HTMLInputElement).value.trim();

        try {
          const res = await fetch('/api/masterclass-registro', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ nombre, email }),
          });

          if (!res.ok) throw new Error('Error');

          // Track
          if (typeof (window as any).fbq !== 'undefined') {
            (window as any).fbq('track', 'Lead', { content_name: 'Masterclass EFECTO LIVIANA' });
          }
          if (typeof (window as any).gtag !== 'undefined') {
            (window as any).gtag('event', 'sign_up', { method: 'masterclass_efecto_liviana' });
          }

          // Show success
          form.style.display = 'none';
          successDiv!.style.display = 'block';

          // Optional: redirect after delay
          setTimeout(() => {
            window.location.href = '/masterclass/gracias';
          }, 2000);
        } catch {
          submitBtn.disabled = false;
          submitBtn.querySelector('.btn-text')!.style.display = 'inline';
          submitBtn.querySelector('.btn-loading')!.style.display = 'none';
          alert('Hubo un error. Por favor intentá de nuevo.');
        }
      });

      // --- CTA Click Tracking ---
      document.querySelectorAll('a[href="#registro"]').forEach((btn) => {
        btn.addEventListener('click', () => {
          if (typeof (window as any).gtag !== 'undefined') {
            (window as any).gtag('event', 'cta_click', { button_location: 'masterclass_cta' });
          }
        });
      });

      // --- Scroll depth tracking ---
      let scrollTracked = false;
      window.addEventListener('scroll', () => {
        if (scrollTracked) return;
        const pct = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
        if (pct >= 0.5) {
          scrollTracked = true;
          if (typeof (window as any).fbq !== 'undefined') {
            (window as any).fbq('track', 'ViewContent', { content_name: 'Masterclass EFECTO LIVIANA' });
          }
        }
      }, { passive: true });
    </script>
  </body>
</html>
