---
import Layout from '../layouts/Layout.astro';
import PremiumFooter from '../components/PremiumFooter.astro';
import TestimonialsCarousel from '../components/TestimonialsCarousel.astro';
import { siteConfig } from '../lib/config';

const mc = siteConfig.masterclass;
const waLink = `https://wa.me/${siteConfig.whatsappNumber}?text=${mc.whatsappMessages.hero}`;

const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: `Masterclass: ${mc.nombre}`,
  description: mc.subtitulo,
  startDate: mc.fechaISO,
  eventAttendanceMode: 'https://schema.org/OnlineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: { '@type': 'VirtualLocation', url: 'https://livianas.com/masterclass' },
  organizer: { '@type': 'Person', name: 'Ana', url: 'https://livianas.com' },
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD', availability: 'https://schema.org/InStock' },
};

const queVasAAprender = [
  {
    num: '01',
    title: '"Necesitás más fuerza de voluntad"',
    description: 'Vas a descubrir por qué la fuerza de voluntad no es el problema — y qué es lo que realmente te frena.',
  },
  {
    num: '02',
    title: '"Comer sano es caro y difícil"',
    description: 'Te voy a mostrar cómo la alimentación antiinflamatoria puede ser simple, accesible y sin restricciones.',
  },
  {
    num: '03',
    title: '"Tu cuerpo es el enemigo"',
    description: 'Vamos a cambiar la forma en que te mirás y hablás sobre tu cuerpo. El cambio empieza por dentro.',
  },
];

const paraQuienEs = [
  'Estás cansada de empezar dietas y no poder sostenerlas',
  'Sentís que la comida te controla en vez de nutrirte',
  'Te pesás cada mañana y ese número decide tu día',
  'Comés por ansiedad o emociones y después sentís culpa',
  'Sabés que algo tiene que cambiar pero no sabés por dónde',
  'Querés entender qué hay detrás de tu relación con la comida',
];
---

<Layout
  title={`Masterclass Gratuita: ${mc.nombre} — LIVIANAS`}
  description={mc.subtitulo}
>
  <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />

  <!-- ========== TOP BAR ========== -->
  <div class="mc-topbar">
    ¿Cansada de empezar dietas que nunca funcionan? Descubrí por qué.
  </div>

  <!-- ========== 1. HERO — PHOTO-FIRST ========== -->
  <section class="mc-hero" aria-label="Masterclass gratuita">
    <!-- Photo area with watermark behind -->
    <div class="mc-hero__photo-area">
      <div class="mc-hero__watermark" aria-hidden="true">
        <span>Vivir</span>
        <span>Liviana</span>
      </div>
      <img
        src="/images/ana-foto.webp"
        alt="Ana, creadora del Método Livianas"
        width="700"
        height="900"
        class="mc-hero__photo"
        loading="eager"
        fetchpriority="high"
      />
      <!-- Badge overlaid on photo -->
      <div class="mc-hero__badge">
        MASTERCLASS GRATUITA &middot; {mc.fecha.toUpperCase()} &middot; {mc.hora.toUpperCase()} &middot; ZOOM
      </div>
    </div>

    <!-- Content below photo -->
    <div class="mc-hero__content">
      <h1 class="mc-hero__title">
        Las 3 Mentiras que te Alejan de <em>Vivir</em> Liviana.
      </h1>

      <p class="mc-hero__subtitle">
        En {mc.duracion} vas a entender por qué las dietas no funcionan, qué hay detrás de tu relación con la comida y los 3 pasos para transformarla. Sin restricciones. Sin culpa. Sin sufrir.
      </p>

      <div class="mc-hero__pills">
        <span class="mc-pill">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {mc.hora}
        </span>
        <span class="mc-pill">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {mc.fecha}
        </span>
        <span class="mc-pill">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          Zoom
        </span>
        <span class="mc-pill mc-pill--free">
          🎁 100% gratuita
        </span>
      </div>

      <a href="#registro" class="mc-hero__cta">
        QUIERO UNIRME Y ASEGURAR MI LUGAR
      </a>

      <p class="mc-hero__urgency">
        ⚡ Los cupos son limitados. Cuando se llena, se cierra. ⚡
      </p>
    </div>
  </section>

  <!-- ========== 2. QUE VAS A APRENDER ========== -->
  <section class="mc-learn" aria-labelledby="mc-learn-title">
    <div class="mc-container">
      <div class="mc-section-header">
        <span class="mc-label">En esta masterclass</span>
        <h2 id="mc-learn-title" class="mc-section-title">¿Qué vas a descubrir?</h2>
        <p class="mc-section-sub">3 creencias que te mantienen atrapada — y cómo soltarlas</p>
      </div>

      <div class="mc-mentiras">
        {queVasAAprender.map((item) => (
          <article class="mc-mentira">
            <span class="mc-mentira__num">{item.num}</span>
            <div>
              <h3 class="mc-mentira__title">Mentira: {item.title}</h3>
              <p class="mc-mentira__desc">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== 3. PARA QUIEN ES ========== -->
  <section class="mc-quien" aria-labelledby="mc-quien-title">
    <div class="mc-container mc-container--narrow">
      <div class="mc-section-header">
        <span class="mc-label">¿Es para vos?</span>
        <h2 id="mc-quien-title" class="mc-section-title">Esta masterclass es para vos si...</h2>
      </div>

      <ul class="mc-checklist">
        {paraQuienEs.map((item) => (
          <li class="mc-check">
            <span class="mc-check__icon">✓</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>

      <div style="text-align:center; margin-top:2.5rem;">
        <a href="#registro" class="mc-hero__cta">Quiero mi lugar gratis</a>
      </div>
    </div>
  </section>

  <!-- ========== 4. SOBRE ANA ========== -->
  <section class="mc-ana" aria-labelledby="mc-ana-title">
    <div class="mc-container">
      <div class="mc-ana__grid">
        <div class="mc-ana__img-wrap">
          <img src="/images/ana-foto.webp" alt="Ana" width="480" height="600" loading="lazy" class="mc-ana__img" />
        </div>
        <div class="mc-ana__text">
          <span class="mc-label">Tu guía</span>
          <h2 id="mc-ana-title" class="mc-section-title">Ana</h2>
          <blockquote class="mc-ana__quote">
            &ldquo;No necesitás más fuerza de voluntad. Necesitás entender por qué hacés lo que hacés.&rdquo;
          </blockquote>
          <p class="mc-ana__bio">
            Coach de bienestar y creadora del Método Livianas. Acompaña a mujeres a transformar su relación con la comida y el cuerpo desde un enfoque integral: conducta, emoción y espiritualidad.
          </p>
          <p class="mc-ana__bio">
            En esta masterclass gratuita, Ana va a compartir las 3 mentiras que la industria de las dietas te hizo creer — y el camino real para vivir más liviana.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 5. TESTIMONIOS ========== -->
  <TestimonialsCarousel />

  <!-- ========== 6. REGISTRO ========== -->
  <section id="registro" class="mc-registro" aria-labelledby="mc-registro-title">
    <div class="mc-container mc-container--narrow">
      <div class="mc-section-header">
        <span class="mc-label">Cupos limitados</span>
        <h2 id="mc-registro-title" class="mc-section-title">Reservá tu lugar</h2>
        <p class="mc-section-sub">Es 100% gratuita. Solo necesitamos tu nombre y email para enviarte el link.</p>
      </div>

      <form id="mc-form" class="mc-form">
        <div class="mc-form__field">
          <label for="mc-nombre" class="mc-form__label">Tu nombre</label>
          <input type="text" id="mc-nombre" name="nombre" required placeholder="¿Cómo te llamás?" class="mc-form__input" autocomplete="given-name" />
        </div>
        <div class="mc-form__field">
          <label for="mc-email" class="mc-form__label">Tu email</label>
          <input type="email" id="mc-email" name="email" required placeholder="tu@email.com" class="mc-form__input" autocomplete="email" />
        </div>
        <button type="submit" class="mc-hero__cta mc-form__submit" id="mc-submit">
          <span id="mc-btn-text">RESERVAR MI LUGAR GRATIS</span>
          <span id="mc-btn-loading" style="display:none;">Registrando...</span>
        </button>
        <p class="mc-form__note">🔒 Tu información está segura. No compartimos tus datos.</p>
      </form>

      <div id="mc-success" class="mc-success" style="display:none;">
        <div class="mc-success__check">✓</div>
        <h3 class="mc-success__title">¡Listo! Tu lugar está reservado</h3>
        <p class="mc-success__text">Revisá tu email — te enviamos los detalles de acceso.</p>
      </div>
    </div>
  </section>

  <!-- ========== 7. CTA FINAL ========== -->
  <section class="mc-final">
    <div class="mc-container mc-container--narrow" style="text-align:center;">
      <h2 class="mc-section-title" style="color:white;">¿Tenés dudas?</h2>
      <p style="color:rgba(255,255,255,0.75); font-size:1.1rem; margin-bottom:2rem;">
        Escribile directamente a Ana por WhatsApp
      </p>
      <a href={waLink} target="_blank" rel="noopener" class="mc-wa-btn">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.67-2.08-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.03-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.21 5.1 4.5.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.58-.09 1.76-.72 2.01-1.42.25-.7.25-1.3.17-1.42-.07-.13-.27-.2-.57-.35z"/><path d="M12 0C5.37 0 0 5.37 0 12c0 2.12.55 4.11 1.51 5.85L0 24l6.33-1.66C8.07 23.42 9.99 24 12 24c6.63 0 12-5.37 12-12S18.63 0 12 0zm0 22c-1.82 0-3.56-.5-5.08-1.41l-.36-.22-3.76.99 1-3.67-.24-.37A9.94 9.94 0 012 12c0-5.51 4.49-10 10-10s10 4.49 10 10-4.49 10-10 10z"/></svg>
        Hablar con Ana
      </a>
    </div>
  </section>

  <PremiumFooter />
</Layout>

<script>
  function initMasterclassForm() {
    const form = document.getElementById('mc-form') as HTMLFormElement;
    const successEl = document.getElementById('mc-success');
    const btnText = document.getElementById('mc-btn-text');
    const btnLoading = document.getElementById('mc-btn-loading');
    const submitBtn = document.getElementById('mc-submit') as HTMLButtonElement;
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !btnText || !btnLoading || !successEl) return;

      submitBtn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = 'inline';

      const formData = new FormData(form);
      const data = { nombre: formData.get('nombre'), email: formData.get('email') };

      try {
        const res = await fetch('/api/masterclass-registro', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          form.style.display = 'none';
          successEl.style.display = 'block';
        } else {
          throw new Error('fail');
        }
      } catch {
        alert('Hubo un error. Por favor intentá de nuevo o escribile a Ana por WhatsApp.');
        submitBtn.disabled = false;
        btnText.style.display = 'inline';
        btnLoading.style.display = 'none';
      }
    });
  }
  initMasterclassForm();
  document.addEventListener('astro:after-swap', initMasterclassForm);
</script>

<style>
  /* ===== RESET & BASE ===== */
  .mc-container {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  .mc-container--narrow { max-width: 680px; }

  /* ===== TOP BAR ===== */
  .mc-topbar {
    background: #B91C1C;
    color: #fff;
    text-align: center;
    font-family: var(--font-outfit);
    font-size: clamp(0.85rem, 2.2vw, 1.1rem);
    font-weight: 700;
    padding: 0.75rem 1rem;
    letter-spacing: 0.02em;
  }

  /* ===== HERO ===== */
  .mc-hero {
    background: #fff;
  }

  /* Photo area — the photo IS the hero */
  .mc-hero__photo-area {
    position: relative;
    width: 100%;
    background: linear-gradient(180deg, #FAF0EC 0%, #F3DDD4 40%, #EDD0C5 100%);
    display: flex;
    justify-content: center;
    align-items: flex-end;
    overflow: hidden;
    min-height: 50vh;
  }

  .mc-hero__watermark {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    pointer-events: none;
    z-index: 0;
  }

  .mc-hero__watermark span {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: italic;
    line-height: 0.9;
    color: rgba(160, 100, 80, 0.12);
  }

  .mc-hero__watermark span:first-child {
    font-size: clamp(5rem, 20vw, 16rem);
  }

  .mc-hero__watermark span:last-child {
    font-size: clamp(5.5rem, 22vw, 18rem);
    color: rgba(160, 100, 80, 0.08);
  }

  .mc-hero__photo {
    position: relative;
    z-index: 1;
    width: 65%;
    max-width: 480px;
    height: auto;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  @media (min-width: 768px) {
    .mc-hero__photo-area {
      min-height: 70vh;
    }
    .mc-hero__photo {
      width: 45%;
      max-width: 520px;
    }
  }

  /* Badge overlaid on photo bottom */
  .mc-hero__badge {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-family: var(--font-outfit);
    font-size: clamp(0.6rem, 1.5vw, 0.75rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(44, 40, 37, 0.85);
    backdrop-filter: blur(8px);
    padding: 0.7rem 1.5rem;
    border-radius: 999px;
    white-space: nowrap;
    max-width: 90%;
    text-align: center;
  }

  @media (max-width: 480px) {
    .mc-hero__badge {
      white-space: normal;
      max-width: 85%;
      font-size: 0.65rem;
    }
  }

  /* Content below photo */
  .mc-hero__content {
    padding: 2.5rem 1.5rem 3rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 680px;
    margin: 0 auto;
  }

  .mc-hero__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 5.5vw, 3rem);
    line-height: 1.2;
    color: #1a1614;
  }

  .mc-hero__title em {
    color: #7B8F6B;
    font-style: italic;
    text-decoration: underline;
    text-decoration-color: rgba(123, 143, 107, 0.35);
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
  }

  .mc-hero__subtitle {
    font-family: var(--font-sans);
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    line-height: 1.7;
    color: #5a524d;
  }

  /* Pills */
  .mc-hero__pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }

  .mc-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    color: #3d3835;
    background: #f5f0ec;
    border: 1px solid #e8dfd6;
    border-radius: 999px;
    padding: 0.5rem 1rem;
  }

  .mc-pill svg { color: #7B8F6B; flex-shrink: 0; }

  .mc-pill--free {
    background: #f0f3ec;
    border-color: #c9d6b8;
    color: #5E7252;
  }

  /* CTA — Big green button */
  .mc-hero__cta {
    display: block;
    width: 100%;
    max-width: 480px;
    font-family: var(--font-outfit);
    font-weight: 800;
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-align: center;
    color: #fff;
    background: #5E7252;
    border: none;
    border-radius: 999px;
    padding: 1.2rem 2rem;
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(94, 114, 82, 0.35);
  }

  .mc-hero__cta:hover {
    background: #4a5e40;
    transform: translateY(-2px);
    box-shadow: 0 10px 36px rgba(94, 114, 82, 0.45);
  }

  .mc-hero__urgency {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: #8a7e77;
    font-weight: 500;
  }

  /* ===== SECTIONS SHARED ===== */
  .mc-section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .mc-label {
    display: inline-block;
    font-family: var(--font-outfit);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #5E7252;
    background: #f0f3ec;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }

  .mc-section-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: #1a1614;
    margin-bottom: 0.75rem;
  }

  .mc-section-sub {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: #7a7470;
    max-width: 480px;
    margin: 0 auto;
  }

  /* ===== QUE VAS A APRENDER ===== */
  .mc-learn {
    background: #fff;
    padding: 5rem 0;
  }

  .mc-mentiras {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 680px;
    margin: 0 auto;
  }

  .mc-mentira {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 2rem 0;
    border-bottom: 1px solid #f0ebe6;
  }

  .mc-mentira:last-child { border-bottom: none; }

  .mc-mentira__num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: rgba(123, 143, 107, 0.2);
    line-height: 1;
    flex-shrink: 0;
    width: 3.5rem;
  }

  .mc-mentira__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    color: #1a1614;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .mc-mentira__desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #7a7470;
  }

  /* ===== PARA QUIEN ===== */
  .mc-quien {
    background: #FAF7F4;
    padding: 5rem 0;
  }

  .mc-checklist {
    list-style: none;
    padding: 0;
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .mc-check {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: #3d3835;
  }

  .mc-check__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #5E7252;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    margin-top: 2px;
  }

  /* ===== SOBRE ANA ===== */
  .mc-ana {
    background: #fff;
    padding: 5rem 0;
  }

  .mc-ana__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    max-width: 880px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .mc-ana__grid { grid-template-columns: 0.8fr 1.2fr; }
  }

  .mc-ana__img-wrap {
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(44, 40, 37, 0.1);
  }

  .mc-ana__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .mc-ana__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mc-ana__quote {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-style: italic;
    font-weight: 600;
    color: #1a1614;
    line-height: 1.5;
    border-left: 3px solid #7B8F6B;
    padding-left: 1.25rem;
    margin: 0;
  }

