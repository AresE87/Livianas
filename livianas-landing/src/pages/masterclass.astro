---
import Layout from '../layouts/Layout.astro';
import PremiumFooter from '../components/PremiumFooter.astro';
import TestimonialsCarousel from '../components/TestimonialsCarousel.astro';
import { siteConfig } from '../lib/config';

const mc = siteConfig.masterclass;
const waLink = `https://wa.me/${siteConfig.whatsappNumber}?text=${mc.whatsappMessages.hero}`;

const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: `Masterclass: ${mc.nombre}`,
  description: mc.subtitulo,
  startDate: mc.fechaISO,
  eventAttendanceMode: 'https://schema.org/OnlineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: { '@type': 'VirtualLocation', url: 'https://livianas.com/masterclass' },
  organizer: { '@type': 'Person', name: 'Ana', url: 'https://livianas.com' },
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD', availability: 'https://schema.org/InStock' },
};

const mentiras = [
  {
    num: '01',
    titulo: '"Para bajar de peso tenés que sufrir"',
    texto: 'Te enseñaron que sin sacrificio no hay resultado. Que si no pasás hambre, no funciona. Eso es una mentira que te mantiene atrapada en el ciclo de culpa.',
  },
  {
    num: '02',
    titulo: '"Si tuvieras fuerza de voluntad, ya lo habrías logrado"',
    texto: 'No es un tema de voluntad. Es un tema de entender qué hay detrás de lo que hacés con la comida. Cuando eso cambia, todo cambia.',
  },
  {
    num: '03',
    titulo: '"Tu cuerpo es el problema"',
    texto: 'Tu cuerpo no es el enemigo. Es el mensajero. Cuando aprendés a escucharlo en vez de castigarlo, empezás a vivir más liviana.',
  },
];

const paraQuien = [
  'Empezás dietas con toda la motivación y a las dos semanas las dejás',
  'Comés por ansiedad, aburrimiento o tristeza — no por hambre real',
  'Tu estado de ánimo depende de lo que dice la balanza',
  'Sentís que la comida te controla en vez de nutrirte',
  'Sabés que el problema no es la comida, pero no sabés qué hacer',
  'Querés un cambio real, no otra promesa con fecha de vencimiento',
];
---

<Layout
  title={`Masterclass Gratuita: ${mc.nombre} — LIVIANAS`}
  description="Descubrí las 3 mentiras que te alejan de vivir liviana. Masterclass gratuita en vivo con Ana."
>
  <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />

  <!-- TOP BAR -->
  <div class="mc-bar">¿Cansada de empezar dietas que nunca funcionan? Descubrí por qué.</div>

  <!-- ===== HERO ===== -->
  <section class="mc-hero">
    <div class="mc-hero__photo-wrap">
      <!-- Watermark behind -->
      <div class="mc-hero__wm" aria-hidden="true">
        <span>Vivir</span>
        <span>Liviana</span>
      </div>
      <img
        src="/images/ana-foto.webp"
        alt="Ana, creadora del Método Livianas"
        class="mc-hero__img"
        width="700" height="900"
        loading="eager"
        fetchpriority="high"
      />
      <div class="mc-hero__badge">
        MASTERCLASS GRATUITA &middot; {mc.fecha.toUpperCase()} &middot; {mc.hora.toUpperCase()} &middot; ZOOM
      </div>
    </div>

    <div class="mc-hero__body">
      <h1 class="mc-hero__h1">
        Las 3 Mentiras que te Alejan de&nbsp;<em>Vivir</em>&nbsp;Liviana.
      </h1>
      <p class="mc-hero__p">
        En {mc.duracion} vas a entender por qué las dietas no funcionan, qué hay detrás de tu relación con la comida y los 3 pasos para transformarla de verdad.<br/>Sin restricciones. Sin culpa. Sin sufrir.
      </p>

      <div class="mc-hero__meta">
        <span class="mc-tag">📅 {mc.fecha}</span>
        <span class="mc-tag">💻 Zoom</span>
        <span class="mc-tag mc-tag--accent">🎁 100% gratuita</span>
      </div>
      <div class="mc-hero__meta">
        <span class="mc-tag">🕐 {mc.hora}</span>
      </div>

      <a href="#registro" class="mc-cta">QUIERO UNIRME AL GRUPO Y ASEGURAR MI LUGAR</a>

      <p class="mc-hero__foot">⚡ Los cupos son limitados. Cuando se llena, se cierra. ⚡</p>
    </div>
  </section>

  <!-- ===== MENTIRAS ===== -->
  <section class="mc-sec mc-sec--white" aria-labelledby="mc-mentiras-t">
    <div class="mc-wrap">
      <span class="mc-pill-label">En esta masterclass</span>
      <h2 id="mc-mentiras-t" class="mc-h2">¿Qué vas a descubrir?</h2>
      <p class="mc-sub">3 creencias que te mantienen atrapada en el mismo ciclo — y cómo soltarlas</p>

      <div class="mc-mentiras">
        {mentiras.map((m) => (
          <article class="mc-lie">
            <span class="mc-lie__n">{m.num}</span>
            <div>
              <h3 class="mc-lie__t">Mentira: {m.titulo}</h3>
              <p class="mc-lie__d">{m.texto}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PARA QUIEN ===== -->
  <section class="mc-sec mc-sec--warm" aria-labelledby="mc-quien-t">
    <div class="mc-wrap mc-wrap--sm">
      <span class="mc-pill-label">¿Es para vos?</span>
      <h2 id="mc-quien-t" class="mc-h2">Esta masterclass es para vos si...</h2>

      <ul class="mc-checks">
        {paraQuien.map((p) => (
          <li class="mc-chk"><span class="mc-chk__dot">✓</span><span>{p}</span></li>
        ))}
      </ul>

      <div style="text-align:center;margin-top:2.5rem;">
        <a href="#registro" class="mc-cta">Quiero mi lugar gratis</a>
      </div>
    </div>
  </section>

  <!-- ===== ANA ===== -->
  <section class="mc-sec mc-sec--white" aria-labelledby="mc-ana-t">
    <div class="mc-wrap">
      <div class="mc-ana">
        <div class="mc-ana__pic">
          <img src="/images/ana-foto.webp" alt="Ana" width="480" height="600" loading="lazy" />
        </div>
        <div class="mc-ana__txt">
          <span class="mc-pill-label">Tu guía</span>
          <h2 id="mc-ana-t" class="mc-h2">Ana</h2>
          <blockquote class="mc-ana__q">
            &ldquo;No necesitás más fuerza de voluntad. Necesitás entender por qué hacés lo que hacés.&rdquo;
          </blockquote>
          <p>Coach de bienestar y creadora del Método Livianas. Acompaña a mujeres a transformar su relación con la comida y el cuerpo desde un enfoque integral: conducta, emoción y espiritualidad.</p>
          <p>En esta masterclass gratuita va a compartir las 3 mentiras que la industria de las dietas te hizo creer — y el camino real para vivir más liviana.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIOS ===== -->
  <TestimonialsCarousel />

  <!-- ===== REGISTRO ===== -->
  <section id="registro" class="mc-sec mc-sec--warm" aria-labelledby="mc-reg-t">
    <div class="mc-wrap mc-wrap--sm">
      <span class="mc-pill-label">Cupos limitados</span>
      <h2 id="mc-reg-t" class="mc-h2">Reservá tu lugar</h2>
      <p class="mc-sub">Es 100% gratuita. Solo necesitamos tu nombre y email para enviarte el link.</p>

      <form id="mc-form" class="mc-form">
        <div class="mc-field">
          <label for="mc-nombre">Tu nombre</label>
          <input type="text" id="mc-nombre" name="nombre" required placeholder="¿Cómo te llamás?" autocomplete="given-name" />
        </div>
        <div class="mc-field">
          <label for="mc-email">Tu email</label>
          <input type="email" id="mc-email" name="email" required placeholder="tu@email.com" autocomplete="email" />
        </div>
        <button type="submit" class="mc-cta" id="mc-submit" style="width:100%;">
          <span id="mc-btn-text">RESERVAR MI LUGAR GRATIS</span>
          <span id="mc-btn-loading" style="display:none;">Registrando...</span>
        </button>
        <p class="mc-note">🔒 Tu información está segura. No compartimos tus datos.</p>
      </form>

      <div id="mc-success" class="mc-ok" style="display:none;">
        <span class="mc-ok__ico">✓</span>
        <h3>¡Listo! Tu lugar está reservado</h3>
        <p>Revisá tu email — te enviamos los detalles de acceso.</p>
      </div>
    </div>
  </section>

  <!-- ===== FINAL ===== -->
  <section class="mc-sec mc-sec--dark">
    <div class="mc-wrap mc-wrap--sm" style="text-align:center;">
      <h2 class="mc-h2" style="color:#fff;">¿Tenés dudas?</h2>
      <p style="color:rgba(255,255,255,.7);margin-bottom:2rem;">Escribile directamente a Ana por WhatsApp</p>
      <a href={waLink} target="_blank" rel="noopener" class="mc-wa">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.67-2.08-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.03-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.21 5.1 4.5.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.58-.09 1.76-.72 2.01-1.42.25-.7.25-1.3.17-1.42-.07-.13-.27-.2-.57-.35z"/><path d="M12 0C5.37 0 0 5.37 0 12c0 2.12.55 4.11 1.51 5.85L0 24l6.33-1.66C8.07 23.42 9.99 24 12 24c6.63 0 12-5.37 12-12S18.63 0 12 0zm0 22c-1.82 0-3.56-.5-5.08-1.41l-.36-.22-3.76.99 1-3.67-.24-.37A9.94 9.94 0 012 12c0-5.51 4.49-10 10-10s10 4.49 10 10-4.49 10-10 10z"/></svg>
        Hablar con Ana
      </a>
    </div>
  </section>

  <PremiumFooter />
</Layout>

<script>
  function initMC() {
    const form = document.getElementById('mc-form') as HTMLFormElement;
    const ok = document.getElementById('mc-success');
    const txt = document.getElementById('mc-btn-text');
    const load = document.getElementById('mc-btn-loading');
    const btn = document.getElementById('mc-submit') as HTMLButtonElement;
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!btn || !txt || !load || !ok) return;
      btn.disabled = true; txt.style.display = 'none'; load.style.display = 'inline';
      const fd = new FormData(form);
      try {
        const r = await fetch('/api/masterclass-registro', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nombre: fd.get('nombre'), email: fd.get('email') }),
        });
        if (r.ok) { form.style.display = 'none'; ok.style.display = 'block'; }
        else throw 0;
      } catch {
        alert('Hubo un error. Intentá de nuevo o escribile a Ana por WhatsApp.');
        btn.disabled = false; txt.style.display = 'inline'; load.style.display = 'none';
      }
    });
  }
  initMC();
  document.addEventListener('astro:after-swap', initMC);
</script>

<style>
  /* ===== TOP BAR ===== */
  .mc-bar {
    background: #B91C1C;
    color: #fff;
    text-align: center;
    font-family: var(--font-outfit);
    font-size: clamp(0.85rem, 2.2vw, 1.1rem);
    font-weight: 700;
    padding: 0.75rem 1rem;
    letter-spacing: 0.02em;
  }

  /* ===== HERO ===== */
  .mc-hero { background: #fff; }

  .mc-hero__photo-wrap {
    position: relative;
    width: 100%;
    /* Exact match to Ana's photo background — pale mint sage */
    background: linear-gradient(180deg, #C8D8C3 0%, #C2D3BC 50%, #BDCEB8 100%);
    display: flex;
    justify-content: center;
    align-items: flex-end;
    overflow: hidden;
    min-height: 55vh;
  }

  /* Watermark */
  .mc-hero__wm {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    pointer-events: none;
    z-index: 0;
  }
  .mc-hero__wm span {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: italic;
    line-height: 0.85;
    color: rgba(255, 255, 255, 0.12);
  }
  .mc-hero__wm span:first-child { font-size: clamp(5rem, 22vw, 18rem); }
  .mc-hero__wm span:last-child  { font-size: clamp(5.5rem, 24vw, 20rem); color: rgba(255,255,255,0.07); }

  /* Photo */
  .mc-hero__img {
    position: relative;
    z-index: 1;
    width: 70%;
    max-width: 440px;
    height: auto;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  @media (min-width: 768px) {
    .mc-hero__photo-wrap { min-height: 70vh; }
    .mc-hero__img { width: 40%; max-width: 480px; }
  }

  /* Badge on photo */
  .mc-hero__badge {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-family: var(--font-outfit);
    font-size: clamp(0.55rem, 1.4vw, 0.72rem);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(30, 28, 26, 0.8);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: 0.65rem 1.4rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .mc-hero__badge { white-space: normal; max-width: 88%; text-align: center; font-size: 0.6rem; }
  }

  /* Body */
  .mc-hero__body {
    padding: 2.5rem 1.5rem 3.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 640px;
    margin: 0 auto;
  }

  .mc-hero__h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.8rem, 6vw, 3.2rem);
    line-height: 1.15;
    color: #1a1614;
  }
  .mc-hero__h1 em {
    color: #5E7252;
    font-style: italic;
    text-decoration: underline;
    text-decoration-color: rgba(94, 114, 82, 0.3);
    text-underline-offset: 5px;
    text-decoration-thickness: 3px;
  }

  .mc-hero__p {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    line-height: 1.75;
    color: #4a4440;
  }

  /* Tags */
  .mc-hero__meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }
  .mc-tag {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: #3d3835;
    background: #f5f0ec;
    border: 1px solid #e6ddd5;
    border-radius: 999px;
    padding: 0.5rem 1.1rem;
  }
  .mc-tag--accent {
    background: #eef2ea;
    border-color: #c5d4b8;
    color: #4a5e40;
  }

  /* CTA */
  .mc-cta {
    display: block;
    width: 100%;
    max-width: 520px;
    font-family: var(--font-outfit);
    font-weight: 800;
    font-size: clamp(0.9rem, 2vw, 1.1rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: center;
    color: #fff;
    background: #5E7252;
    border: none;
    border-radius: 999px;
    padding: 1.15rem 2rem;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(94, 114, 82, 0.35);
    transition: all 0.25s ease;
  }
  .mc-cta:hover {
    background: #4a5e40;
    transform: translateY(-2px);
    box-shadow: 0 10px 36px rgba(94, 114, 82, 0.45);
  }
  .mc-cta:disabled { opacity: 0.6; cursor: wait; }

  .mc-hero__foot {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: #8a7e77;
    font-weight: 500;
  }

  /* ===== SECTIONS ===== */
  .mc-sec { padding: 5rem 0; }
  .mc-sec--white { background: #fff; }
  .mc-sec--warm  { background: #FAF7F4; }
  .mc-sec--dark  { background: #1a1614; padding: 4rem 0; }

  .mc-wrap { max-width: 780px; margin: 0 auto; padding: 0 1.25rem; text-align: center; }
  .mc-wrap--sm { max-width: 600px; }

  .mc-pill-label {
    display: inline-block;
    font-family: var(--font-outfit);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #5E7252;
    background: #eef2ea;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }

  .mc-h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: #1a1614;
    margin-bottom: 0.75rem;
  }

  .mc-sub {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: #7a7470;
    max-width: 480px;
    margin: 0 auto 3rem;
  }

  /* ===== MENTIRAS ===== */
  .mc-mentiras {
    max-width: 640px;
    margin: 0 auto;
    text-align: left;
  }

  .mc-lie {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.75rem 0;
    border-bottom: 1px solid #f0ebe6;
  }
  .mc-lie:last-child { border-bottom: none; }

  .mc-lie__n {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: rgba(94, 114, 82, 0.18);
    line-height: 1;
    flex-shrink: 0;
    width: 3rem;
  }

  .mc-lie__t {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: #1a1614;
    margin-bottom: 0.5rem;
    line-height: 1.35;
  }

  .mc-lie__d {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #6a6360;
  }

  /* ===== PARA QUIEN ===== */
  .mc-checks {
    list-style: none;
    padding: 0;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mc-chk {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: #3d3835;
  }

  .mc-chk__dot {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #5E7252;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 800;
    margin-top: 3px;
  }

  /* ===== ANA ===== */
  .mc-ana {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    text-align: left;
  }

  @media (min-width: 768px) {
    .mc-ana { grid-template-columns: 0.75fr 1.25fr; }
  }

  .mc-ana__pic {
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 8px 36px rgba(44, 40, 37, 0.1);
  }
  .mc-ana__pic img { width: 100%; height: auto; display: block; object-fit: cover; }

  .mc-ana__txt {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .mc-ana__txt p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #6a6360;
  }

  .mc-ana__q {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: italic;
    font-weight: 600;
    color: #1a1614;
    line-height: 1.5;
    border-left: 3px solid #7B8F6B;
    padding-left: 1.25rem;
    margin: 0.5rem 0;
  }

  /* ===== FORM ===== */
  .mc-form {
    max-width: 420px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
    text-align: left;
  }

  .mc-field { display: flex; flex-direction: column; gap: 0.35rem; }

  .mc-field label {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    color: #1a1614;
  }

  .mc-field input {
    font-family: var(--font-sans);
    font-size: 1rem;
    padding: 0.85rem 1.15rem;
    border: 1.5px solid #ddd5cc;
    border-radius: 0.65rem;
    background: #fff;
    color: #1a1614;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .mc-field input:focus { border-color: #7B8F6B; box-shadow: 0 0 0 3px rgba(123,143,107,.15); }
  .mc-field input::placeholder { color: #b5ada7; }

  .mc-note { text-align: center; font-size: 0.8rem; color: #8a7e77; }

  /* Success */
  .mc-ok { text-align: center; padding: 2rem 0; }
  .mc-ok__ico {
    display: flex; align-items: center; justify-content: center;
    width: 52px; height: 52px; border-radius: 50%;
    background: #5E7252; color: #fff; font-size: 1.4rem; font-weight: 800;
    margin: 0 auto 1rem;
  }
  .mc-ok h3 { font-family: var(--font-display); font-weight: 700; font-size: 1.5rem; color: #1a1614; margin-bottom: 0.5rem; }
  .mc-ok p { font-size: 1rem; color: #7a7470; }

  /* WhatsApp */
  .mc-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-outfit);
    font-weight: 700;
    font-size: 1rem;
