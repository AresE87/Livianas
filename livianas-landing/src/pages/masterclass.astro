---
// src/pages/masterclass.astro — EFECTO LIVIANA masterclass landing page
import '../styles/global.css';
import { siteConfig } from '../lib/config';

const metaPixelId = siteConfig.metaPixelId;
const ga4Id = siteConfig.ga4Id;
const whatsappGroupLink = 'https://chat.whatsapp.com/Go2uknvqcGb2e5nmlzdYcd';
const whatsappAnaLink = `https://wa.me/59891086674?text=${encodeURIComponent('Hola Ana, quiero info sobre la masterclass EFECTO LIVIANA 🌿')}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EFECTO LIVIANA — Masterclass Gratuita | LIVIANAS</title>
    <meta name="description" content="Cómo pasar de estar cansada y pesada a sentirte liviana en 30 días. Masterclass gratuita con Ana — Sábado 28 de marzo, 11 hs (Uruguay) por Zoom." />
    <link rel="canonical" href="https://livianas.com/masterclass" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://livianas.com/masterclass" />
    <meta property="og:title" content="EFECTO LIVIANA — Masterclass Gratuita" />
    <meta property="og:description" content="Cómo pasar de estar cansada y pesada a sentirte liviana en 30 días. Evento gratuito por Zoom." />
    <meta property="og:locale" content="es_UY" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,700;1,400;1,700&family=Outfit:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    {metaPixelId && (
      <script set:html={`
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '${metaPixelId}');
        fbq('track', 'PageView');
      `} />
      <noscript>
        <img height="1" width="1" style="display:none" src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`} />
      </noscript>
    )}

    {ga4Id && (
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
    )}
    {ga4Id && (
      <script set:html={`
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '${ga4Id}');
      `} />
    )}
  </head>

  <body>

    <!-- ═══ TOP BAR ═══ -->
    <div class="topbar">
      <p>✨ EVENTO GRATUITO &mdash; Sábado 28 de marzo &mdash; 11 hs Uruguay &mdash; Cupos limitados</p>
    </div>

    <!-- ═══ HERO ═══ -->
    <section class="hero">
      <div class="hero__bg-elements">
        <div class="hero__orb hero__orb--1"></div>
        <div class="hero__orb hero__orb--2"></div>
        <div class="hero__orb hero__orb--3"></div>
      </div>
      <div class="hero__inner">
        <div class="hero__photo-col">
          <div class="hero__photo-frame">
            <img src="/images/ana-foto.webp" alt="Ana, creadora del Método Livianas" class="hero__photo" width="380" height="460" loading="eager" />
          </div>
        </div>
        <div class="hero__content">
          <p class="hero__eyebrow">EXPERIENCIA INTEGRAL CON ENERGÍA</p>
          <h1 class="hero__title">EFECTO<br/><span class="hero__title-accent">LIVIANA</span></h1>
          <p class="hero__subtitle">Cómo pasar de estar cansada y pesada a sentirte <strong>liviana</strong> en 30 días.</p>
          <div class="hero__badges">
            <span class="badge"><span class="badge__icon">📅</span> Sáb 28 de marzo</span>
            <span class="badge"><span class="badge__icon">🕐</span> 11 hs (Uruguay)</span>
            <span class="badge"><span class="badge__icon">🎁</span> 100% Gratuita</span>
          </div>
          <a href="#inscripcion" class="hero__cta">
            INSCRÍBETE AHORA
            <svg class="hero__cta-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <p class="hero__limited">Cupos limitados. Transformación integral.</p>
        </div>
      </div>
    </section>

    <!-- ═══ 3 PILARES ═══ -->
    <section class="pillars" id="descubrir">
      <div class="section-inner">
        <p class="section-label">Qué vas a descubrir</p>
        <h2 class="section-title">En esta masterclass vas a entender...</h2>

        <div class="pillars__grid">
          <!-- Pilar 1: El Problema -->
          <div class="pillar-card pillar-card--problem">
            <div class="pillar-card__number">01</div>
            <div class="pillar-card__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><circle cx="12" cy="16" r="0.5" fill="currentColor"/></svg>
            </div>
            <h3 class="pillar-card__title">El Problema</h3>
            <ul class="pillar-card__list">
              <li>Te sentís cansada y pesada todo el tiempo</li>
              <li>Sin tiempo ni organización para cuidarte</li>
              <li>No entendés por qué aumentás de peso</li>
            </ul>
          </div>

          <!-- Pilar 2: La Solución -->
          <div class="pillar-card pillar-card--solution">
            <div class="pillar-card__number">02</div>
            <div class="pillar-card__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 4 12.73V17a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1v-2.27A7 7 0 0 1 12 2z"/><line x1="9" y1="21" x2="15" y2="21"/></svg>
            </div>
            <h3 class="pillar-card__title">El Enfoque</h3>
            <ul class="pillar-card__list">
              <li>Revisar emociones y traumas del pasado que te llevaron a estar así</li>
              <li>Cambiar la perspectiva desde adentro</li>
              <li>Planificación de menú simple y sostenible</li>
            </ul>
          </div>

          <!-- Pilar 3: El Resultado -->
          <div class="pillar-card pillar-card--result">
            <div class="pillar-card__number">03</div>
            <div class="pillar-card__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="pillar-card__title">El Resultado</h3>
            <ul class="pillar-card__list">
              <li>Bajar de peso como consecuencia natural</li>
              <li>Más organizada con mejor rendimiento de tu tiempo</li>
              <li>Sentirte más liviana por dentro y por fuera</li>
            </ul>
          </div>
        </div>

        <div class="text-center mt-10">
          <a href="#inscripcion" class="cta-secondary">QUIERO MI LUGAR</a>
        </div>
      </div>
    </section>

    <!-- ═══ ES PARA VOS SI... ═══ -->
    <section class="for-you">
      <div class="section-inner">
        <p class="section-label">¿Es para vos?</p>
        <h2 class="section-title">Esta masterclass es para vos si...</h2>

        <div class="for-you__grid">
          <div class="for-you__item">
            <span class="for-you__check">✓</span>
            <p>Te sentís cansada y pesada, y no sabés por dónde empezar</p>
          </div>
          <div class="for-you__item">
            <span class="for-you__check">✓</span>
            <p>Probaste muchas dietas pero siempre volvés al punto de partida</p>
          </div>
          <div class="for-you__item">
            <span class="for-you__check">✓</span>
            <p>No tenés tiempo para organizarte con la comida</p>
          </div>
          <div class="for-you__item">
            <span class="for-you__check">✓</span>
            <p>Sabés que el peso no es solo un tema de alimentación</p>
          </div>
          <div class="for-you__item">
            <span class="for-you__check">✓</span>
            <p>Querés entender qué emociones hay detrás de tus hábitos</p>
          </div>
          <div class="for-you__item">
            <span class="for-you__check">✓</span>
            <p>Buscás un cambio real y profundo, no otra dieta más</p>
          </div>
        </div>

        <div class="text-center mt-8">
          <a href="#inscripcion" class="cta-secondary">Quiero mi lugar gratis</a>
        </div>
      </div>
    </section>

    <!-- ═══ SOBRE ANA ═══ -->
    <section class="about-ana">
      <div class="section-inner about-ana__inner">
        <div class="about-ana__photo-wrap">
          <img src="/images/ana-foto.webp" alt="Ana" class="about-ana__photo" width="160" height="160" loading="lazy" />
        </div>
        <div class="about-ana__content">
          <p class="section-label" style="text-align:left;">Tu guía</p>
          <h2 class="section-title" style="text-align:left;">Ana</h2>
          <p class="about-ana__bio">
            Coach de bienestar integral y creadora del <strong>Método Livianas</strong>. Acompaña a mujeres a transformar su relación con la comida, su cuerpo y sus emociones — trabajando desde las emociones y traumas del pasado para lograr resultados reales y duraderos.
          </p>
          <p class="about-ana__bio">
            En esta masterclass gratuita va a compartir su enfoque que combina <strong>nutrición consciente, trabajo emocional y planificación práctica</strong> para que puedas sentirte liviana en 30 días.
          </p>
          <a href="https://instagram.com/anabienestarintegral" target="_blank" rel="noopener" class="about-ana__ig">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            @anabienestarintegral
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ TESTIMONIOS ═══ -->
    <section class="testimonials">
      <div class="section-inner">
        <p class="section-label">Transformaciones reales</p>
        <h2 class="section-title">Ellas ya lo lograron</h2>
        <p class="section-subtitle">Historias de mujeres que cambiaron su relación con la comida y su cuerpo</p>

        <div class="testimonials__carousel" id="carousel">
          <div class="testimonial-card" data-index="0">
            <img src="/images/testimonios/cecilia.webp" alt="Transformación de Cecilia" class="testimonial-card__img" loading="lazy" />
            <h3 class="testimonial-card__name">Cecilia</h3>
            <p class="testimonial-card__text">Llegó sin mucha expectativa y se sorprendió muchísimo durante el proceso. Poco a poco cambió su alimentación sin privarse de nada. Su trabajo requiere estar muchas horas sentada y aún así lo logró más rápido de lo que pensaba.</p>
          </div>
          <div class="testimonial-card" data-index="1">
            <img src="/images/testimonios/veronica.webp" alt="Transformación de Verónica" class="testimonial-card__img" loading="lazy" />
            <h3 class="testimonial-card__name">Verónica</h3>
            <p class="testimonial-card__text">Cuando comenzó vivía con mucho estrés y ansiedad. No creía que podía bajar de peso comiendo, sin sufrir. Trabaja con alimentos y están presentes los dulces siempre. Cambió 100% su mentalidad y su forma de ver la comida.</p>
          </div>
          <div class="testimonial-card" data-index="2">
            <img src="/images/testimonios/camila.webp" alt="Transformación de Camila" class="testimonial-card__img" loading="lazy" />
            <h3 class="testimonial-card__name">Camila</h3>
            <p class="testimonial-card__text">Desde el primer día tuvo absoluta confianza en el proceso. Tiene hijos pequeños, sin embargo logró vivir más liviana todos los días haciendo cambios en sus hábitos. La confianza en el proceso es un gran pilar.</p>
          </div>
          <div class="testimonial-card" data-index="3">
            <img src="/images/testimonios/viviana.webp" alt="Transformación de Viviana" class="testimonial-card__img" loading="lazy" />
            <h3 class="testimonial-card__name">Viviana</h3>
            <p class="testimonial-card__text">Cuando comenzó estaba muy estructurada y rígida. Se preocupaba mucho por las cantidades, las marcas, los alimentos light. Trabajamos la flexibilidad y estar abierta a cambiar conceptos en la alimentación para vivir más liviana.</p>
          </div>
        </div>

        <div class="testimonials__nav">
          <button class="carousel-btn" id="prev-btn" aria-label="Testimonio anterior">❮</button>
          <div class="carousel-dots" id="carousel-dots"></div>
          <button class="carousel-btn" id="next-btn" aria-label="Siguiente testimonio">❯</button>
        </div>
      </div>
    </section>

    <!-- ═══ INSCRIPCIÓN — GRUPO DE WHATSAPP ═══ -->
