---
import { weeksData, transformationData } from '../lib/config';
---

<section id="features" class="section features-section">
  <div class="container">

    <!-- Section Header -->
    <header class="features-header" data-gsap="features-header">
      <h2 class="features-title">
        <span class="features-title__serif">Tres dimensiones.</span>
        <span class="features-title__sans">Un solo proceso.</span>
      </h2>
      <p class="features-subtitle">
        Cada semana abre una nueva capa de transformaci&oacute;n: lo que com&eacute;s, lo que sent&iacute;s y lo que cre&eacute;s sobre vos misma.
      </p>
    </header>

    <!-- Weeks Cards Grid -->
    <div class="weeks-grid" data-gsap="features-weeks">
      {weeksData.map((week) => (
        <article class="feature-panel week-card" data-gsap="feature-panel" style={`--card-gradient: ${week.gradient};`}>
          <div class="week-card__badge">
            <span class="week-card__badge-text">Semana {week.number}</span>
          </div>
          <div class="week-card__icon" aria-hidden="true">
            {week.number === 1 && (
              <!-- Seedling / Eye opening -->
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="24" cy="14" r="6" />
                <circle cx="24" cy="14" r="2" />
                <path d="M24 20v18" />
                <path d="M18 32c0-4 2.7-7 6-7s6 3 6 7" />
              </svg>
            )}
            {week.number === 2 && (
              <!-- Flame / Transformation -->
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M24 6c-2 8-10 14-10 22a10 10 0 0020 0C34 20 26 14 24 6z" />
                <path d="M24 44c-3 0-5-2.5-5-6 0-5 5-9 5-9s5 4 5 9c0 3.5-2 6-5 6z" />
              </svg>
            )}
            {week.number === 3 && (
              <!-- Hands holding heart / Connection -->
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M24 38s-14-8.5-14-18c0-5.5 4-9 8-9 2.5 0 4.5 1 6 3.5 1.5-2.5 3.5-3.5 6-3.5 4 0 8 3.5 8 9 0 9.5-14 18-14 18z" />
              </svg>
            )}
            {week.number === 4 && (
              <!-- Diamond / Radiant self -->
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M24 6l-12 12 12 22 12-22L24 6z" />
                <path d="M12 18h24" />
                <path d="M18 6l-6 12" />
                <path d="M30 6l6 12" />
                <path d="M24 18l-6-12" />
                <path d="M24 18l6-12" />
              </svg>
            )}
          </div>
          <h3 class="week-card__title">{week.title}</h3>
          <span class="week-card__name">{week.name}</span>
          <p class="week-card__description">{week.description}</p>
        </article>
      ))}
    </div>

    <!-- Transformation: Before → After -->
    <div class="transformation" data-gsap="features-transformation">
      <div class="transformation__header">
        <h3 class="transformation__title">
          <span class="transformation__title-serif">De donde est&aacute;s</span>
          <span class="transformation__title-sans">a donde quer&eacute;s llegar</span>
        </h3>
      </div>

      <div class="transformation__list">
        {transformationData.map((item) => (
          <div class="transformation__row feature-panel">
            <div class="transformation__from">
              <span class="transformation__label transformation__label--from">Antes</span>
              <p class="transformation__text transformation__text--from">{item.from}</p>
            </div>
            <div class="transformation__divider">
              <svg class="transformation__arrow" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div class="transformation__elegant-arrow" aria-hidden="true">
                <span class="transformation__line"></span>
                <svg viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m1 1 5 5 5-5" />
                </svg>
              </div>
            </div>
            <div class="transformation__to">
              <span class="transformation__label transformation__label--to">Despu&eacute;s</span>
              <p class="transformation__text transformation__text--to">{item.to}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  /* ============================
     Section & Header
     ============================ */
  .features-section {
    background: var(--color-cream);
    position: relative;
  }

  .features-header {
    text-align: center;
    margin-bottom: var(--space-16);
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .features-title {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .features-title__serif {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-sage);
    line-height: 1.15;
  }

  .features-title__sans {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: var(--color-carbon);
    line-height: 1.2;
  }

  .features-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* ============================
     Weeks Card Grid
     ============================ */
  .weeks-grid {
    display: grid;
    gap: var(--space-6);
    margin-bottom: var(--space-20);
  }

  @media (min-width: 768px) {
    .weeks-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  /* ============================
     Individual Week Card
     ============================ */
  .week-card {
    background: var(--card-gradient, var(--color-cream-warm));
    border-radius: var(--radius-3xl);
    padding: var(--space-8) var(--space-6);
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-3);
    border: 1px solid rgba(123, 143, 107, 0.08);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .week-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .week-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(8px);
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-2);
  }

  .week-card__badge-text {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-sage-dark);
  }

  .week-card__icon {
    width: 48px;
    height: 48px;
    color: var(--color-sage);
  }

  .week-card__icon svg {
    width: 100%;
    height: 100%;
  }

  .week-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-sage-dark);
  }

  .week-card__name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-style: italic;
    font-weight: 400;
    color: var(--color-carbon);
    line-height: 1.2;
  }

  .week-card__description {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    max-width: 320px;
  }

  /* ============================
     Transformation Section
     ============================ */
  .transformation {
    max-width: 800px;
    margin: 0 auto;
  }

  .transformation__header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .transformation__title {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .transformation__title-serif {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-blush);
    line-height: 1.2;
  }

  .transformation__title-sans {
    font-family: var(--font-sans);
    font-size: clamp(1.2rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: var(--color-carbon);
    line-height: 1.3;
  }

  /* ============================
     Transformation Rows
     ============================ */
  .transformation__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .transformation__row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    background: var(--color-white);
    border-radius: var(--radius-2xl);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-base);
  }

  .transformation__row:hover {
    box-shadow: var(--shadow-md);
  }

  .transformation__from,
  .transformation__to {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .transformation__label {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    width: max-content;
  }

  .transformation__label--from {
    background: var(--color-sand);
    color: var(--color-text-muted);
  }

  .transformation__label--to {
    background: var(--color-sage-wash);
    color: var(--color-sage-dark);
  }

  .transformation__text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .transformation__text--from {
    color: var(--color-text-muted);
    text-decoration: line-through;
    text-decoration-color: var(--color-sand);
    text-decoration-thickness: 1.5px;
  }

  .transformation__text--to {
    color: var(--color-sage-dark);
    font-weight: 600;
  }

  /* Divider */
  .transformation__divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    flex-shrink: 0;
  }

  .transformation__arrow {
    width: 20px;
    height: 20px;
    color: var(--color-blush);
    display: none;
  }

  .transformation__elegant-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .transformation__elegant-arrow .transformation__line {
    width: 1px;
    height: 12px;
    background: var(--color-sage);
    opacity: 0.35;
  }

  .transformation__elegant-arrow svg {
    width: 10px;
    height: 7px;
    color: var(--color-sage);
    opacity: 0.4;
  }

  @media (min-width: 768px) {
    .transformation__arrow {
      display: block;
    }

    .transformation__elegant-arrow {
      display: none;
    }
  }

  /* ============================
     Responsive: Mobile Stacking
     ============================ */
  @media (max-width: 767px) {
    .weeks-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: var(--space-16);
    }

    .transformation__row {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-3);
      padding: var(--space-5);
    }

    .transformation__from,
    .transformation__to {
      align-items: center;
    }

    .transformation__divider {
      padding: var(--space-1) 0;
    }

    .transformation__label {
      margin: 0 auto;
    }
  }

  /* ============================
     Responsive: Tablet+
     ============================ */
  @media (min-width: 768px) {
    .transformation__row {
      gap: var(--space-6);
      padding: var(--space-6) var(--space-8);
    }

    .transformation__text {
      font-size: var(--text-base);
    }
  }

  /* ============================
     Responsive: Desktop (4-col option)
     ============================ */
  @media (min-width: 1024px) {
    .weeks-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-6);
    }

    .week-card {
      padding: var(--space-8) var(--space-5);
    }

    .week-card__description {
      font-size: 0.8rem;
    }
  }
</style>
