---
import { siteConfig, getWhatsAppLink } from '../lib/config';

const whatsappLink = getWhatsAppLink('floating');
const year = new Date().getFullYear();
---

<footer role="contentinfo" class="premium-footer" data-gsap="footer">
  <div class="container">
    <!-- Top row: Logo + Status -->
    <div class="footer-top">
      <a href="#" class="footer-logo" aria-label="LIVIANAS - Volver al inicio">
        <span class="footer-logo__text">LIVIANAS</span>
      </a>

      {siteConfig.inscripcionesAbiertas && (
        <div class="footer-status">
          <span class="footer-status__dot" aria-hidden="true"></span>
          <span class="footer-status__text">Inscripciones abiertas</span>
        </div>
      )}
    </div>

    <!-- Divider -->
    <div class="footer-divider" aria-hidden="true"></div>

    <!-- Three columns -->
    <nav class="footer-nav" aria-label="Footer">
      <div class="footer-nav__col">
        <h3 class="footer-nav__title">Programa</h3>
        <ul class="footer-nav__list">
          <li><a href="#features">El Metodo</a></li>
          <li><a href="#programa">Las 4 Semanas</a></li>
          <li><a href="#archivo">Que incluye</a></li>
          <li><a href="#precio">Precio</a></li>
        </ul>
      </div>

      <div class="footer-nav__col">
        <h3 class="footer-nav__title">Soporte</h3>
        <ul class="footer-nav__list">
          <li><a href="#faq">Preguntas frecuentes</a></li>
          <li>
            <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="footer-whatsapp-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Hablar por WhatsApp
            </a>
          </li>
        </ul>
      </div>

      <div class="footer-nav__col">
        <h3 class="footer-nav__title">Legal</h3>
        <ul class="footer-nav__list">
          <li><a href="/terminos">Terminos y condiciones</a></li>
          <li><a href="/privacidad">Politica de privacidad</a></li>
        </ul>
      </div>
    </nav>

    <!-- Divider -->
    <div class="footer-divider" aria-hidden="true"></div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-bottom__copy">
        &copy; {year} LIVIANAS — Todos los derechos reservados
      </p>
      <p class="footer-bottom__tagline">
        Hecho con cuidado para mujeres que eligen transformarse.
      </p>
    </div>
  </div>
</footer>

<style>
  /* --- Footer --- */
  .premium-footer {
    background: var(--color-carbon);
    border-radius: var(--radius-3xl) var(--radius-3xl) 0 0;
    padding: var(--space-12) 0 var(--space-8);
    margin-top: -1px;
  }

  @media (min-width: 768px) {
    .premium-footer {
      padding: var(--space-16) 0 var(--space-10);
    }
  }

  /* --- Top row --- */
  .footer-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  /* Logo */
  .footer-logo {
    text-decoration: none;
  }

  .footer-logo__text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: var(--text-3xl);
    color: white;
    letter-spacing: 0.04em;
  }

  @media (min-width: 768px) {
    .footer-logo__text {
      font-size: var(--text-4xl);
    }
  }

  /* Status indicator */
  .footer-status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.05);
  }

  .footer-status__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ADE80;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .footer-status__text {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* --- Divider --- */
  .footer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin-bottom: var(--space-8);
  }

  /* --- Navigation columns --- */
  .footer-nav {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 480px) {
    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .footer-nav {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-12);
    }
  }

  .footer-nav__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.9);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-4);
  }

  .footer-nav__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-nav__list a {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer-nav__list a:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  .footer-whatsapp-link svg {
    opacity: 0.7;
    transition: opacity var(--transition-fast);
  }

  .footer-whatsapp-link:hover svg {
    opacity: 1;
  }

  /* --- Bottom bar --- */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer-bottom__copy {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.3);
  }

  .footer-bottom__tagline {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.2);
    font-style: italic;
  }
</style>
