---
import CountdownTimer from './CountdownTimer.astro';
import PaymentButtons from './PaymentButtons.astro';
import { siteConfig, pricingFeatures, getPaymentLink, getWhatsAppLink } from '../lib/config';
---

<section id="precio" aria-labelledby="precio-title" class="premium-pricing section">
  <div class="container">
    <!-- Section Header -->
    <div class="pricing-header" data-gsap="pricing-header">
      <h2 id="precio-title" class="pricing-title">
        <span class="pricing-title-serif">Tu inversi&oacute;n</span>
        <span class="pricing-title-sans">en vos misma.</span>
      </h2>
    </div>

    <!-- Countdown -->
    <div class="pricing-countdown" data-gsap="pricing-countdown">
      <p class="pricing-countdown-label">El c&iacute;rculo cierra en:</p>
      <CountdownTimer variant="section" />
    </div>

    <!-- Premium Card -->
    <div class="pricing-card" data-gsap="pricing-card">
      <!-- Badge -->
      <div class="pricing-badge-wrap">
        <span class="pricing-badge">
          Precio de lanzamiento
        </span>
      </div>

      <!-- Program name -->
      <p class="pricing-program-name">
        LIVIANAS &mdash; Experiencia 30 D&iacute;as
      </p>

      <!-- Prices -->
      <div class="pricing-prices">
        <span class="pricing-old-price">
          USD {siteConfig.valorTotal}
        </span>
        <div class="pricing-main-price">
          <span class="pricing-currency">USD</span>
          <span class="pricing-amount">{siteConfig.precioUSD}</span>
        </div>
        <p class="pricing-weekly">
          Solo USD {siteConfig.precioSemanal} por semana
        </p>
        <p class="pricing-installments">
          Cuotas disponibles con tarjeta de cr&eacute;dito
        </p>
      </div>

      <!-- Divider -->
      <div class="pricing-divider"></div>

      <!-- Value stack -->
      <ul class="pricing-features" role="list">
        {pricingFeatures.map((feature) => (
          <li class="pricing-feature-item">
            <span class="pricing-check">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </span>
            <span>{feature}</span>
          </li>
        ))}
      </ul>

      <!-- CTAs -->
      <div class="pricing-ctas">
        <a
          href={getPaymentLink()}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--clay"
          data-utm="pricing-primary"
        >
          {siteConfig.ctaMessages.primary}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a
          href={getWhatsAppLink('pricing')}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--ghost-card"
          data-utm="pricing-secondary"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          {siteConfig.ctaMessages.secondary}
        </a>
      </div>

      <!-- Payment Buttons -->
      <div class="pricing-payment-buttons">
        <PaymentButtons variant="compact" />
      </div>

      <!-- Guarantee -->
      <div class="pricing-guarantee">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="pricing-guarantee-icon">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <p class="pricing-guarantee-text">
          <strong>Garant&iacute;a:</strong> Si despu&eacute;s de la semana 1 sent&iacute;s que no es para vos, hablamos.
        </p>
      </div>
    </div>

    <!-- Below-card note -->
    <p class="pricing-below-note" data-gsap="pricing-note">
      Son solo USD {siteConfig.precioSemanal} por semana de coaching grupal, acompa&ntilde;amiento diario, plan de alimentaci&oacute;n y material de por vida.
    </p>

    <!-- Trust badges -->
    <div class="pricing-trust" data-gsap="pricing-trust">
      <span class="pricing-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Pago seguro
      </span>
      <span class="pricing-trust-dot">&bull;</span>
      <span class="pricing-trust-item">Mercado Pago</span>
      <span class="pricing-trust-dot">&bull;</span>
      <span class="pricing-trust-item">PayPal</span>
    </div>
  </div>
</section>

<style>
  .premium-pricing {
    background: var(--color-cream);
  }

  /* --- Header --- */
  .pricing-header {
    text-align: center;
    margin-bottom: var(--space-6);
  }

  .pricing-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .pricing-title-serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: var(--text-4xl);
    color: var(--color-carbon);
    line-height: 1.15;
  }

  .pricing-title-sans {
    font-family: var(--font-outfit);
    font-weight: 700;
    font-size: var(--text-3xl);
    color: var(--color-sage);
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .pricing-title-serif {
      font-size: var(--text-5xl);
    }
    .pricing-title-sans {
      font-size: var(--text-4xl);
    }
    .pricing-title {
      flex-direction: row;
      gap: var(--space-3);
    }
  }

  /* --- Countdown --- */
  .pricing-countdown {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .pricing-countdown-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  /* --- Card --- */
  .pricing-card {
    max-width: 580px;
    margin: 0 auto;
    background: var(--color-sage);
    border-radius: var(--radius-3xl);
    padding: var(--space-8) var(--space-6);
    color: white;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  @media (min-width: 768px) {
    .pricing-card {
      padding: var(--space-12) var(--space-10);
    }
  }

  /* Subtle grain inside card */
  .pricing-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 0%, rgba(255,255,255,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  /* --- Badge --- */
  .pricing-badge-wrap {
    text-align: center;
    margin-bottom: var(--space-4);
    position: relative;
  }

  .pricing-badge {
    display: inline-block;
    background: var(--color-blush);
    color: white;
    font-family: var(--font-outfit);
    font-weight: 700;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
  }

  /* --- Program name --- */
  .pricing-program-name {
    text-align: center;
    font-family: var(--font-outfit);
    font-weight: 600;
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-6);
    position: relative;
  }

  /* --- Prices --- */
  .pricing-prices {
    text-align: center;
    margin-bottom: var(--space-6);
    position: relative;
  }

  .pricing-old-price {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-blush-light);
    text-decoration: line-through;
    text-decoration-thickness: 2px;
    display: block;
    margin-bottom: var(--space-1);
  }

  .pricing-main-price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .pricing-currency {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
  }

  .pricing-amount {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-7xl);
    color: white;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .pricing-amount {
      font-size: var(--text-8xl);
    }
  }

  .pricing-weekly {
    font-family: var(--font-outfit);
    font-weight: 600;
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--space-1);
  }

  .pricing-installments {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.55);
  }

  /* --- Divider --- */
  .pricing-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.15);
    margin: var(--space-6) 0;
    position: relative;
  }

  /* --- Features --- */
  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    position: relative;
  }

  .pricing-feature-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.5;
  }

  @media (min-width: 768px) {
    .pricing-feature-item {
      font-size: var(--text-base);
    }
  }

  .pricing-check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-sm);
    margin-top: 1px;
  }

  /* --- CTAs --- */
  .pricing-ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    position: relative;
  }

  .btn--clay {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    background: var(--color-blush);
    color: white;
    font-family: var(--font-outfit);
    font-weight: 700;
    font-size: var(--text-lg);
    padding: var(--space-4) var(--space-8);
    border-radius: var(--radius-full);
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all var(--transition-base);
    box-shadow: 0 4px 20px rgba(212, 145, 126, 0.4);
    position: relative;
    overflow: hidden;
  }

  .btn--clay::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transition: left var(--transition-slow);
  }

  .btn--clay:hover::before {
    left: 100%;
  }

  .btn--clay:hover {
    background: var(--color-blush-light);
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 6px 30px rgba(212, 145, 126, 0.5);
  }

  .btn--clay:active {
    transform: translateY(0) scale(0.98);
  }

  .btn--ghost-card {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--font-outfit);
    font-weight: 600;
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-full);
    border: 1.5px solid rgba(255, 255, 255, 0.18);
    cursor: pointer;
    text-decoration: none;
    transition: all var(--transition-base);
    backdrop-filter: blur(8px);
  }

  .btn--ghost-card:hover {
    background: rgba(255, 255, 255, 0.18);
    color: white;
    transform: translateY(-1px);
  }

  /* --- Payment Buttons --- */
  .pricing-payment-buttons {
    margin-bottom: var(--space-5);
    position: relative;
  }

  /* --- Guarantee --- */
  .pricing-guarantee {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    background: rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    position: relative;
  }

  .pricing-guarantee-icon {
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 1px;
  }

  .pricing-guarantee-text {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.5;
  }

  .pricing-guarantee-text strong {
    color: white;
  }

  /* --- Below card --- */
  .pricing-below-note {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    max-width: 440px;
    margin: var(--space-8) auto 0;
    text-wrap: balance;
  }

  /* --- Trust badges --- */
  .pricing-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-5);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .pricing-trust-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  .pricing-trust-dot {
    opacity: 0.4;
  }
</style>
