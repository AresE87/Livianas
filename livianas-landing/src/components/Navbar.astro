---
import { siteConfig, getPaymentLink } from '../lib/config';

const paymentHref = getPaymentLink();
const fechaCierre = siteConfig.fechaCierre;
---

<nav
  id="navbar"
  class="navbar"
  aria-label="Navegacion principal"
>
  <div class="navbar__inner">
    <!-- Logo -->
    <a href="#" class="navbar__logo" aria-label="LIVIANAS - Inicio">
      LIVIANAS
    </a>

    <!-- Desktop nav links -->
    <div class="navbar__links" role="navigation">
      <a href="#metodo" class="navbar__link">El Metodo</a>
      <a href="#programa" class="navbar__link">Programa</a>
      <a href="#precio" class="navbar__link">Precio</a>
      <span class="navbar__divider" aria-hidden="true"></span>
      <span class="navbar__countdown">
        <span class="navbar__countdown-dot" aria-hidden="true"></span>
        Cierra el {fechaCierre}
      </span>
    </div>

    <!-- CTA button -->
    <a
      href={paymentHref}
      class="navbar__cta"
      data-utm="navbar"
    >
      {siteConfig.ctaMessages.primary}
    </a>

    <!-- Mobile hamburger -->
    <button
      class="navbar__hamburger"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
    >
      <span class="navbar__hamburger-line" aria-hidden="true"></span>
      <span class="navbar__hamburger-line" aria-hidden="true"></span>
      <span class="navbar__hamburger-line" aria-hidden="true"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="navbar__mobile" aria-hidden="true">
    <a href="#metodo" class="navbar__mobile-link">El Metodo</a>
    <a href="#programa" class="navbar__mobile-link">Programa</a>
    <a href="#precio" class="navbar__mobile-link">Precio</a>
    <div class="navbar__mobile-divider"></div>
    <span class="navbar__mobile-countdown">
      <span class="navbar__countdown-dot" aria-hidden="true"></span>
      Cierra el {fechaCierre}
    </span>
    <a
      href={paymentHref}
      class="navbar__mobile-cta btn btn--primary"
      data-utm="navbar-mobile"
    >
      {siteConfig.ctaMessages.primary}
    </a>
  </div>
</nav>

<script>
  // --- State machine for navbar transitions ---
  const navbar = document.getElementById('navbar') as HTMLElement;
  const hamburger = navbar?.querySelector('.navbar__hamburger') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
  const heroSection = document.getElementById('hero');

  if (navbar && heroSection) {
    // IntersectionObserver: when hero leaves viewport, switch to scrolled state
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          navbar.classList.remove('navbar--scrolled');
        } else {
          navbar.classList.add('navbar--scrolled');
        }
      },
      {
        root: null,
        threshold: 0,
        rootMargin: '-80px 0px 0px 0px',
      }
    );
    observer.observe(heroSection);
  }

  // Mobile menu toggle
  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
      hamburger.setAttribute('aria-expanded', String(!isOpen));
      mobileMenu.setAttribute('aria-hidden', String(isOpen));
      navbar?.classList.toggle('navbar--mobile-open', !isOpen);

      // Toggle hamburger animation
      hamburger.classList.toggle('is-active', !isOpen);
    });

    // Close mobile menu on link click
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        hamburger.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
        navbar?.classList.remove('navbar--mobile-open');
        hamburger.classList.remove('is-active');
      });
    });
  }
</script>

<style>
  /* ==========================================
     NAVBAR — Floating pill with state transitions
     ========================================== */

  .navbar {
    position: fixed;
    top: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    width: calc(100% - var(--space-8));
    max-width: 960px;
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-3);
    transition:
      background var(--transition-slow),
      border-color var(--transition-slow),
      box-shadow var(--transition-slow),
      padding var(--transition-slow);

    /* Default state: transparent over hero */
    background: rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Scrolled state: glass white pill */
  .navbar--scrolled {
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(46, 64, 54, 0.1);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.06),
      0 1px 3px rgba(0, 0, 0, 0.04);
  }

  /* --- Inner container --- */
  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    min-height: 44px;
  }

  /* --- Logo --- */
  .navbar__logo {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.95);
    text-decoration: none;
    transition: color var(--transition-slow);
    flex-shrink: 0;
    padding-left: var(--space-3);
  }

  .navbar--scrolled .navbar__logo {
    color: var(--color-moss);
  }

  /* --- Desktop links --- */
  .navbar__links {
    display: none;
    align-items: center;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .navbar__links {
      display: flex;
    }
  }

  .navbar__link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color var(--transition-base);
    white-space: nowrap;
    position: relative;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: currentColor;
    transition: width var(--transition-base);
  }

  .navbar__link:hover::after {
    width: 100%;
  }

  .navbar__link:hover {
    color: rgba(255, 255, 255, 1);
  }

  .navbar--scrolled .navbar__link {
    color: var(--color-text-muted);
  }

  .navbar--scrolled .navbar__link:hover {
    color: var(--color-moss);
  }

  /* --- Divider --- */
  .navbar__divider {
    width: 1px;
    height: 16px;
    background: rgba(255, 255, 255, 0.2);
    transition: background var(--transition-slow);
  }

  .navbar--scrolled .navbar__divider {
    background: var(--color-border);
  }

  /* --- Countdown pill --- */
  .navbar__countdown {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    white-space: nowrap;
    letter-spacing: 0.02em;
    transition: color var(--transition-slow);
  }

  .navbar--scrolled .navbar__countdown {
    color: var(--color-text-muted);
  }

  .navbar__countdown-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-clay);
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* --- CTA button --- */
  .navbar__cta {
    display: none;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    text-decoration: none;
    white-space: nowrap;
    transition:
      background var(--transition-base),
      color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
    flex-shrink: 0;

    /* Default state: semi-transparent white on dark bg */
    background: rgba(255, 255, 255, 0.15);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .navbar__cta:hover {
    transform: translateY(-1px);
    background: rgba(255, 255, 255, 0.25);
  }

  .navbar--scrolled .navbar__cta {
    background: var(--color-clay);
    color: white;
    border-color: var(--color-clay);
    box-shadow: 0 2px 12px rgba(204, 88, 51, 0.25);
  }

  .navbar--scrolled .navbar__cta:hover {
    background: var(--color-clay-light);
    box-shadow: 0 4px 20px rgba(204, 88, 51, 0.35);
    transform: translateY(-1px);
  }

  @media (min-width: 768px) {
    .navbar__cta {
      display: inline-flex;
    }
  }

  /* --- Hamburger --- */
  .navbar__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    transition: background var(--transition-base);
  }

  .navbar__hamburger:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .navbar--scrolled .navbar__hamburger:hover {
    background: rgba(46, 64, 54, 0.06);
  }

  @media (min-width: 768px) {
    .navbar__hamburger {
      display: none;
    }
  }

  .navbar__hamburger-line {
    width: 20px;
    height: 1.5px;
    border-radius: 1px;
    background: rgba(255, 255, 255, 0.9);
    transition:
      transform var(--transition-base),
      opacity var(--transition-base),
      background var(--transition-slow);
    transform-origin: center;
  }

  .navbar--scrolled .navbar__hamburger-line {
    background: var(--color-moss);
  }

  /* Hamburger to X animation */
  .navbar__hamburger.is-active .navbar__hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .navbar__hamburger.is-active .navbar__hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .navbar__hamburger.is-active .navbar__hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* --- Mobile menu --- */
  .navbar__mobile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: 0 var(--space-4);
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      opacity var(--transition-base),
      padding var(--transition-base);
  }

  .navbar--mobile-open .navbar__mobile {
    max-height: 320px;
    opacity: 1;
    padding: var(--space-4) var(--space-4) var(--space-5);
  }

  /* When mobile menu is open, always use glass bg so links are readable */
  .navbar--mobile-open {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border-color: rgba(46, 64, 54, 0.1);
    border-radius: var(--radius-2xl);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
  }

  .navbar--mobile-open .navbar__logo {
    color: var(--color-moss);
  }

  .navbar--mobile-open .navbar__hamburger-line {
    background: var(--color-moss);
  }

  .navbar__mobile-link {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-moss);
    text-decoration: none;
    padding: var(--space-2) 0;
    transition: color var(--transition-base);
  }

  .navbar__mobile-link:hover {
    color: var(--color-clay);
  }

  .navbar__mobile-divider {
    width: 40px;
    height: 1px;
    background: var(--color-border);
  }

  .navbar__mobile-countdown {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .navbar__mobile-cta {
    width: 100%;
    text-align: center;
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-6);
  }
</style>
