---
import { siteConfig, getPaymentLink, getWhatsAppLink } from '../lib/config';
import CountdownTimer from './CountdownTimer.astro';

const paymentLink = getPaymentLink();
const whatsappLink = getWhatsAppLink('finalCta');
---

<section id="cta-final" aria-labelledby="final-cta-title" class="final-cta section" data-gsap="final-cta">
  <!-- Organic gradient overlays -->
  <div class="final-cta__gradient final-cta__gradient--1" aria-hidden="true"></div>
  <div class="final-cta__gradient final-cta__gradient--2" aria-hidden="true"></div>
  <div class="final-cta__gradient final-cta__gradient--3" aria-hidden="true"></div>

  <div class="container container--narrow final-cta__content">
    <!-- Main headline -->
    <div class="final-cta__headline">
      <p class="final-cta__line-1">Tu cuerpo no es el</p>
      <h2 id="final-cta-title" class="final-cta__line-2">enemigo.</h2>
      <p class="final-cta__line-3">Es el espejo.</p>
    </div>

    <!-- Supporting copy -->
    <p class="final-cta__copy">
      En 30 dias podes seguir peleando con la balanza, o podes elegir una forma nueva de tratarte.
    </p>

    <!-- Countdown -->
    <div class="final-cta__countdown">
      <p class="final-cta__countdown-label">El circulo cierra en:</p>
      <div class="final-cta__countdown-timer">
        <CountdownTimer variant="topbar" />
      </div>
    </div>

    <!-- CTAs -->
    <div class="final-cta__actions">
      <a
        href={paymentLink}
        target="_blank"
        rel="noopener noreferrer"
        data-utm="final-primary"
        class="btn btn--white final-cta__btn-primary"
      >
        {siteConfig.ctaMessages.finalCta}
      </a>
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        data-utm="final-secondary"
        class="btn btn--ghost final-cta__btn-secondary"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {siteConfig.ctaMessages.secondary}
      </a>
    </div>

    <!-- Trust line -->
    <div class="final-cta__trust">
      <span class="final-cta__trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        Respuesta en minutos
      </span>
      <span class="final-cta__trust-sep" aria-hidden="true">|</span>
      <span class="final-cta__trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Cupos limitados
      </span>
    </div>
  </div>
</section>

<style>
  /* --- Section --- */
  .final-cta {
    position: relative;
    overflow: hidden;
    background: var(--color-sage-dark);
    padding: var(--space-24) 0;
  }

  @media (min-width: 768px) {
    .final-cta {
      padding: var(--space-32) 0;
    }
  }

  /* --- Organic gradient overlays --- */
  .final-cta__gradient {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
  }

  .final-cta__gradient--1 {
    width: 500px;
    height: 500px;
    top: -15%;
    left: -10%;
    background: radial-gradient(circle, rgba(94, 114, 82, 0.6) 0%, transparent 70%);
  }

  .final-cta__gradient--2 {
    width: 400px;
    height: 400px;
    bottom: -10%;
    right: -5%;
    background: radial-gradient(circle, rgba(212, 145, 126, 0.15) 0%, transparent 70%);
  }

  .final-cta__gradient--3 {
    width: 300px;
    height: 300px;
    top: 40%;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(123, 143, 107, 0.4) 0%, transparent 70%);
  }

  /* --- Content --- */
  .final-cta__content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  /* --- Headline --- */
  .final-cta__headline {
    margin-bottom: var(--space-8);
  }

  .final-cta__line-1 {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: var(--text-2xl);
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-1);
  }

  .final-cta__line-2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: italic;
    font-size: var(--text-6xl);
    color: white;
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .final-cta__line-3 {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-xl);
    color: var(--color-blush-light);
    line-height: 1.3;
    margin-top: var(--space-3);
  }

  @media (min-width: 768px) {
    .final-cta__line-1 {
      font-size: var(--text-3xl);
    }
    .final-cta__line-2 {
      font-size: var(--text-8xl);
    }
    .final-cta__line-3 {
      font-size: var(--text-2xl);
    }
  }

  /* --- Copy --- */
  .final-cta__copy {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    max-width: 540px;
    margin: 0 auto var(--space-10);
    text-wrap: balance;
  }

  /* --- Countdown --- */
  .final-cta__countdown {
    margin-bottom: var(--space-10);
  }

  .final-cta__countdown-label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: var(--space-2);
  }

  .final-cta__countdown-timer {
    display: inline-block;
  }

  /* --- Actions --- */
  .final-cta__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 480px) {
    .final-cta__actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  .final-cta__btn-primary {
    font-weight: 700;
    font-size: var(--text-base);
    padding: var(--space-4) var(--space-8);
  }

  .final-cta__btn-secondary {
    font-size: var(--text-sm);
  }

  /* --- Trust line --- */
  .final-cta__trust {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.45);
  }

  @media (min-width: 480px) {
    .final-cta__trust {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-4);
    }
  }

  .final-cta__trust-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .final-cta__trust-sep {
    display: none;
    color: rgba(255, 255, 255, 0.2);
  }

  @media (min-width: 480px) {
    .final-cta__trust-sep {
      display: inline;
    }
  }
</style>
