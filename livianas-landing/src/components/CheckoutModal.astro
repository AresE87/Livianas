---
// src/components/CheckoutModal.astro
// Checkout Bricks embebido en modal — sin salir de livianas.com
// Requiere: PUBLIC_MP_PUBLIC_KEY en variables de entorno

const MP_PUBLIC_KEY = import.meta.env.PUBLIC_MP_PUBLIC_KEY;
---

<!-- BOTÓN TRIGGER -->
<button
  id="btn-comprar"
  class="btn-comprar"
>
  <span class="btn-comprar__text">Comprar Pack</span>
  <span class="btn-comprar__price">USD 15</span>
</button>

<!-- ══════════════════════════════════════════
     MODAL OVERLAY
═══════════════════════════════════════════ -->
<div
  id="checkout-modal"
  class="modal-overlay"
  style="display:none !important;"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <div id="modal-card" class="modal-card">

    <!-- Close button -->
    <button
      id="btn-modal-close"
      class="modal-close"
      aria-label="Cerrar"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M12 4L4 12M4 4l8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Header -->
    <div class="modal-header">
      <div class="modal-header__brand">LIVIANAS</div>
      <h2 id="modal-title" class="modal-header__title">Pack Bienestar</h2>
      <div class="modal-header__meta">
        <span class="modal-header__badge">Descarga inmediata</span>
        <span class="modal-header__sep">&middot;</span>
        <span class="modal-header__badge">Pago seguro</span>
      </div>
    </div>

    <!-- Price strip -->
    <div class="modal-price">
      <span class="modal-price__old">USD 24</span>
      <span class="modal-price__current">USD 15</span>
      <span class="modal-price__save">Ahorrás 38%</span>
    </div>

    <!-- PASO 1: Email -->
    <div id="step-email" class="modal-step">
      <p class="modal-step__hint">Ingresá tu email para recibir los materiales después de pagar.</p>
      <div class="modal-input-group">
        <label class="modal-input-group__label" for="modal-email">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Email
        </label>
        <input
          id="modal-email"
          type="email"
          placeholder="tu@email.com"
          autocomplete="email"
          class="modal-input"
        />
        <p id="email-error" class="modal-input-error hidden">Ingresá un email válido.</p>
      </div>
      <button id="btn-continuar" class="modal-btn-primary">
        Continuar al pago
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
    </div>

    <!-- PASO 2: Bricks -->
    <div id="step-bricks" class="modal-step hidden">
      <div id="bricks-loader" class="modal-loader">
        <div class="modal-loader__spinner"></div>
        <p class="modal-loader__text">Preparando tu checkout seguro...</p>
      </div>
      <div id="paymentBrick_container"></div>
    </div>

    <!-- PASO 3: Éxito -->
    <div id="step-success" class="modal-step hidden">
      <div class="modal-result">
        <div class="modal-result__icon modal-result__icon--success">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
            <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="modal-result__title">¡Pago confirmado!</h3>
        <p class="modal-result__text">Te enviamos los materiales a</p>
        <p id="success-email" class="modal-result__email"></p>
        <p class="modal-result__note">Revisá tu bandeja de entrada (y spam).<br/>Si en 5 minutos no llega, escribinos por WhatsApp.</p>
        <button id="btn-close-success" class="modal-btn-secondary">Cerrar</button>
      </div>
    </div>

    <!-- PASO 4: Error -->
    <div id="step-error" class="modal-step hidden">
      <div class="modal-result">
        <div class="modal-result__icon modal-result__icon--error">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 8v4m0 4h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="modal-result__title">Algo salió mal</h3>
        <p id="error-message" class="modal-result__text">Hubo un error al procesar tu pago. Podés intentarlo de nuevo.</p>
        <button id="btn-retry" class="modal-btn-primary">Intentar de nuevo</button>
      </div>
    </div>

    <!-- Security badge -->
    <div class="modal-security" id="security-badge">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      <span>Pago seguro con Mercado Pago &middot; SSL</span>
    </div>

  </div>
</div>

<style>
  /* ═══════════════════════════════════════════
     CHECKOUT MODAL — LIVIANAS DESIGN SYSTEM
  ═══════════════════════════════════════════ */

  /* ── Trigger Button ── */
  .btn-comprar {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    border: none;
    border-radius: var(--radius-full);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-base);
    color: white;
    background: var(--color-sage);
    box-shadow: var(--shadow-md), var(--shadow-glow-sage);
    cursor: pointer;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .btn-comprar::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transition: left var(--transition-slow);
  }

  .btn-comprar:hover::before {
    left: 100%;
  }

  .btn-comprar:hover {
    background: var(--color-sage-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg), var(--shadow-glow-sage);
  }

  .btn-comprar:active {
    transform: translateY(0) scale(0.98);
  }

  .btn-comprar__text {
    font-weight: 600;
  }

  .btn-comprar__price {
    background: rgba(255,255,255,0.2);
    padding: 2px 10px;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  /* ── Modal Overlay ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    background: rgba(44, 40, 37, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* ── Modal Card ── */
  .modal-card {
    position: relative;
    width: 100%;
    max-width: 420px;
    max-height: 92vh;
    overflow-y: auto;
    background: var(--color-cream);
    border: 1px solid rgba(123, 143, 107, 0.15);
    border-radius: var(--radius-2xl);
    box-shadow:
      0 25px 80px rgba(44, 40, 37, 0.2),
      0 8px 24px rgba(44, 40, 37, 0.08);
    animation: modal-enter 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes modal-enter {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* ── Close Button ── */
  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 10;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(44, 40, 37, 0.06);
    border: none;
    border-radius: var(--radius-full);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .modal-close:hover {
    background: rgba(44, 40, 37, 0.12);
    color: var(--color-carbon);
  }

  /* ── Header ── */
  .modal-header {
    text-align: center;
    padding: var(--space-8) var(--space-6) var(--space-5);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-white);
    border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  }

  .modal-header__brand {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--color-sage);
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .modal-header__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.4rem, 5vw, 1.65rem);
    color: var(--color-carbon);
    line-height: 1.2;
    margin-bottom: var(--space-3);
  }

  .modal-header__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .modal-header__badge {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .modal-header__sep {
    color: var(--color-text-light);
    font-size: 11px;
  }

  /* ── Price Strip ── */
  .modal-price {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-6);
    background: var(--color-sage-wash);
    border-bottom: 1px solid var(--color-border);
  }

  .modal-price__old {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-light);
    text-decoration: line-through;
  }

  .modal-price__current {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-2xl);
    color: var(--color-sage-dark);
    line-height: 1;
  }

  .modal-price__save {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-blush-dark);
    background: var(--color-blush-wash);
    padding: 2px 8px;
    border-radius: var(--radius-full);
  }

  /* ── Step containers ── */
  .modal-step {
    padding: var(--space-6);
  }

  .modal-step__hint {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-5);
    text-align: center;
  }

  /* ── Input Group ── */
  .modal-input-group {
    margin-bottom: var(--space-5);
  }

  .modal-input-group__label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-carbon);
    margin-bottom: var(--space-2);
  }

  .modal-input-group__label svg {
    color: var(--color-sage);
  }

  .modal-input {
    width: 100%;
    padding: 14px var(--space-4);
    border: 1.5px solid rgba(123, 143, 107, 0.2);
    border-radius: var(--radius-lg);
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--color-carbon);
    background: var(--color-white);
    outline: none;
    transition: all var(--transition-fast);
  }

  .modal-input::placeholder {
    color: var(--color-text-light);
  }

  .modal-input:focus {
    border-color: var(--color-sage);
    box-shadow: 0 0 0 3px rgba(123, 143, 107, 0.12);
  }

  .modal-input--error {
    border-color: var(--color-blush-dark) !important;
    box-shadow: 0 0 0 3px rgba(212, 145, 126, 0.15) !important;
  }

  .modal-input-error {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-blush-dark);
    margin-top: var(--space-2);
  }

  /* ── Buttons ── */
  .modal-btn-primary {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: 14px var(--space-6);
    border: none;
    border-radius: var(--radius-full);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-sm);
    color: white;
    background: var(--color-sage);
    cursor: pointer;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .modal-btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transition: left var(--transition-slow);
  }

  .modal-btn-primary:hover::before {
    left: 100%;
  }

  .modal-btn-primary:hover {
    background: var(--color-sage-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md), var(--shadow-glow-sage);
  }

  .modal-btn-primary:active {
    transform: translateY(0);
  }

  .modal-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-full);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    background: transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .modal-btn-secondary:hover {
    border-color: var(--color-sage);
    color: var(--color-sage);
    background: var(--color-sage-wash);
  }

  /* ── Loader ── */
  .modal-loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-8) 0;
  }

  .modal-loader__spinner {
    width: 32px;
    height: 32px;
    border: 2px solid var(--color-sage-wash);
    border-top-color: var(--color-sage);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .modal-loader__text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* ── Result (Success/Error) ── */
  .modal-result {
    text-align: center;
    padding: var(--space-4) 0;
  }

  .modal-result__icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-5);
  }

  .modal-result__icon--success {
    background: var(--color-sage-wash);
    color: var(--color-sage-dark);
  }

  .modal-result__icon--error {
    background: var(--color-blush-wash);
    color: var(--color-blush-dark);
  }

  .modal-result__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xl);
    color: var(--color-carbon);
    margin-bottom: var(--space-2);
  }

  .modal-result__text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }

  .modal-result__email {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-sage-dark);
    margin-bottom: var(--space-5);
  }

  .modal-result__note {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: var(--space-5);
  }

  /* ── Security Badge ── */
  .modal-security {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6) var(--space-5);
  }

  .modal-security svg {
    color: var(--color-text-light);
    flex-shrink: 0;
  }

  .modal-security span {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--color-text-light);
    letter-spacing: 0.01em;
  }

  /* ── Scrollbar ── */
  .modal-card::-webkit-scrollbar {
    width: 4px;
  }

  .modal-card::-webkit-scrollbar-track {
    background: transparent;
  }

  .modal-card::-webkit-scrollbar-thumb {
    background: var(--color-sand);
    border-radius: 2px;
  }

  /* ── Mobile tweaks ── */
  @media (max-width: 480px) {
    .modal-overlay {
      align-items: flex-end;
      padding: 0;
    }

    .modal-card {
      max-height: 95vh;
      border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
      animation: modal-enter-mobile 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes modal-enter-mobile {
      from {
        opacity: 0;
        transform: translateY(100%);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .modal-header {
      border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
    }
  }

  /* ── Hidden utility ── */
  .hidden {
    display: none !important;
  }
</style>

<!-- ══════════════════════════════════════════
     SDK DE MERCADO PAGO
═══════════════════════════════════════════ -->
<script src="https://sdk.mercadopago.com/js/v2" is:inline></script>

<script define:vars={{ MP_PUBLIC_KEY }}>

  // ── Referencias DOM ──────────────────────────────
  const modal          = document.getElementById('checkout-modal');
  const btnComprar     = document.getElementById('btn-comprar');
  const btnModalClose  = document.getElementById('btn-modal-close');
  const btnContinuar   = document.getElementById('btn-continuar');
  const btnRetry       = document.getElementById('btn-retry');
  const btnCloseSuccess= document.getElementById('btn-close-success');

  const stepEmail      = document.getElementById('step-email');
  const stepBricks     = document.getElementById('step-bricks');
  const stepSuccess    = document.getElementById('step-success');
  const stepError      = document.getElementById('step-error');

  const emailInput     = document.getElementById('modal-email');
  const emailError     = document.getElementById('email-error');
  const successEmail   = document.getElementById('success-email');
  const errorMsg       = document.getElementById('error-message');
  const bricksLoader   = document.getElementById('bricks-loader');
  const securityBadge  = document.getElementById('security-badge');
  const priceStrip     = document.querySelector('.modal-price');

  let currentEmail = '';
  let brickController = null;

  // ── Helpers de UI ────────────────────────────────
  function showModal()  { modal.style.setProperty('display', 'flex', 'important'); document.body.style.overflow = 'hidden'; }
  function hideModal()  { modal.style.setProperty('display', 'none', 'important'); document.body.style.overflow = ''; }

  function showStep(step) {
    [stepEmail, stepBricks, stepSuccess, stepError].forEach(s => s.classList.add('hidden'));
    step.classList.remove('hidden');
    // Ocultar badge y price en success/error
    if (step === stepSuccess || step === stepError) {
      securityBadge.style.display = 'none';
      btnModalClose.style.display = 'none';
      if (priceStrip) priceStrip.style.display = 'none';
    } else {
      securityBadge.style.display = 'flex';
      btnModalClose.style.display = 'flex';
      if (priceStrip) priceStrip.style.display = 'flex';
    }
  }

  // ── Validación de email ───────────────────────────
  function isValidEmail(v) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
  }

  // ── Abrir modal ───────────────────────────────────
  btnComprar?.addEventListener('click', () => {
    const landingEmail = document.getElementById('email-input')?.value || '';
    if (landingEmail && isValidEmail(landingEmail)) {
      emailInput.value = landingEmail;
    }
    showStep(stepEmail);
    showModal();
    setTimeout(() => emailInput.focus(), 100);
  });

  // ── Cerrar modal ──────────────────────────────────
  function closeModal() {
    hideModal();
    if (brickController) {
      brickController.unmount();
      brickController = null;
    }
    setTimeout(() => {
      showStep(stepEmail);
      securityBadge.style.display = 'flex';
      btnModalClose.style.display = 'flex';
      if (priceStrip) priceStrip.style.display = 'flex';
    }, 300);
  }

  btnModalClose?.addEventListener('click', closeModal);
  btnCloseSuccess?.addEventListener('click', closeModal);

  // Click fuera del modal
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.style.display !== 'none') closeModal();
  });

  // ── Continuar al pago ─────────────────────────────
  btnContinuar?.addEventListener('click', async () => {
    const email = emailInput.value.trim();
    if (!isValidEmail(email)) {
      emailError.classList.remove('hidden');
      emailInput.classList.add('modal-input--error');
      return;
    }
    emailError.classList.add('hidden');
    emailInput.classList.remove('modal-input--error');
    currentEmail = email;

    showStep(stepBricks);
    bricksLoader.style.display = 'flex';
    document.getElementById('paymentBrick_container').innerHTML = '';

    try {
      const res = await fetch('/api/create-preference', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (!res.ok) throw new Error('Error al crear preferencia');
      const { preference_id } = await res.json();

      await initBricks(preference_id);

    } catch (err) {
      console.error(err);
      errorMsg.textContent = 'No pudimos iniciar el checkout. Intentá de nuevo.';
      showStep(stepError);
    }
  });

  // ── Inicializar Wallet Brick ──────────────────────
  // Wallet Brick: muestra botón "Pagar con Mercado Pago"
  // El usuario paga en MP y vuelve via back_urls de la preferencia.
  // El webhook se encarga de enviar los materiales por email.
  async function initBricks(preferenceId) {
    const mp = new MercadoPago(MP_PUBLIC_KEY, { locale: 'es-UY' });
    const bricksBuilder = mp.bricks();

    brickController = await bricksBuilder.create('wallet', 'paymentBrick_container', {
      initialization: {
        preferenceId: preferenceId,
        redirectMode: 'self',
      },
      customization: {
        visual: {
          buttonHeight: '48px',
        },
      },
      callbacks: {
        onReady: () => {
          bricksLoader.style.display = 'none';
        },
        onError: (error) => {
          console.error('Brick error:', error);
          errorMsg.textContent = 'Error en el checkout. Intentá de nuevo.';
          showStep(stepError);
        },
      },
    });
  }

  // ── Reintentar ────────────────────────────────────
  btnRetry?.addEventListener('click', async () => {
    if (!currentEmail) {
      showStep(stepEmail);
      return;
    }
    showStep(stepBricks);
    bricksLoader.style.display = 'flex';
    document.getElementById('paymentBrick_container').innerHTML = '';

    try {
      const res = await fetch('/api/create-preference', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: currentEmail }),
      });
      const { preference_id } = await res.json();
      await initBricks(preference_id);
    } catch(err) {
      errorMsg.textContent = 'No pudimos reiniciar el checkout.';
    }
  });

  // ── Input interactions ──────────────────────────
  emailInput?.addEventListener('input', () => {
    emailError.classList.add('hidden');
    emailInput.classList.remove('modal-input--error');
  });

  emailInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') btnContinuar.click();
  });

</script>
