---
import { includesData } from '../lib/config';

// Soft botanical/wellness SVG icons — one per card
const icons = [
  // 1. Coaching — Lotus flower (group guidance, growth)
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M18 30c0-6-4-11-9-14 2-5 6-9 9-12 3 3 7 7 9 12-5 3-9 8-9 14z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M18 30c0-7 5-13 12-15-1-4-4-7-7-9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
    <path d="M18 30c0-7-5-13-12-15 1-4 4-7 7-9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
    <circle cx="18" cy="12" r="2" fill="currentColor" opacity="0.3"/>
  </svg>`,
  // 2. Community — Heart with connection
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M18 29s-10-6.5-10-14a6 6 0 0 1 10-4.5A6 6 0 0 1 28 15c0 7.5-10 14-10 14z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M14 18c1.5 1.5 4 2.5 4 2.5s2.5-1 4-2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
  </svg>`,
  // 3. Nutrition — Leaf
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M8 30c0-12 9-20 22-22C28 20 19 28 8 30z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M8 30C17 21 21 15 30 8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
    <path d="M15 23c2-3 5-6 9-8" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3"/>
  </svg>`,
  // 4. Movement — Sun (energy, vitality)
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="18" cy="18" r="6" stroke="currentColor" stroke-width="1.4"/>
    <path d="M18 6v4M18 26v4M6 18h4M26 18h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    <path d="M9.5 9.5l2.8 2.8M23.7 23.7l2.8 2.8M9.5 26.5l2.8-2.8M23.7 12.3l2.8-2.8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
  </svg>`,
  // 5. Spiritual — Star / sparkle
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M18 4l2 10 10 2-10 2-2 10-2-10L6 16l10-2z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M27 7l1 4 4 1-4 1-1 4-1-4-4-1 4-1z" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
  </svg>`,
  // 6. Recordings — Play circle (soft)
  `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="18" cy="18" r="13" stroke="currentColor" stroke-width="1.4"/>
    <path d="M15 12.5l9 5.5-9 5.5z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
];

// Alternating soft background washes for cards
const cardBackgrounds = [
  'var(--color-white)',
  'var(--color-blush-wash)',
  'var(--color-sage-wash)',
  'var(--color-lavender-wash)',
  'var(--color-blush-wash)',
  'var(--color-sage-wash)',
];

// Icon accent color per card to complement the background
const iconColors = [
  'var(--color-sage)',
  'var(--color-blush)',
  'var(--color-sage-dark)',
  'var(--color-lavender)',
  'var(--color-blush-dark)',
  'var(--color-sage)',
];
---

<section id="incluye" aria-labelledby="archive-title" class="archive-section section" data-gsap="archive-section">
  <div class="container">
    <!-- Header -->
    <div class="archive-header" data-gsap="archive-header">
      <h2 id="archive-title" class="archive-title">
        <span class="archive-title-serif">Todo lo que incluye</span>
        <br />
        <span class="archive-title-sans">tu experiencia.</span>
      </h2>
      <p class="archive-subtitle">
        Cada elemento fue pensado para acompa&ntilde;arte en cuerpo, emoci&oacute;n y esp&iacute;ritu.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="archive-grid" role="list">
      {includesData.map((item, i) => (
        <article
          class="archive-card"
          data-gsap="archive-card"
          role="listitem"
          style={`--card-bg: ${cardBackgrounds[i]}; --icon-color: ${iconColors[i]};`}
        >
          <div class="archive-card-inner">
            <div class="archive-card-icon" set:html={icons[i]} />
            <h3 class="archive-card-title">{item.title}</h3>
            <p class="archive-card-desc">{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* --- Section --- */
  .archive-section {
    background: var(--color-cream);
    padding: var(--space-20) 0 var(--space-24);
  }

  /* --- Header --- */
  .archive-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .archive-title {
    margin-bottom: var(--space-4);
    line-height: 1.2;
  }

  .archive-title-serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: var(--text-4xl);
    color: var(--color-carbon);
    display: inline;
  }

  .archive-title-sans {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-3xl);
    color: var(--color-blush);
    display: inline-block;
    margin-top: var(--space-1);
  }

  @media (min-width: 768px) {
    .archive-title-serif {
      font-size: var(--text-5xl);
    }
    .archive-title-sans {
      font-size: var(--text-4xl);
    }
  }

  .archive-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* --- Card Grid --- */
  .archive-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 1080px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .archive-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .archive-grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: var(--space-8);
    }
  }

  /* --- Card --- */
  .archive-card {
    background: var(--card-bg);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    position: relative;
    box-shadow: var(--shadow-sm);
  }

  .archive-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .archive-card-inner {
    padding: var(--space-8) var(--space-6);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .archive-card-inner {
      padding: var(--space-10) var(--space-8);
    }
  }

  /* --- Icon --- */
  .archive-card-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.7);
    border-radius: var(--radius-xl);
    color: var(--icon-color);
    margin-bottom: var(--space-5);
    flex-shrink: 0;
  }

  /* --- Title --- */
  .archive-card-title {
    font-family: var(--font-outfit);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-carbon);
    line-height: 1.35;
    margin-bottom: var(--space-2);
  }

  @media (min-width: 768px) {
    .archive-card-title {
      font-size: var(--text-xl);
    }
  }

  /* --- Description --- */
  .archive-card-desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
  }
</style>
