---
// VIDEO DE ANA PRESENTANDO EL MÉTODO
// Cuando Ana grabe el video, reemplazar el placeholder con:
//   <iframe> de YouTube/Vimeo o un <video src="...">
---

<section id="metodo" aria-labelledby="video-title" class="video-section section">
  <div class="container container--narrow">
    <div class="video-header" data-gsap="video">
      <span class="video-label">Conoc&eacute; el m&eacute;todo Livianas</span>
      <h2 id="video-title" class="video-title">
        <span class="video-title__serif">Ana te explica</span>
        <span class="video-title__sans">c&oacute;mo funciona</span>
      </h2>
    </div>

    <div class="video-wrapper" data-gsap="video-player">
      <div class="video-placeholder">
        <div class="play-button" aria-hidden="true">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
            <circle cx="28" cy="28" r="28" fill="var(--color-sage)" opacity="0.9"/>
            <path d="M22 17l16 11-16 11V17z" fill="white"/>
          </svg>
        </div>
        <p class="placeholder-text">Video pr&oacute;ximamente</p>
        <p class="placeholder-sub">Ana te cuenta en 2 minutos de qu&eacute; se trata LIVIANAS</p>
      </div>
    </div>
  </div>
</section>

<style>
  .video-section {
    background: var(--color-cream);
  }

  /* --- Header --- */
  .video-header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .video-label {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-sage);
    margin-bottom: var(--space-4);
  }

  .video-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    line-height: 1.1;
  }

  .video-title__serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: var(--text-4xl);
    color: var(--color-carbon);
    letter-spacing: -0.02em;
  }

  .video-title__sans {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-2xl);
    color: var(--color-carbon);
    letter-spacing: -0.01em;
    margin-top: var(--space-1);
  }

  @media (min-width: 768px) {
    .video-title__serif {
      font-size: var(--text-5xl);
    }
    .video-title__sans {
      font-size: var(--text-3xl);
    }
  }

  /* --- Video wrapper --- */
  .video-wrapper {
    max-width: 720px;
    margin: 0 auto;
  }

  .video-placeholder {
    position: relative;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, var(--color-sage-wash), var(--color-blush-wash));
    border-radius: var(--radius-2xl);
    border: 2px dashed var(--color-sage);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    cursor: default;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .video-placeholder:hover {
    border-color: var(--color-sage-dark);
    box-shadow: var(--shadow-md);
  }

  .play-button {
    opacity: 0.85;
    transition: opacity var(--transition-base), transform var(--transition-base);
  }

  .video-placeholder:hover .play-button {
    opacity: 1;
    transform: scale(1.08);
  }

  .placeholder-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-carbon);
    margin: 0;
  }

  .placeholder-sub {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    max-width: 300px;
    text-align: center;
    line-height: 1.5;
  }
</style>
