---
// VIDEO DE ANA PRESENTANDO EL MÉTODO
// Cuando Ana grabe el video, reemplazar el placeholder con:
//   <lite-youtube videoid="YOUTUBE_ID" /> o un <video> / <iframe>
---

<section id="video-ana" aria-labelledby="video-title" class="section">
  <div class="container container--narrow text-center animate-on-scroll">

    <!-- Título de la sección -->
    <p class="text-xs font-semibold tracking-[0.15em] uppercase text-[var(--color-sage-dark)] mb-3">Conocé el método</p>
    <h2 id="video-title" class="font-[var(--font-display)] font-bold text-[var(--text-2xl)] md:text-[var(--text-3xl)] text-[var(--color-dark)] leading-snug mb-6">
      Ana te explica cómo funciona
    </h2>

    <!-- Video placeholder -->
    <div class="video-wrapper">
      <div class="video-placeholder">
        <!-- Play button -->
        <div class="play-button" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="24" r="24" fill="var(--color-sage)" opacity="0.9"/>
            <path d="M19 15l14 9-14 9V15z" fill="white"/>
          </svg>
        </div>
        <p class="placeholder-text">Video próximamente</p>
        <p class="placeholder-sub">Ana te cuenta en 2 minutos de qué se trata LIVIANAS</p>
      </div>
    </div>

    <!-- Frase de Ana debajo del video -->
    <blockquote class="manifesto">
      <p class="font-[var(--font-display)] font-bold italic text-[var(--text-xl)] md:text-[var(--text-2xl)] text-[var(--color-dark)] leading-snug mb-3">
        "No necesitás más fuerza de voluntad. Necesitás entender por qué hacés lo que hacés."
      </p>
      <footer class="text-sm text-[var(--color-sage-dark)] font-medium">
        — Ana, creadora del Método Livianas
      </footer>
    </blockquote>

    <!-- Pilares -->
    <div class="pillars">
      <div class="pillar">
        <span class="pillar-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </span>
        <h3 class="font-bold text-sm text-[var(--color-dark)] mb-1">Sin dietas restrictivas</h3>
        <p class="text-sm text-[var(--color-gray)]">Alimentación consciente con guía de porciones simple</p>
      </div>
      <div class="pillar">
        <span class="pillar-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </span>
        <h3 class="font-bold text-sm text-[var(--color-dark)] mb-1">Enfoque emocional</h3>
        <p class="text-sm text-[var(--color-gray)]">Entendé por qué comés lo que comés</p>
      </div>
      <div class="pillar">
        <span class="pillar-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </span>
        <h3 class="font-bold text-sm text-[var(--color-dark)] mb-1">Poder del grupo</h3>
        <p class="text-sm text-[var(--color-gray)]">8 mujeres que se sostienen mutuamente</p>
      </div>
    </div>
  </div>
</section>

<style>
  .video-wrapper {
    max-width: 720px;
    margin: 0 auto var(--space-8);
  }

  .video-placeholder {
    position: relative;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, var(--color-sage-wash) 0%, var(--color-warm-pale) 100%);
    border-radius: var(--radius-lg);
    border: 2px dashed var(--color-sage);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    cursor: default;
    transition: border-color 0.3s ease;
  }

  .video-placeholder:hover {
    border-color: var(--color-sage-dark);
  }

  .play-button {
    opacity: 0.8;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .video-placeholder:hover .play-button {
    opacity: 1;
    transform: scale(1.05);
  }

  .placeholder-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-dark);
    margin: 0;
  }

  .placeholder-sub {
    font-size: var(--text-sm);
    color: var(--color-gray);
    margin: 0;
    max-width: 280px;
  }

  .manifesto {
    padding: var(--space-6) var(--space-4);
    margin-bottom: var(--space-4);
  }

  .pillars {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  @media (min-width: 480px) {
    .pillars {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pillar {
    background: white;
    border-radius: var(--radius-md);
    padding: var(--space-6) var(--space-4);
    text-align: center;
    border: 1px solid var(--color-sage-wash);
  }

  .pillar-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-sage-wash);
    color: var(--color-sage-dark);
    margin-bottom: var(--space-3);
  }
</style>
