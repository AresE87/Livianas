---
import SectionLabel from './SectionLabel.astro';
import { weeksData } from '../lib/config';
---

<section id="programa" aria-labelledby="programa-title" class="section">
  <div class="container animate-on-scroll">
    <div class="text-center mb-10">
      <SectionLabel text="EL PROGRAMA" />
      <h2 id="programa-title" class="font-[var(--font-display)] font-bold text-[var(--text-3xl)] md:text-[var(--text-4xl)] text-[var(--color-dark)] mb-3">
        4 semanas que cambian todo
      </h2>
      <p class="text-lg text-[var(--color-gray)] max-w-[600px] mx-auto">
        Cada semana trabaja una dimensión diferente de tu bienestar. Juntas construyen una transformación completa.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" role="list">
      {weeksData.map((week, index) => (
        <article class="week-card" role="listitem" style={`background: ${week.gradient};`}>
          <div class="text-sm font-medium text-[var(--color-gray)] mb-2">Semana {week.number}</div>
          <div class="text-[32px] mb-3 animation-float" style={`animation-delay: ${index * 0.5}s;`} aria-hidden="true">
            {week.emoji}
          </div>
          <h3 class="font-bold text-xl uppercase tracking-[0.05em] text-[var(--color-dark)] mb-1">
            {week.title}
          </h3>
          <p class="font-medium text-base text-[var(--color-sage-dark)] mb-3">
            {week.name}
          </p>
          <p class="text-sm text-[var(--color-gray)] leading-relaxed">
            {week.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .week-card {
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-align: center;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .week-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }
</style>
